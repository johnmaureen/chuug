    "accordions_M9ze79": {
      "type": "accordions",
      "blocks": {
        "accordion_tab_1_t6dTx3": {
          "type": "accordion_tab_1",
          "settings": {
            "accordion_title_tab_1": "How long will my Chuug tankard keep my drink cold?",
            "accordion_text_tab_1": "Up to 2 hours of frosty goodness! Your Chuug tankard is designed to keep your brew at the perfect temperature, ensuring you enjoy every sip as much as the first."
          }
        },
        "accordion_tab_1_x7ccWB": {
          "type": "accordion_tab_1",
          "settings": {
            "accordion_title_tab_1": "is it dishwasher safe?",
            "accordion_text_tab_1": "YES! Just unscrew the stainless steel core and put in the dishwasher as normal. For the wooden outer, wipe clean with a damp cloth - HANDWASH ONLY."
          }
        },
        "accordion_tab_1_mF3ELh": {
          "type": "accordion_tab_1",
          "settings": {
            "accordion_title_tab_1": "Can I put hot beverages in my Chuug tankard?",
            "accordion_text_tab_1": "Yes, it will keep hot drinks hot for up to 2 hours. Your Chuug isn't just for cold ones – it's a year-round companion."
          }
        },
        "accordion_tab_1_3eTKRt": {
          "type": "accordion_tab_1",
          "settings": {
            "accordion_title_tab_1": "How do I look after my Chuug tankard?",
            "accordion_text_tab_1": "Hand wash the exterior wood and SmartRope handle. Unscrew the inner metal core and wash how you like! This part is dishwasher-safe.\n\nThe wood might like an occasional rub with food-grade mineral oil to keep it looking sharp."
          }
        },
        "accordion_tab_1_V7gKe9": {
          "type": "accordion_tab_1",
          "settings": {
            "accordion_title_tab_1": "What does the CHUUG logo/coin mean?",
            "accordion_text_tab_1": "The coin symbol on your CHUUG is inspired by ancient “treasure coins” from the age of exploration. The cross at its centre represents craftsmanship, connection, and the spirit of giving - values rooted in the Viking Gebo rune, which also inspired our logo. The surrounding markings echo the mint marks once used by old-world artisans to certify their work. It’s our way of marking each CHUUG as a piece made with purpose, strength, and heritage."
          }
        },
        "accordion_tab_2_mWMj93": {
          "type": "accordion_tab_2",
          "settings": {
            "accordion_title_tab_2": "HOW LONG WILL IT TAKE FOR MY ORDER TO ARRIVE?",
            "accordion_text_tab_2": "Your CHUUG is eager to meet you!\nJust enter your country and address so we can provide an accurate ETA. Add your items to the cart and proceed through checkout - your despatch and delivery dates will be shown just above the order confirmation button."
          }
        },
        "accordion_tab_2_UihAen": {
          "type": "accordion_tab_2",
          "settings": {
            "accordion_title_tab_2": "DO YOU OFFER INTERNATIONAL SHIPPING?",
            "accordion_text_tab_2": "Yes! Chuug tankards are ready to travel the world. We ship internationally because everyone deserves cold beer."
          }
        },
        "accordion_tab_2_WfLQpf": {
          "type": "accordion_tab_2",
          "settings": {
            "accordion_title_tab_2": "HOW DO I TRACK MY ORDER?",
            "accordion_text_tab_2": "We'll keep you in the loop! As soon as your Chuug begins its journey, we'll send you an email with tracking information. You can follow your tankard's adventure right to your doorstep."
          }
        },
        "accordion_tab_2_6LPDJP": {
          "type": "accordion_tab_2",
          "settings": {
            "accordion_title_tab_2": "WHAT IF MY CHUUG ARRIVES DAMAGED?",
            "accordion_text_tab_2": "No worries, we've got you covered! If your Chuug arrives looking less than perfect, just send us a photo. We'll replace it faster than you can say \"cheers\" - no questions asked."
          }
        }
      },
