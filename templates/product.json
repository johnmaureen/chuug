    "image_with_text_UmWYLd": {
      "type": "image-with-text",
      "blocks": {
        "heading_tcEKeq": {
          "type": "heading",
          "settings": {
            "heading": "SmartRope™",
            "heading_size": "h1"
          }
        },
        "text_Hfw9EC": {
          "type": "text",
          "settings": {
            "text": "<p>Our SmartRope™ technology offers the look and feel of traditional hemp while eliminating its drawbacks. Unlike natural hemp, SmartRope™ doesn't absorb water, meaning it won't warp, stretch, or rot over time. This ensures that our CHUUG handles remain durable and comfortable for a lifetime.<br/><br/>Plus, SmartRope™ is easy to maintain, requiring only a simple hand wash with standard dishwashing liquid, making it both practical and long-lasting.</p>",
            "text_style": "body"
          }
        },
        "button_D6EPf3": {
