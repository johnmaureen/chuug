{{ 'benefits.css' | asset_url | stylesheet_tag }}

<section class="benefits-section">
  <div class="benefits-article">
    <!-- Article Header -->
    <header class="benefits-header">
      <h1 class="benefits-title">{{ section.settings.section_title | strip_html }}</h1>
      <p class="benefits-subtitle">{{ section.settings.section_subtitle }}</p>
    </header>

    <!-- Article Content -->
    <div class="benefits-content">
      <!-- Article Details (Tabs) -->
      <div class="benefits-details">
        <div class="detail-item active" data-tab="1">
          <div class="detail-title">{{ section.settings.tab_1_title }}</div>
        </div>
        <div class="detail-item inactive" data-tab="2">
          <div class="detail-title">{{ section.settings.tab_2_title }}</div>
        </div>
      </div>
    </div>

    <!-- Comparison Section -->
    <div class="comparison-section">
      <div class="comparison-container">
        {% for block in section.blocks %}
          {% if block.type == 'comparison_section' %}
            <div class="comparison-item">
              <h3 class="comparison-title">{{ block.settings.section_title }}</h3>
              
              <div class="comparison-detail">
                <div class="detail-icon {{ block.settings.section_type }}">
                  {% if block.settings.section_type == 'negative' %}
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none">
                      <path d="M2 2L14 14" stroke="#DBE188" stroke-width="3.6"/>
                      <path d="M14 2L2 14" stroke="#DBE188" stroke-width="3.6"/>
                    </svg>
                  {% else %}
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="16" viewBox="0 0 20 16" fill="none">
                      <path d="M18 2L6 14" stroke="#0D2026" stroke-width="3.6"/>
                      <path d="M2 8L8 14" stroke="#0D2026" stroke-width="3.6"/>
                    </svg>
                  {% endif %}
                </div>
                <div class="detail-text">{{ block.settings.point_1 }}</div>
              </div>
              
              <div class="comparison-detail">
                <div class="detail-icon {{ block.settings.section_type }}">
                  {% if block.settings.section_type == 'negative' %}
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none">
                      <path d="M2 2L14 14" stroke="#DBE188" stroke-width="3.6"/>
                      <path d="M14 2L2 14" stroke="#DBE188" stroke-width="3.6"/>
                    </svg>
                  {% else %}
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="16" viewBox="0 0 20 16" fill="none">
                      <path d="M18 2L6 14" stroke="#0D2026" stroke-width="3.6"/>
                      <path d="M2 8L8 14" stroke="#0D2026" stroke-width="3.6"/>
                    </svg>
                  {% endif %}
                </div>
                <div class="detail-text">{{ block.settings.point_2 }}</div>
              </div>
              
              <div class="comparison-detail">
                <div class="detail-icon {{ block.settings.section_type }}">
                  {% if block.settings.section_type == 'negative' %}
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none">
                      <path d="M2 2L14 14" stroke="#DBE188" stroke-width="3.6"/>
                      <path d="M14 2L2 14" stroke="#DBE188" stroke-width="3.6"/>
                    </svg>
                  {% else %}
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="16" viewBox="0 0 20 16" fill="none">
                      <path d="M18 2L6 14" stroke="#0D2026" stroke-width="3.6"/>
                      <path d="M2 8L8 14" stroke="#0D2026" stroke-width="3.6"/>
                    </svg>
                  {% endif %}
                </div>
                <div class="detail-text">{{ block.settings.point_3 }}</div>
              </div>
            </div>
            
            {% unless forloop.last %}
              <!-- Vertical Divider -->
              <div class="comparison-divider"></div>
            {% endunless %}
          {% endif %}
        {% endfor %}
      </div>
    </div>

    <!-- Add to Cart Button -->
    <a href="{{ section.settings.button_url | default: '#hero-section' }}" class="add-to-cart-button">
      <span class="add-to-cart-text">{{ section.settings.button_text }}</span>
    </a>
  </div>

</section>

{% schema %}
{
  "name": "Benefits",
  "settings": [
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Title",
      "default": "Time to Ditch the Dainty Glassware"
    },
    {
      "type": "text",
      "id": "section_subtitle",
      "label": "Section Subtitle",
      "default": "Leave that for Prosecco and Bucks-fizz. We're here for real drinks."
    },
    {
      "type": "text",
      "id": "tab_1_title",
      "label": "Tab 1 Title",
      "default": "SMARTROPE TECH"
    },
    {
      "type": "text",
      "id": "tab_2_title",
      "label": "Tab 2 Title",
      "default": "THE CHUUG RITUAL"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "ADD TO CART"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    }
  ],
  "blocks": [
    {
      "type": "comparison_section",
      "name": "Comparison Section",
      "settings": [
        {
          "type": "text",
          "id": "section_title",
          "label": "Section Title",
          "default": "Slippery Slope"
        },
        {
          "type": "select",
          "id": "section_type",
          "label": "Section Type",
          "options": [
            {
              "value": "negative",
              "label": "Negative"
            },
            {
              "value": "positive",
              "label": "Positive"
            }
          ],
          "default": "negative"
        },
        {
          "type": "text",
          "id": "point_1",
          "label": "Point 1",
          "default": "Flimsy and fragile handles ruin your ritual."
        },
        {
          "type": "text",
          "id": "point_2",
          "label": "Point 2",
          "default": "Uncomfortable ceramic & metal handles."
        },
        {
          "type": "text",
          "id": "point_3",
          "label": "Point 3",
          "default": "Slippy handles lead to spillage, not build for men."
        }
      ],
      "limit": 2
    }
  ],
  "presets": [
    {
      "name": "Benefits",
      "blocks": [
        {
          "type": "comparison_section",
          "settings": {
            "section_title": "Slippery Slope",
            "section_type": "negative",
            "point_1": "Flimsy and fragile handles ruin your ritual.",
            "point_2": "Uncomfortable ceramic & metal handles.",
            "point_3": "Slippy handles lead to spillage, not build for men."
          }
        },
        {
          "type": "comparison_section",
          "settings": {
            "section_title": "Rope Revolution",
            "section_type": "positive",
            "point_1": "A durable, comfortable grip built for men.",
            "point_2": "Anti-bacterial means no fur growing.",
            "point_3": "Waterproof technology keeps it dry and fresh."
          }
        }
      ]
    }
  ]
}
{% endschema %}
