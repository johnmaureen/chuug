<link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"
>
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

<section class="tw-bg-chuug-gainsboro tw-rounded-ss-[2em] tw-rounded-se-[2em] tw-px-[1rem] tw-pt-[2.5rem] tw-pb-[6rem] md:tw-pt-[3.75em] md:tw-pb-32">
  <div class="tw-container tw-px-0 tw-flex tw-flex-col tw-justify-center tw-items-center tw-gap-y-[2rem] lg:tw-gap-y-[8rem]">
    <header class="tw-flex tw-flex-col tw-justify-center tw-max-w-[60em] tw-gap-y-4">
      <div class="tw-text-[3.2rem] tw-font-bold tw-leading-[1.1] tw-text-center tw-text-chuug-dark-navy tw-capitalize md:tw-text-[4.8rem]">
        {{ section.settings.section_title }}
      </div>
      <p class="tw-text-center tw-text-[1.6rem] tw-leading-[1.5] tw-text-chuug-dark-navy md:tw-text-[1.8rem]">
        {{ section.settings.section_description }}
      </p>
    </header>
    <div class="tw-group tw-flex tw-flex-col tw-gap-y-[2rem] tw-gap-x-[3.75em] tw-w-full tw-max-w-[120rem] xl:tw-flex-row lg:tw-h-fit">
      <div class="tw-relative tw-w-fit tw-mx-auto md:tw-w-[32rem] md:tw-h-[32rem] lg:tw-w-[30.75em] lg:tw-h-[30.75em]">
        <img
          data-src="{{ section.settings.image_one | image_url }}"
          alt=""
          width="100%"
          height="100%"
          class="lazyload tw-w-[30rem] tw-h-[30rem] md:tw-h-[32rem] lg:my-auto lg:tw-w-[30.75em] lg:tw-h-[30.75em]"
        >
        <div class="badge-container tw-absolute tw-top-[-2rem] tw-left-[-2rem] tw-w-[6rem] tw-h-[6rem] md:tw-w-[8rem] md:tw-h-[8rem] xl:!tw-top-[-2rem]">
          <div class="tw-relative md:!tw-flex md:tw-justify-center md:tw-items-center">
            <img
              data-src="https://cdn.shopify.com/s/files/1/0799/4307/4111/files/badge.png?v=1729107293"
              alt="Badge"
              width="100%"
              height="100%"
              class="lazyload tw-w-[6rem] tw-h-[6rem] md:tw-w-[8rem] md:tw-h-[8rem]"
            >
            <p class="tw-absolute tw-text-center tw-text-black tw-top-[0.7rem] tw-leading-[1.8rem] tw-font-bold tw-text-[1.4rem] md:tw-mt-[0.8rem] md:tw-w-[6rem] ">
              UP TO <span class="discount">{{ section.settings.discount_number }}%</span> OFF
            </p>
          </div>
        </div>
      </div>

      <div class="swiper fading-text-carousel-swiper tw-w-full tw-max-w-[65rem] tw-h-[36rem] tw-gap-y-[2rem] md:tw-h-[30rem] lg:tw-h-[46rem] xl:tw-h-[49rem]">
        <div class="swiper-wrapper tw-h-[20rem]">
          {% for i in (1..3) %}
            <div class="swiper-slide slide-number-{{ i }}">
              <div class="tw-flex-1 tw-flex tw-flex-col tw-gap-y-5">
                <div class="feature-one tw-px-4 tw-flex tw-flex-col tw-gap-y-4">
                  <div class="tw-flex tw-items-center tw-gap-x-4">
                    <div class="tw-rounded-full tw-bg-[#6093A3] !tw-w-[3.5rem] tw-h-[3.5rem] tw-flex tw-justify-center tw-items-center">
                      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                        <path d="M9.48632 18.3946C9.30707 18.5748 9.06265 18.6754 8.80864 18.6754C8.55463 18.6754 8.31021 18.5748 8.13096 18.3946L2.71912 12.9818C2.15743 12.4201 2.15743 11.5095 2.71912 10.9487L3.3968 10.2711C3.9585 9.70936 4.86814 9.70936 5.42984 10.2711L8.80864 13.6499L17.9386 4.5199C18.5003 3.95821 19.4109 3.95821 19.9716 4.5199L20.6493 5.19758C21.211 5.75928 21.211 6.66988 20.6493 7.23061L9.48632 18.3946Z" fill="white"/>
                      </svg>
                    </div>
                    <h3 class="tw-text-[2.4rem] tw-font-bold tw-leading-[1.1] tw-w-11/12">
                      {{ section.settings.feature_one_title }}
                    </h3>
                  </div>
                  <p class="tw-text-[1.6rem] tw-leading-[1.5] tw-text-chuug-dark-navy">
                    {{ section.settings.feature_one_description }}
                  </p>
                </div>
                <div class="feature-two tw-px-4 tw-flex tw-flex-col tw-gap-y-4">
                  <div class="tw-flex tw-items-center tw-gap-x-4">
                    <div class="tw-rounded-full tw-bg-[#6093A3] !tw-w-[3.5rem] tw-h-[3.5rem] tw-flex tw-justify-center tw-items-center">
                      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                        <path d="M9.48632 18.3946C9.30707 18.5748 9.06265 18.6754 8.80864 18.6754C8.55463 18.6754 8.31021 18.5748 8.13096 18.3946L2.71912 12.9818C2.15743 12.4201 2.15743 11.5095 2.71912 10.9487L3.3968 10.2711C3.9585 9.70936 4.86814 9.70936 5.42984 10.2711L8.80864 13.6499L17.9386 4.5199C18.5003 3.95821 19.4109 3.95821 19.9716 4.5199L20.6493 5.19758C21.211 5.75928 21.211 6.66988 20.6493 7.23061L9.48632 18.3946Z" fill="white"/>
                      </svg>
                    </div>
                    <h3 class="tw-text-[2.4rem] tw-font-bold tw-leading-[1.1] tw-w-11/12">
                      {{ section.settings.feature_two_title }}
                    </h3>
                  </div>
                  <p class="tw-text-[1.6rem] tw-leading-[1.5] tw-text-chuug-dark-navy">
                    {{ section.settings.feature_two_description }}
                  </p>
                </div>
                <div class="feature-three tw-px-4 tw-flex tw-flex-col tw-gap-y-4">
                  <div class="tw-flex tw-items-center tw-gap-x-4">
                    <div class="tw-rounded-full tw-bg-[#6093A3] !tw-w-[3.5rem] tw-h-[3.5rem] tw-flex tw-justify-center tw-items-center">
                      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                        <path d="M9.48632 18.3946C9.30707 18.5748 9.06265 18.6754 8.80864 18.6754C8.55463 18.6754 8.31021 18.5748 8.13096 18.3946L2.71912 12.9818C2.15743 12.4201 2.15743 11.5095 2.71912 10.9487L3.3968 10.2711C3.9585 9.70936 4.86814 9.70936 5.42984 10.2711L8.80864 13.6499L17.9386 4.5199C18.5003 3.95821 19.4109 3.95821 19.9716 4.5199L20.6493 5.19758C21.211 5.75928 21.211 6.66988 20.6493 7.23061L9.48632 18.3946Z" fill="white"/>
                      </svg>
                    </div>
                    <h3 class="tw-text-[2.4rem] tw-font-bold tw-leading-[1.1] tw-w-11/12">
                      {{ section.settings.feature_three_title }}
                    </h3>
                  </div>
                  <p class="tw-text-[1.6rem] tw-leading-[1.5] tw-text-chuug-dark-navy">
                    {{ section.settings.feature_three_description }}
                  </p>
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
        <div class="swiper-pagination !tw-block"></div>
      </div>
    </div>
  </div>
  <a
    href="#hero-section"
    type="submit"
    class="cta-button tw-container tw-text-[2rem] tw-text-white tw-leading-[1] tw-font-bold tw-p-0 tw-uppercase tw-bg-no-repeat tw-w-full tw-max-w-[34.5rem] tw-h-[4.375em] tw-rounded-[1.25em] tw-flex tw-justify-center tw-items-center tw-mt-[2rem] md:tw-mt-[6rem]"
    style="
      background-image: url('https://cdn.shopify.com/s/files/1/0799/4307/4111/files/cta-button-white-bg.png?v=1729273009');
      background-size: contain;
      background-position: center;
    "
  >
    {{ section.settings.button_text }}
  </a>
</section>

<script>
    var swiper = new Swiper('.fading-text-carousel-swiper', {
      loop: true,
      autoplay: {
        delay: 0,
        disableOnInteraction: false,
      },
      speed: 5000,
      pagination: {
        clickable: true,
        el: '.swiper-pagination',
      },
    });
</script>

<style>
  .fading-text-carousel-swiper .swiper-pagination .swiper-pagination-bullet {
    height: 1rem;
    width: 4.5rem;
    border-radius: 75px;
    background-color: #a5a5a5;
    opacity: 1;
  }
  .fading-text-carousel-swiper .swiper-pagination .swiper-pagination-bullet-active {
    background-color: #fdff96;
  }

  @media screen and (max-width: 1024px) {
    .fading-text-carousel-swiper .swiper-slide.slide-number-1 .feature-two p,
    .fading-text-carousel-swiper .swiper-slide.slide-number-1 .feature-three p {
      display: none;
    }

    .fading-text-carousel-swiper .swiper-slide.slide-number-2 .feature-one p,
    .fading-text-carousel-swiper .swiper-slide.slide-number-2 .feature-three p {
      display: none;
    }

    .fading-text-carousel-swiper .swiper-slide.slide-number-3 .feature-one p,
    .fading-text-carousel-swiper .swiper-slide.slide-number-3 .feature-two p {
      display: none;
    }
  }

  @media screen and (min-width: 1024px) {
    .feature-one,
    .feature-two,
    .feature-three {
      opacity: 0.35;
    }

    .fading-text-carousel-swiper .swiper-slide.slide-number-1 .feature-one {
      opacity: 1;
    }

    .fading-text-carousel-swiper .swiper-slide.slide-number-2 .feature-two {
      opacity: 1;
    }

    .fading-text-carousel-swiper .swiper-slide.slide-number-3 .feature-three {
      opacity: 1;
    }
  }
</style>
{% schema %}
{
  "name": "Fading text carousel",
  "settings": [
    {
      "type": "richtext",
      "id": "section_title",
      "label": "Section Title",
      "default": "<h1>You Deserve Cold Beer</h1>"
    },
    {
      "type": "textarea",
      "id": "section_description",
      "label": "Section Description",
      "default": "Every guy needs his personalised beer tankard. If you’re a confused woman reading this, just trust us."
    },
    {
      "type": "image_picker",
      "id": "image_one",
      "label": "Image One"
    },
    {
      "type": "text",
      "id": "feature_one_title",
      "label": "Feature One Title",
      "default": "Craft Your Perfect Tankard"
    },
    {
      "type": "textarea",
      "id": "feature_one_description",
      "label": "Feature One Description",
      "default": "Select from our range of premium wood finishes, each with its own character and charm."
    },
    {
      "type": "text",
      "id": "feature_two_title",
      "label": "Feature Two Title",
      "default": "Select Your Grip"
    },
    {
      "type": "textarea",
      "id": "feature_two_description",
      "label": "Feature Two Description",
      "default": "Complete your tankard's look with a rope that's as tough as you are."
    },
    {
      "type": "text",
      "id": "feature_three_title",
      "label": "Feature Three Title",
      "default": "Stamp Your Mark"
    },
    {
      "type": "textarea",
      "id": "feature_three_description",
      "label": "Feature Three Description",
      "default": "Add a personal engraving to transform your tankard from great to unforgettable."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Add to cart"
    },
    {
      "type": "text",
      "id": "discount_number",
      "default": "XX",
      "label": "Discount Number"
    }
  ],
  "presets": [
    {
      "name": "Fading text carousel"
    }
  ]
}
{% endschema %}
