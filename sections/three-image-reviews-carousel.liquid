<section class="tw-bg-chuug-gainsboro tw-overflow-hidden tw-rounded-ss-[2em] tw-rounded-se-[2em] -tw-mt-8 tw-pt-[4rem] tw-pb-[6rem] lg:tw-py-[10rem]">
  <div class="tw-flex tw-flex-col tw-justify-center tw-items-center tw-gap-y-20">
    <div class="tw-flex tw-flex-col tw-justify-center tw-max-w-[60em] tw-gap-y-4">
      <div class="tw-text-[2.8rem] tw-px-[1rem] tw-font-bold tw-leading-[52.8px] tw-text-center tw-text-chuug-dark-navy tw-capitalize md:tw-text-6xl">
        {{ section.settings.title }}
      </div>
      <p class="tw-text-center tw-text-[1.6rem] tw-px-[1rem] tw-leading-[1.6875em] tw-text-chuug-dark-navy md:tw-text-lg">
        {{ section.settings.subtitle }}
      </p>
    </div>
    <div class="tw-group tw-flex tw-flex-col tw-items-center tw-gap-y-10 tw-w-full">
      <div
        id="three-image-reviews-carousel"
        class="swiper tw-w-full md:tw-max-w-[90em] lg:tw-max-w-[120rem] lg:tw-h-[39rem]"
      >
        <div class="swiper-wrapper">
          {% for block in section.blocks %}
            <div class="swiper-slide !tw-flex tw-items-center tw-justify-center lg:tw-items-start hover:tw-cursor-pointer">
              <div class="tw-relative tw-h-[20.44469em] !tw-w-[21.1405em] tw-select-none lg:tw-flex lg:tw-items-center">
                <img
                  src="{{ block.settings.background_image | image_url }}"
                  width="100%"
                  class="background-image tw-w-[28rem] tw-h-[24rem] lg:tw-w-[30rem] lg:tw-h-[29rem]"
                  height="auto"
                  alt="background image"
                >
                <div class="text-container tw-absolute tw-flex tw-flex-col tw-justify-center tw-items-center tw-gap-y-[1.2rem] tw-text-white tw-top-[2em] tw-w-[16rem] tw-left-[1.5rem] md:tw-left-[2rem] lg:tw-right-[10em] lg:tw-w-[17rem] lg:tw-top-[8rem]">
                  {% if block.settings.stars == 'five' %}
                    <img
                      class="tw-w-[9rem] tw-h-[1.5rem] lg:tw-w-[9rem] lg:tw-h-[1.5rem]"
                      src="https://cdn.shopify.com/s/files/1/0799/4307/4111/files/five-stars.png?v=1728937309"
                      alt="Five stars"
                      height="15"
                      width="90"
                    >
                  {% else %}
                    <img
                      class="tw-w-[9rem] tw-h-[1.5rem] lg:tw-w-[9rem] lg:tw-h-[1.5rem]"
                      src="https://cdn.shopify.com/s/files/1/0799/4307/4111/files/four-stars.png?v=1728937309"
                      alt="Four stars"
                      height="15"
                      width="90"
                    >
                  {% endif %}
                  <p class="tw-flex-1 tw-text-center tw-text-[1.4rem] tw-leading-[1.5] lg:tw-text-[1.6rem]">
                    {{ block.settings.review_text }}
                  </p>
                  <span class="tw-text-center tw-text-[1.4rem] tw-leading-[1.5] lg:tw-mt-[2rem]">
                    {{- block.settings.review_author -}}
                  </span>
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
        <div class="swiper-pagination !tw-flex tw-justify-center"></div>
        <div class="swiper-scrollbar md:tw-hidden"></div>
      </div>
    </div>
  </div>
</section>

<script>
  function initThreeImageReviewsCarousel() {
    if (typeof Swiper === 'undefined') {
      setTimeout(initThreeImageReviewsCarousel, 50);
      return;
    }
    
    const threeImageReviewsCarousel = new Swiper('#three-image-reviews-carousel', {
    slidesPerView: 1.4,
    spaceBetween: 15,
    initialSlide: 0,
    loop: true,
    scrollbar: {
      el: '.swiper-scrollbar',
      hide: false,
    },
    breakpoints: {
      500: {
        slidesPerView: 1.6,
        slidesPerView: 2,
      },
      768: {
        slidesPerView: 2.5,
        pagination: {
          clickable: true,
          el: '.swiper-pagination',
        },
      },
      1024: {
        slidesPerView: 3,
        slidesPerGroup: 3,
        centeredSlides: true,
        pagination: {
          clickable: true,
          el: '.swiper-pagination',
        },
      },
    },
  });
  }
  
  // Initialize when ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initThreeImageReviewsCarousel);
  } else {
    initThreeImageReviewsCarousel();
  }
</script>

<style>
  #three-image-reviews-carousel .swiper-pagination .swiper-pagination-bullet {
    height: 1rem;
    width: 4.5rem;
    border-radius: 75px;
    background-color: #a5a5a5;
    opacity: 1;
  }
  #three-image-reviews-carousel .swiper-pagination .swiper-pagination-bullet-active {
    background-color: #fdff96;
    border: 1px solid black;
  }

  #three-image-reviews-carousel {
    margin-left: 3rem;
  }

  @media screen and (max-width: 768px) {
    #three-image-reviews-carousel .swiper-scrollbar {
      height: 12px;
      background-color: #a5a5a5;
      width: 90%;
    }
    #three-image-reviews-carousel .swiper-scrollbar-drag {
      background-color: #fdff96;
      display: block;
      border: 1px solid black;
    }
  }

  @media screen and (min-width: 1024px) {
    #three-image-reviews-carousel .swiper-slide-active .background-image {
      width: 34rem;
      height: 33rem;
    }

    #three-image-reviews-carousel {
      margin: 0 auto;
    }

    #three-image-reviews-carousel .swiper-slide-active .text-container {
      width: 20rem;
    }
  }
</style>

{% schema %}
{
  "name": "Three image reviews",
  "settings": [
    {
      "type": "richtext",
      "id": "title",
      "label": "Title",
      "default": "<h1>“my go to vessel for tea and beer”</h1>"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Hot or cold beverages. We don’t judge, our tankards can do it all."
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "background_image",
          "label": "Background Image"
        },
        {
          "type": "select",
          "id": "stars",
          "label": "Stars amount",
          "options": [
            {
              "value": "five",
              "label": "Five"
            },
            {
              "value": "four",
              "label": "Four"
            }
          ]
        },
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review Text"
        },
        {
          "type": "text",
          "id": "review_author",
          "label": "Review Author"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Three image reviews"
    }
  ]
}
{% endschema %}
