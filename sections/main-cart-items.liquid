<!-- Add this HTML where you want the timer to be displayed -->
<h5 id="cart-timer" style="display: none; background-color: #6b92a1; color: white; padding: 10px; border-radius: 5px;">
  We'll hold your cart for <span id="time-remaining-minutes"></span> minutes and <span id="time-remaining-seconds"></span> seconds.
</h5>

<script>
// Set the countdown time (10 minutes = 600 seconds)
const countdownMinutes = 10;
const countdownTime = countdownMinutes * 60 * 1000; // in milliseconds

// Function to format time
function formatTime(milliseconds) {
  const totalSeconds = Math.floor(milliseconds / 1000);
  const minutes = Math.floor(totalSeconds / 60);
  const seconds = totalSeconds % 60;
  return { minutes, seconds };
}

// Function to update the timer
function updateTimer() {
  const timerDiv = document.getElementById('cart-timer');
  const minutesRemainingDiv = document.getElementById('time-remaining-minutes');
  const secondsRemainingDiv = document.getElementById('time-remaining-seconds');

  let endTime = localStorage.getItem('cartEndTime');

  // If endTime is not set, set a new one
  if (!endTime) {
    resetTimer();
    endTime = localStorage.getItem('cartEndTime');
  }

  const currentTime = new Date().getTime();
  const timeRemaining = endTime - currentTime;

  // Check if time has expired
  if (timeRemaining <= 0) {
    removeTimer();
    return;
  }

  const { minutes, seconds } = formatTime(timeRemaining);

  // Display minutes and seconds
  minutesRemainingDiv.textContent = minutes;
  secondsRemainingDiv.textContent = seconds < 10 ? '0' + seconds : seconds; // Pad seconds with leading 0 if <10

  // Show the timer
  timerDiv.style.display = 'block';

  // Update every second
  setTimeout(updateTimer, 1000);
}

// Function to reset the timer to 10 minutes
function resetTimer() {
  const currentTime = new Date().getTime();
  const newEndTime = currentTime + countdownTime;
  localStorage.setItem('cartEndTime', newEndTime);
  updateTimer();
}

// Function to remove the timer
function removeTimer() {
  localStorage.removeItem('cartEndTime');
  document.getElementById('cart-timer').style.display = 'none';
}

// Function to check if the cart is empty
function checkCartItems() {
  fetch('/cart.js')
    .then(response => response.json())
    .then(cart => {
      if (cart.item_count === 0) {
        removeTimer();
      } else {
        updateTimer();
      }
    });
}

// Function to listen for product addition
function productAdded() {
  // Reset the timer when a new product is added
  resetTimer();
}

// Listen for when products are added
document.addEventListener('DOMContentLoaded', () => {
  checkCartItems();
  // Listen for changes to the cart
  document.addEventListener('cart:updated', productAdded);
});

// Make sure to check the cart items when the page loads
checkCartItems();

</script>




    
