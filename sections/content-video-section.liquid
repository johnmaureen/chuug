{% comment %}
  Content Video Section
  Displays a video section with article content and footer
{% endcomment %}

{{ 'content-video-section.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign section_id = section.id | prepend: 'content-video-section-'
  assign video_image = section.settings.video_image
  assign video_url = section.settings.video_url
  assign video_file = section.settings.video_file
  assign video_poster = section.settings.video_poster
  assign article_title = section.settings.article_title
  assign article_content = section.settings.article_content
  assign footer_links = section.settings.footer_links
  assign email_title = section.settings.email_title
  assign country_text = section.settings.country_text
  assign footer_text = section.settings.footer_text
-%}

<div id="{{ section_id }}" class="content-video-section">
  <div class="content-video-section__container">
    <!-- Article Section -->
    <div class="content-video-section__article">
      <h2 class="content-video-section__title">{{ article_title }}</h2>
      <div class="content-video-section__content">
        {{ article_content }}
      </div>
    </div>

    <!-- Video Section -->
    <div class="content-video-section__video">
      {% if section.settings.video_url != blank %}
        <!-- Embedded Video (YouTube/Vimeo) -->
        <div class="content-video-section__video-embed">
          {{ section.settings.video_url | video_tag: image_size: "1080x723", controls: true, autoplay: false, loop: false, muted: false }}
        </div>
      {% elsif section.settings.video_file != blank %}
        <!-- Direct Video File -->
        <video 
          class="content-video-section__video-element"
          width="1080"
          height="723"
          controls
          preload="metadata"
          poster="{{ section.settings.video_poster | image_url: width: 1080 }}"
        >
          <source src="{{ section.settings.video_file | asset_url }}" type="video/mp4">
          <source src="{{ section.settings.video_file | asset_url }}" type="video/webm">
          Your browser does not support the video tag.
        </video>
      {% else %}
        <!-- Fallback Image -->
        <img 
          src="{{ video_image | asset_url }}" 
          alt="{{ article_title }}"
          class="content-video-section__video-image"
          width="1080"
          height="723"
          loading="lazy"
        >
      {% endif %}
    </div>

    <!-- Footer -->
    <div class="content-video-section__footer">
      <!-- Footer Links -->
      {% if footer_links != blank %}
        <div class="content-video-section__footer-links">
          {% for link in footer_links %}
            <a href="{{ link.url }}" class="content-video-section__footer-link">{{ link.title }}</a>
          {% endfor %}
        </div>
      {% endif %}

      <!-- Email Signup -->
      <div class="content-video-section__email">
        <h3 class="content-video-section__email-title">{{ email_title }}</h3>
        <form class="content-video-section__email-form" action="#" method="post">
          <input 
            type="email" 
            name="email" 
            placeholder="Email" 
            class="content-video-section__email-input"
            required
          >
          <button type="submit" class="content-video-section__email-submit">
            <svg width="9" height="0" viewBox="0 0 9 0" fill="none">
              <path d="M0 0L9 0" stroke="#969393" stroke-width="1"/>
            </svg>
          </button>
        </form>
      </div>

      <!-- Country Selector -->
      <div class="content-video-section__country">
        <label class="content-video-section__country-label">Country/region</label>
        <div class="content-video-section__country-dropdown">
          <span class="content-video-section__country-text">{{ country_text }}</span>
          <svg width="18.07" height="16.43" viewBox="0 0 18.07 16.43" fill="none">
            <path d="M8.18 10.46L8.18 10.46" stroke="#0D2026" stroke-width="1.64"/>
          </svg>
        </div>
        
        <!-- Social Media Link -->
        <a href="#" class="content-video-section__social-link">
          <div class="content-video-section__social-icon">
            <svg width="16" height="14.87" viewBox="0 0 16 14.87" fill="none">
              <path d="M0 0L16 0" fill="#FFFFFF"/>
            </svg>
          </div>
          <div class="content-video-section__social-text">
            <span>Follow on</span>
            <div class="content-video-section__shop-logo">
              <svg width="38" height="15" viewBox="0 0 38 15" fill="none">
                <path d="M0.25 3L7.76 12.01" fill="#FFFFFF"/>
                <path d="M9.07 0L17.23 11.93" fill="#FFFFFF"/>
                <path d="M18.5 2.74L27.14 12.28" fill="#FFFFFF"/>
                <path d="M28.42 3L37.75 15" fill="#FFFFFF"/>
              </svg>
            </div>
          </div>
        </a>
      </div>

      <!-- Footer Text -->
      <div class="content-video-section__footer-text">
        {{ footer_text }}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Content Video Section",
  "tag": "section",
  "class": "section-content-video",
  "settings": [
    {
      "type": "header",
      "content": "Video Settings"
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Video URL",
      "info": "YouTube or Vimeo video URL (recommended)"
    },
    {
      "type": "url",
      "id": "video_file",
      "label": "Video File URL",
      "info": "Direct link to video file (MP4, WebM)"
    },
    {
      "type": "image_picker",
      "id": "video_poster",
      "label": "Video Poster Image",
      "info": "Thumbnail image shown before video plays"
    },
    {
      "type": "image_picker",
      "id": "video_image",
      "label": "Fallback Image",
      "info": "Static image shown if no video is provided"
    },
    {
      "type": "header",
      "content": "Content Settings"
    },
    {
      "type": "text",
      "id": "article_title",
      "label": "Article Title",
      "default": "Wood Becomes Art"
    },
    {
      "type": "richtext",
      "id": "article_content",
      "label": "Article Content",
      "default": "<p>Indulge in the artistry of our handcrafted rope handle tankards, where raw materials are elevated to create exceptional pieces for the discerning connoisseur.</p><p>You have never had a drink like this before.</p>"
    },
    {
      "type": "link_list",
      "id": "footer_links",
      "label": "Footer Links",
      "info": "Select a menu for footer navigation links"
    },
    {
      "type": "text",
      "id": "email_title",
      "label": "Email Signup Title",
      "default": "Join the Email Fellowship"
    },
    {
      "type": "text",
      "id": "country_text",
      "label": "Country/Region Text",
      "default": "GBP £ | United Kingdom"
    },
    {
      "type": "textarea",
      "id": "footer_text",
      "label": "Footer Text",
      "default": "© 2025, CHUUG® • Refund Policy • Privacy Policy • Terms of Service • Contact Information"
    }
  ],
  "presets": [
    {
      "name": "Content Video Section"
    }
  ]
}
{% endschema %}

<script src="{{ 'content-video-section.js' | asset_url }}" defer></script>
