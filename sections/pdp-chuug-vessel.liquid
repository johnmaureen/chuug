<script>
  document.querySelectorAll('.js-dropdown-container').forEach((container) => {
    const trigger = container.querySelector('.js-dropdown-trigger');
    const dropdown = container.querySelector('.js-dropdown');
    const selectedText = container.querySelector('.js-selected-option');
    const options = container.querySelectorAll('.js-option');

    trigger.addEventListener('click', () => {
      if (trigger.parentElement.hasAttribute('disabled')) return;
      dropdown.classList.toggle('tw-hidden');
      trigger.classList.toggle('active');
    });

    options.forEach((option) => {
      option.addEventListener('click', () => {
        if (option.hasAttribute('disabled')) return;
        const label = option.closest('label');
        const nameSpan = label.querySelector('span');
        selectedText.textContent = nameSpan.textContent;
        dropdown.classList.add('tw-hidden');
        trigger.classList.remove('active');
      });
    });

    document.addEventListener('click', (event) => {
      if (!container.contains(event.target)) {
        dropdown.classList.add('tw-hidden');
        trigger.classList.remove('active');
      }
    });
  });
</script>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    addEventListenerToMaterialAndRopeInputs();
    addEventListenerToMonogramInitialsInput();
    setProductAmount('2');
    disableUnavailableMaterials();
    setEngraving('0');

    setTimeout(function () {
      const elements = document.querySelectorAll('.bottom-autoplay-carousel .bss_pl_img');
      elements.forEach(function (element) {
        element.remove();
      });
    }, 1000);
  });

  function disableUnavailableMaterials() {
    const options = [];
  
    for (let i = 1; i <= 10; i++) {
      const materialType = document.getElementById(`select_${i}_material`);
  
      if (materialType) {
        const option = {
          dusk: materialType.querySelector(`input[value="DUSK"]`),
          dawn: materialType.querySelector(`input[value="DAWN"]`),
          midnight: materialType.querySelector(`input[value="MIDNIGHT"]`)
        };
        options.push(option);
      }
    }
  
    const availability = {
      dusk: { charcoal: duskCharcoalAvailable, natural: duskNaturalAvailable },
      dawn: { charcoal: dawnCharcoalAvailable, natural: dawnNaturalAvailable },
      midnight: { charcoal: midnightCharcoalAvailable, natural: midnightNaturalAvailable }
    };
  
    options.forEach(optionGroup => {
      Object.entries(availability).forEach(([key, materials]) => {
        const option = optionGroup[key];
        if (option && (!materials.charcoal && !materials.natural)) {
          option.disabled = true;
          option.closest("label").classList.add("tw-opacity-50", "tw-pointer-events-none"); 
        }
      });
    });
  }  

  function addEventListenerToMaterialAndRopeInputs() {
    for (let i = 1; i <= 10; i++) {
      const materialInputs = document.querySelectorAll(`#select_${i}_material input[type="radio"]`);
      const ropeSelect = document.getElementById(`select_${i}_rope`);
  
      materialInputs.forEach(input => {
        input.addEventListener("change", (event) => {
          updateAvailableRopes(event.target);
        });
      });
  
      if (ropeSelect) {
        ropeSelect.addEventListener("change", (event) => {
          updateSelectedProduct(event.target);
        });
      }
    }
  }
  
  function updateAvailableRopes(selectedMaterial) {
    const materialContainer = selectedMaterial.closest(".js-dropdown-container.material");
    const ropeSelect = materialContainer?.nextElementSibling;

    if (!ropeSelect) return;
  
    populateAvailableRopes(ropeSelect, selectedMaterial.value);
  
    if (ropeSelect.hasAttribute("disabled")) {
      ropeSelect.removeAttribute("disabled");
    }
  }
  
  function populateAvailableRopes(ropeSelect, materialValue) {
    const optionCharcoal = ropeSelect.querySelector(`option[value="charcoal"]`);
    const optionNatural = ropeSelect.querySelector(`option[value="natural"]`);
  
    [optionCharcoal, optionNatural].forEach(option => option?.setAttribute("disabled", "true"));
  
    const availability = {
      dusk: { charcoal: false, natural: false },
      dawn: { charcoal: dawnCharcoalAvailable, natural: dawnNaturalAvailable },
      midnight: { charcoal: midnightCharcoalAvailable, natural: midnightNaturalAvailable }
    };
  
    const currentAvailability = availability[materialValue];
  
    if (currentAvailability) {
      if (currentAvailability.charcoal) {
        optionCharcoal?.removeAttribute("disabled");
      }
      if (currentAvailability.natural) {
        optionNatural?.removeAttribute("disabled");
      }
    }
  }  

function addEventListenerToMonogramInitialsInput() {
  const fields = document.querySelectorAll('.monogram_initials');

  const enforceUppercaseLettersOnly = (el) => {
    const start = el.selectionStart;
    const end = el.selectionEnd;

    // Remove non-letters, force uppercase, enforce maxlength of 1
    const clean = el.value.replace(/[^A-Za-z]/g, '').toUpperCase().slice(0, 1);

    if (el.value !== clean) {
      el.value = clean;
      try { el.setSelectionRange(start, end); } catch (e) {}
    }
  };

  fields.forEach((field, i) => {
    if (i >= 10) return;

    // As-you-type: block non-letters, force uppercase
    field.addEventListener('input', () => {
      enforceUppercaseLettersOnly(field);
      updateMonogramInitials();
    });

    // Clean paste: allow only letters, uppercase, respect maxlength
    field.addEventListener('paste', (e) => {
      e.preventDefault();
      const text = (e.clipboardData || window.clipboardData).getData('text') || '';
      const insert = text.replace(/[^A-Za-z]/g, '').toUpperCase();

      const start = field.selectionStart;
      const end = field.selectionEnd;
      const before = field.value.slice(0, start);
      const after = field.value.slice(end);

      const max = field.maxLength && field.maxLength > 0 ? field.maxLength : Infinity;
      const spaceLeft = Math.max(0, max - before.length - after.length);
      const clipped = insert.slice(0, spaceLeft);

      field.value = before + clipped + after;
      const caret = before.length + clipped.length;
      try { field.setSelectionRange(caret, caret); } catch (err) {}

      updateMonogramInitials();
    });

    // Final check on blur
    field.addEventListener('blur', () => {
      enforceUppercaseLettersOnly(field);
      updateMonogramInitials();
    });
  });
}


  function setProductAmount(productAmount) {
    const cta_product_price = document.querySelector('.cta-product-price');
 
    changeProductAmount(productAmount, cta_product_price);
    hideInputs(productAmount);
    updateCarouselsImages();
    disableCTAbutton(productAmount);
  }

  function disableCTAbutton(productAmount) {
    const cta_button = document.querySelector('.cta-button');
    const incompleted_inputs_text = document.querySelector('.incompleted-inputs-text');

    if (!thereAreNoIncompleteInputs(productAmount)) {
      cta_button.setAttribute('disabled', true);
      if (incompleted_inputs_text && incompleted_inputs_text.classList.contains('tw-hidden')) {
          incompleted_inputs_text.classList.remove('tw-hidden');
      }
    } else {
      cta_button.removeAttribute('disabled');
      if (incompleted_inputs_text && !incompleted_inputs_text.classList.contains('tw-hidden')) {
          incompleted_inputs_text.classList.add('tw-hidden');
      }
    }
  }



  function setEngraving(index) {
    const inputs = document.querySelectorAll('.inputs');
    const currentVariantIndex = parseInt(inputs[0].getAttribute('variant_index'), 10);
  
    if (parseInt(index, 10) === currentVariantIndex) return;
  
    inputs.forEach(input => {
      input.setAttribute('variant_index', index);

      if (index === 0) {
        input.setAttribute('monogram_initials', '');
      }
    });
  
    const variant0 = document.querySelector('.product_variant_0');
    const variant1 = document.querySelector('.product_variant_1');
  
    if (index === 0) {
      variant0.classList.add('active');
      variant1.classList.remove('active');
    } else if (index === 1) {
      variant0.classList.remove('active');
      variant1.classList.add('active');
    }
  
    toggleClass('monogram_initials', 'tw-hidden', true);
    updateCarouselsImages();
    updatePrices(index);
  }

  function handleATCbutton() {
  const inputs = document.querySelectorAll('.inputs');
  const variant_index = inputs[0].getAttribute('variant_index');
  const product_amount = parseInt(inputs[0].getAttribute('product_amount'), 10);

  const variant_ids = Array.from(inputs).map((input) => ({
    variant_id: input.getAttribute('variant_id'),
    variant_monogram_initials_id: input.getAttribute('variant_monogram_initials_id')
  }));
  const monogram_initials = Array.from(inputs).map((input) => input.getAttribute('monogram_initials'));

  const products = [];

  for (let i = 0; i < product_amount; i++) {
    const initials = monogram_initials[i] && monogram_initials[i].trim() !== '' ? monogram_initials[i].trim().slice(0, 1) : 'NONE';

    const product = {
      id: initials === 'NONE' ? variant_ids[i].variant_id : variant_ids[i].variant_monogram_initials_id,
      quantity: 1,
      properties: {
        "PERSONALISED INITIAL": initials
      }
    };

    products.push(product);
  }

  addProductsToCart(products);
}

  function addProductsToCart(products){
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ items: products }),
    })
      .then((response) => {
        if (!response.ok) throw new Error('Error adding products');
        return response.json();
      })
      .then((data) => {
        window.location.href = '/cart';
      })
      .catch((error) => {
        console.error('Error:', error);
        alert('There was a problem adding products to the cart.');
      });
  }


  function handleToggleHeroSwiperState(elm) {
    if (bottom_autoplay_carousel.autoplay.running) {
      bottom_autoplay_carousel.autoplay.stop();
      elm.title = 'play';
      elm.dataset.play = 'false';
      elm.querySelector('.play-icon').style.display = 'block';
    } else {
      bottom_autoplay_carousel.autoplay.start();
      elm.title = 'pause';
      elm.dataset.play = 'true';
      elm.querySelector('.play-icon').style.display = 'none';
    }
  }

  function toggleClass(elementClasses, classToToggle, toggleState) {
    const classesArray = Array.isArray(elementClasses) ? elementClasses : [elementClasses];

    classesArray.forEach((elementClass) => {
      if (toggleState) {
        const elements = document.querySelectorAll(`.${elementClass}`);
        elements.forEach((element) => {
          element.classList.toggle(classToToggle);
        });
      } else {
        const element = document.querySelector(`.${elementClass}`);
        if (element) {
          element.classList.toggle(classToToggle);
        }
      }
    });
  }

  function changeProductAmount(productAmount, cta_product_price) {
    removeActiveClass();
    const variant_index = parseInt(document.querySelector('.inputs').getAttribute('variant_index'), 10);
    
    const one_product_no_engraving_price = "{{ section.settings.one_chuug_product.price | money }}";
    const one_product_engraving_price = "{{ section.settings.one_chuug_product.variants[1].price | money }}";
  
    const two_products_no_engraving_price = "{{ section.settings.two_chuug_product.price | money }}";
    const two_products_engraving_price = "{{ section.settings.two_chuug_product.variants[1].price | money }}";
  
    const three_products_no_engraving_price = "{{ section.settings.three_chuug_product.price | money }}";
    const three_products_engraving_price = "{{ section.settings.three_chuug_product.variants[1].price | money }}";
  
    const amt = parseInt(productAmount, 10);
    if (productAmount === '1') {
        cta_product_price.innerHTML = variant_index === 0 ? one_product_no_engraving_price : one_product_engraving_price;
        changeProductAmountInputValue('1');
        document.querySelector('.product_amount_label_1').classList.add('active');
    } else if (productAmount === '2') {
        cta_product_price.innerHTML = variant_index === 0 ? two_products_no_engraving_price : two_products_engraving_price;
        changeProductAmountInputValue('2');
        document.querySelector('.product_amount_label_2').classList.add('active');
    } else if (productAmount === '3') {
        cta_product_price.innerHTML = variant_index === 0 ? three_products_no_engraving_price : three_products_engraving_price;
        changeProductAmountInputValue('3');
        document.querySelector('.product_amount_label_3').classList.add('active');
    } else if (amt >= 4 && amt <= 10) {
        const priceEl = document.querySelector('.product_amount_label_' + amt + '_price');
        const priceAttr = variant_index === 0 ? 'no_engraving_price' : 'engraving_price';
        if (priceEl && priceEl.getAttribute(priceAttr)) {
          cta_product_price.innerHTML = priceEl.getAttribute(priceAttr);
        }
        changeProductAmountInputValue(String(amt));
        const labelEl = document.querySelector('.product_amount_label_' + amt);
        if (labelEl) labelEl.classList.add('active');
    }
  }
  
  function removeActiveClass() {
    for (let i = 1; i <= 10; i++) {
      const el = document.querySelector('.product_amount_label_' + i);
      if (el) el.classList.remove('active');
    }
  }

  function changeProductAmountInputValue(product_amount) {
    const inputs = document.querySelectorAll('.inputs');
    inputs.forEach(input => input.setAttribute('product_amount', product_amount));
  }
  
  function updateSelectedProduct(elementId) {
    const inputs = document.querySelectorAll('.inputs');
    const productAmount = parseInt(inputs[0].getAttribute('product_amount'), 10);
    const selectedValues = addSelectedValues(productAmount);
    const cta_button = document.querySelector('.cta-button');
    const incompleted_inputs_text = document.querySelector('.incompleted-inputs-text');
  
    const updateInputAttributes = (input, selectedProduct) => {
      if (selectedProduct) {
        input.setAttribute('variant_id', selectedProduct.variants[0].id);
        input.setAttribute('variant_monogram_initials_id', selectedProduct.variants[1].id);
      }
    };
    
    const monogram_initials = elementId.parentElement.parentElement.parentElement.parentElement.nextElementSibling;

    if (monogram_initials?.hasAttribute('disabled')) {
      monogram_initials.removeAttribute('disabled');
    }

    inputs.forEach((input, index) => {
      if (index < productAmount) {
        const selectedProduct = getSelectedProduct(selectedValues[index]);
        updateInputAttributes(input, selectedProduct);
      }
    });

    if (thereAreNoIncompleteInputs(productAmount)){
      if (cta_button?.hasAttribute('disabled')) {
        cta_button.removeAttribute('disabled');
        if (!incompleted_inputs_text?.classList.contains('tw-hidden')) {
          incompleted_inputs_text.classList.add('tw-hidden');
        }
      }
    }
  }  

  function thereAreNoIncompleteInputs(productAmount) {
    const inputs = document.querySelectorAll('.inputs');
    for (let i = 0; i < productAmount; i++) {
      const input = inputs[i];
      const materialText = input.querySelector('.wood-type')?.textContent.trim().toLowerCase().replace(/\s+/g, '-');
      const ropeText = input.querySelector('.rope-type')?.textContent.trim().toLowerCase().replace(/\s+/g, '-');      

      if (materialText === 'wood-finish' || ropeText === 'rope-type' ) {
        return false;
      }
    }
    return true;
  }  
  
  function addSelectedValues(productAmount){
    let selectedValues = [];
    for (let i = 1; i <= parseInt(productAmount); i++) {
      const materialContainer = document.getElementById(`select_${i}_material`);
      const ropeContainer = document.getElementById(`select_${i}_rope`);
      
      const materialSelect = materialContainer?.querySelector('.wood-type span');
      const ropeSelect = ropeContainer?.querySelector('.rope-type span');
      
      const materialText = materialSelect?.textContent.trim().toLowerCase().replace(/\s+/g, '-');
      const ropeText = ropeSelect?.textContent.trim().toLowerCase().replace(/\s+/g, '-');
      
      if (materialText && ropeText) {
        selectedValues.push([materialText, ropeText]);
      }
    }
    return selectedValues;
  }

  function hideInputs(productAmount){
    for (let i = 1; i <= 10; i++) {
      const vessel = document.querySelector(`.vessel_number_${i}`);
      if (vessel) vessel.style.display = i <= parseInt(productAmount) ? 'flex' : 'none';
    }
  }
  
  function updateMonogramInitials() {
    const inputs = document.querySelectorAll('.inputs');
    const monogram_initials = document.querySelectorAll('.monogram_initials');
    for (let i = 0; i < inputs.length && i < monogram_initials.length && i < 10; i++) {
      const monogram_initials_value = monogram_initials[i].value;
      inputs[i].setAttribute('monogram_initials', monogram_initials_value);
    }
  }

  const possible_product_values = [
    ['dusk', 'charcoal'],
    ['dusk', 'natural'],
    ['dawn', 'charcoal'],
    ['dawn', 'natural'],
    ['midnight', 'charcoal'],
    ['midnight', 'natural'],
    ['wood-finish', 'rope-type'],
  ];

  function getSelectedProduct(selectedValues) {
    let selected_product;
  
    for (let i = 0; i < possible_product_values.length; i++) {
      if (selectedValues[0] !== "" && selectedValues[1] !== "") {
        if (
          possible_product_values[i][0] === selectedValues[0] &&
          possible_product_values[i][1] === selectedValues[1]
        ) {
          if(i == '0'){
            return {{ dusk_charcoal | json }};
            }else if(i == '1'){
              return {{ dusk_natural | json }};
            }else if(i == '2'){
              return {{ dawn_charcoal | json }};
            }else if(i == '3'){
              return {{ dawn_natural | json }};
            }else if(i == '4'){
              return {{ midnight_charcoal | json }};
            }else if(i == '5'){
              selected_product = {{ midnight_natural | json }};
              if(selected_product.error) return null
              return selected_product;
            }else if(i == '6'){
              return undefined;
            }
        }
      }
    }
    return null;
  }

  function updateCarouselsImages() {
    const input = document.querySelector('.inputs');
    const variant_index = parseInt(input.getAttribute('variant_index'), 10);
    const product_amount = parseInt(input.getAttribute('product_amount'), 10);
    const images_src = window.pdp_chuug_vessel.src;
    let image_index;
  
    if (product_amount === 1) {
      image_index = variant_index === 0 ? 1 : 0;
    } else if (product_amount === 2) {
      image_index = variant_index === 0 ? 3 : 2;
    } else {
      /* 3 or 4–10: use 3-chuug imagery */
      image_index = variant_index === 0 ? 5 : 4;
    }
  
    if(images_src[image_index]){
      document.querySelector('.main_carousel_first_image').src = images_src[image_index];
      document.querySelector('.thumbnails_carousel_first_image').src = images_src[image_index];
    }
  }

  function updatePrices(index) {
    const cta_product_price = document.querySelector('.cta-product-price');
    const product_amount = parseInt(document.querySelector('.inputs').getAttribute('product_amount'), 10);
  
    const labels = [];
    for (let i = 1; i <= 10; i++) {
      const compare = document.querySelector('.product_amount_label_' + i + '_compare_at_price');
      const price = document.querySelector('.product_amount_label_' + i + '_price');
      if (compare && price) labels.push({ compare, price });
    }
  
    function getTextContentFromHTML(htmlString) {
      if (!htmlString) return '';
      const tempDiv = document.createElement('div');
      tempDiv.innerHTML = htmlString;
      
      const dualPriceElement = tempDiv.querySelector('.dualPrice');
      if (dualPriceElement && dualPriceElement.textContent) {
        return dualPriceElement.textContent;
      } else {
        return htmlString;
      }
    }
  
    function updateLabelPrices(label, engravingType) {
      const compareVal = label.compare.getAttribute(engravingType + '_compare_at_price');
      const priceVal = label.price.getAttribute(engravingType + '_price');
      if (compareVal) label.compare.innerHTML = getTextContentFromHTML(compareVal);
      if (priceVal) label.price.innerHTML = getTextContentFromHTML(priceVal);
    }
  
    const engravingType = index === 0 ? 'no_engraving' : 'engraving';
    labels.forEach(label => updateLabelPrices(label, engravingType));
  
    const selectedLabel = labels[product_amount - 1];
    if (selectedLabel && selectedLabel.price) {
      cta_product_price.innerHTML = selectedLabel.price.innerHTML;
    }
  }
</script>

<script>
  var bottom_autoplay_carousel;

  document.addEventListener('DOMContentLoaded', (event) => {
    const thumbs_swiper = new Swiper('.thumbsSlider', {
      slidesPerView: 5.5,
      freeMode: true,
      watchSlidesProgress: true,
      spaceBetween: 10,
      breakpoints: {
        0: {
          slidesPerView: 5.5,
        },
        767: {
          slidesPerView: 6,
          spaceBetween: 20,
        },
      },
    });

    const main_swiper = new Swiper('.pdp-chuug-vessel-main-swiper', {
      slidesPerView: 'auto',
      spaceBetween: 5,
      thumbs: {
        swiper: thumbs_swiper,
      },
    });

    bottom_autoplay_carousel = new Swiper('.bottom-autoplay-carousel', {
      slidesPerView: 1,
      spaceBetween: 15,
      loop: true,
      simulateTouch: false,
      autoplay: {
        delay: 3000,
        disableOnInteraction: false,
      },
      breakpoints: {
        0: {
          slidesPerView: 1,
        },
        1024: {
          slidesPerView: 4,
        },
      },
    });
  });
</script>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    fetch("https://ipapi.co/json/")
      .then(response => response.json())
      .then(data => {
        if (data && data.country_code === "US") {
          const badge = document.getElementById("duties-badge");
          if (badge) badge.style.display = "flex";
        }
      })
      .catch(err => {
        console.error("Geo lookup failed:", err);
      });
  });
</script>


