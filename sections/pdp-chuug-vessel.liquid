<link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"
>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link
  href="https://fonts.googleapis.com/css2?family=Merriweather:ital,wght@0,300;0,400;0,700;0,900;1,300;1,400;1,700;1,900&display=swap"
  rel="stylesheet"
>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Gabarito:wght@400..900&display=swap" rel="stylesheet">

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script src="https://cdn.tailwindcss.com"></script>

{{ 'pdp-chuug-vessel.css' | asset_url | stylesheet_tag }}

{% assign max_bundle_qty = section.settings.max_bundle_qty | default: 10 %}
{% assign dusk_charcoal = all_products[section.settings.dusk_charcoal] %}
{% assign dusk_natural = all_products[section.settings.dusk_natural] %}
{% assign dawn_charcoal = all_products[section.settings.dawn_charcoal] %}
{% assign dawn_natural = all_products[section.settings.dawn_natural] %}
{% assign midnight_charcoal = all_products[section.settings.midnight_charcoal] %}
{% assign midnight_natural = all_products[section.settings.midnight_natural] %}

<script>
  window.pdp_chuug_vessel = {
    src: [
      {{ section.settings.one_chuug_initials | json }},
      {{ section.settings.one_chuug_no_initials | json }},
      {{ section.settings.two_chuug_initials | json }},
      {{ section.settings.two_chuug_no_initials | json }},
      {{ section.settings.three_chuug_initials | json }},
      {{ section.settings.three_chuug_no_initials | json}},
    ],
  };

  const duskCharcoalAvailable = {{ dusk_charcoal.available | json }};
  const duskNaturalAvailable = {{ dusk_natural.available | json }};
  const dawnCharcoalAvailable = {{ dawn_charcoal.available | json }};
  const dawnNaturalAvailable = {{ dawn_natural.available | json }};
  const midnightCharcoalAvailable = {{ midnight_charcoal.available | json }};
  const midnightNaturalAvailable = {{ midnight_natural.available | json }};
</script>

<section
  id="hero-section"
  class="tw-bg-chuug-dark-navy tw-pt-5 md:tw-pt-24 tw-pb-[3rem] md:tw-pb-[12rem] tw-overflow-hidden"
>
  <div class="tw-flex tw-flex-col tw-gap-x-20 tw-container lg:tw-flex-row lg:tw-justify-center lg:tw-gap-x-[1rem] xl:tw-gap-x-20">
    <div class="tw-flex tw-flex-col tw-w-full lg:tw-w-[32.5em] tw-gap-y-[2rem]">
      <div class="tw-relative tw-w-fit tw-mx-auto">
        <div
          class="swiper pdp-chuug-vessel-main-swiper tw-w-[35.5rem] tw-h-[37.5rem] md:tw-w-[52rem] md:tw-h-[52rem]"
        >
          <div class="swiper-wrapper">
            {% for block in section.blocks %}
              {%- case block.type -%}
                {%- when 'main_carousel_image' -%}
                  <div class="swiper-slide tw-cursor-pointer tw-rounded-2xl">
                    <img
                      src="{{ block.settings.carousel_image | image_url}}"
                      class="{%- if forloop.first -%}main_carousel_first_image{% endif %} tw-w-full tw-h-full tw-rounded-2xl"
                      alt="{{ section.settings.hero_image_alt }}"
                      width="100%"
                      height="100%"
                    >
                  </div>
              {%- endcase -%}
            {% endfor %}
          </div>
        </div>
        <div class="badge-container tw-z-50 tw-absolute tw-top-[-1.5rem] tw-left-[-2.5rem] tw-w-[6rem] tw-h-[6rem] md:tw-w-[8rem] md:tw-h-[8rem]">
          <div class="tw-relative md:!tw-flex md:tw-justify-center md:tw-items-center">
            <img
              src="https://cdn.shopify.com/s/files/1/0799/4307/4111/files/badge.png?v=1729107293"
              alt="Badge"
              width="100%"
              height="100%"
              class="tw-w-[6rem] tw-h-[6rem] md:tw-w-[8rem] md:tw-h-[8rem]"
            >
            <p class="tw-absolute tw-text-center tw-text-black tw-top-[0.7rem] tw-leading-[1.8rem] tw-font-bold tw-text-[1.4rem] md:tw-mt-[0.8rem] md:tw-w-[6rem] ">
              UP TO <span class="discount">{{ section.settings.discount_number }}%</span> OFF
            </p>
          </div>
        </div>
      </div>

      <div class="swiper thumbsSlider tw-w-[35.5rem] tw-h-[5rem] md:tw-w-[52rem] md:tw-h-[7rem]">
        <div class="swiper-wrapper">
          {% for block in section.blocks %}
            {%- case block.type -%}
              {%- when 'main_carousel_image' -%}
                <div class="swiper-slide tw-cursor-pointer tw-rounded">
                  <img
                    src="{{ block.settings.carousel_image | image_url }}"
                    class="{%- if forloop.first -%}thumbnails_carousel_first_image{% endif %} tw-cursor-pointer tw-w-[5rem] tw-h-[5rem] tw-rounded md:tw-w-[7rem] md:tw-h-[7rem]"
                    alt="{{ block.settings.image_alt }}"
                    width="100%"
                    height="100%"
                  >
                </div>
            {%- endcase -%}
          {% endfor %}
        </div>
      </div>
      {% render 'icon-title-and-text',
        block: section.blocks,
        custom_classes: 'tw-hidden tw-mt-[1.2rem] md:tw-flex md:tw-max-w-[52rem] md:tw-mx-auto md:tw-mb-[2rem]'
      %}
    </div>

    <!-- insert here -->
    <div class="tw-flex-1 tw-flex tw-flex-col tw-gap-y-[2rem] tw-mt-[2rem] md:tw-gap-y-8 lg:tw-w-full lg:tw-max-w-[60rem]">
      <div class="tw-flex tw-flex-col tw-gap-y-4 md:tw-text-center lg:tw-text-left">
        <a
          class="tw-flex tw-items-center tw-gap-x-2 md:tw-justify-center lg:tw-justify-start"
          href="{{ section.settings.review_url }}"
          target="_blank"
        >
          <img
            class="tw-w-[18rem] tw-h-[3rem] tw-object-contain md:tw-w-[24rem]"
            src="https://cdn.shopify.com/s/files/1/0799/4307/4111/files/pdp-chuug-vessel-trustpilot.png?v=1729625666"
            alt="Review logo"
            width="113"
            height="29"
          >
          <span class="tw-text-white tw-text-[1.4rem] tw-leading-[1] tw-whitespace-nowrap lg:tw-text-[1.6rem] lg:tw-leading-[1.5]">
            {{- section.settings.review_text -}}
          </span>
        </a>
        <h1 class="tw-text-white tw-text-[2.4rem] tw-leading-[1.1] tw-font-bold md:tw-text-[3.6rem]">
          {{ section.settings.product_title }}
        </h1>
      </div>
      <ul class="tw-flex tw-flex-col tw-gap-y-4 md:tw-items-center lg:tw-items-start">
        {% for block in section.blocks %}
          {%- case block.type -%}
            {%- when 'benefits' -%}
              <li class="tw-bg-[url(https://cdn.shopify.com/s/files/1/0799/4307/4111/files/ch-lp-ul-list-icon.svg?v=1727978730)] tw-h-fit tw-bg-left tw-bg-no-repeat tw-pl-8 tw-text-white tw-text-[1.6rem] tw-leading-[1.5] md:tw-h-[2.6rem]">
                {{ block.settings.benefit_text }}
              </li>
          {%- endcase -%}
        {% endfor %}
      </ul>
      <div class="tw-border-t-white tw-border-t-4 tw-border-dotted tw-h-0">&nbsp;</div>
      <div class="tw-bg-chuug-yankees-blue tw-p-4 tw-rounded-[1.25em] tw-flex tw-flex-col tw-gap-y-4 ">
        <div class="tw-flex tw-flex-col tw-gap-y-2 tw-text-white">
          <div class="tw-flex tw-whitespace-nowrap tw-gap-x-[1rem] tw-text-[1.6rem] tw-font-semibold">
            <span>{{ section.settings.vessel_question }}</span>
            {% render 'icon-question-mark-tooltip', tooltip_text: section.settings.vessel_question_tooltip_text %}
          </div>

          <div class="vessel-amount-grid">
            <div class="tw-w-full">
              <label
                class="tw-cursor-pointer"
              >
                <div
                  onclick="setProductAmount('1')" class="product_amount_label_1 tw-h-[7rem] tw-flex tw-flex-col tw-gap-y-[1.2rem] tw-items-center tw-justify-center tw-select-none tw-rounded-[0.84613em] tw-border tw-border-white tw-bg-chuug-rackley tw-py-[0.62em] tw-w-full tw-transition-opacity" style="opacity: 0.85;"

                >
                  <span class="tw-text-center tw-text-[2rem] tw-leading-[1] tw-font-bold tw-tracking-[0.0625em] tw-leading-5 tw-uppercase"
                    >1X</span>
                  <div class="tw-whitespace-nowrap tw-flex tw-items-center tw-gap-x-[1rem]">
                    <span
                      class="product_amount_label_1_compare_at_price tw-opacity-40 tw-line-through tw-text-[1.6rem] tw-font-bold tw-leading-4 tw-tracking-tighter tw-flex tw-gap-x-[1rem]"
                      no_engraving_compare_at_price="{{ section.settings.one_chuug_product.compare_at_price | money }}"
                      engraving_compare_at_price="{{  section.settings.one_chuug_product.variants[1].compare_at_price | money }}"
                    >
                      {{ section.settings.one_chuug_product.variants[0].compare_at_price | money }}
                    </span>
                    <span
                      class="product_amount_label_1_price tw-text-[1.6rem] tw-font-bold tw-leading-4"
                      no_engraving_price="{{ section.settings.one_chuug_product.price | money }}"
                      engraving_price="{{ section.settings.one_chuug_product.variants[1].price | money }}"
                    >
                      {{ section.settings.one_chuug_product.variants[0].price | money }}
                    </span>
                  </div>
                </div>
              </label>
            </div>
            <div class="tw-w-full">
              <label
                onclick="setProductAmount('2')"
                class="product_amount_label_2 tw-cursor-pointer tw-transition-opacity before:tw-bottom-0 before:tw-bg-[#ECC78C] before:tw-text-black before:tw-rounded-ss-lg before:tw-rounded-se-lg before:tw-text-xs before:tw-font-bold before:tw-tracking-[0.075em] before:tw-w-fit before:tw-inline-block before:tw-mx-[50%] before:-tw-translate-x-1/2 before:tw-text-center before:tw-text-nowrap before:tw-content-['Most_Popular'] before:tw-top-0 before:tw-px-2 before:tw-py-1 before:tw-uppercase"
              >
                <div class="peer-checked:tw-bg-chuug-pastel-yellow peer-checked:tw-text-black peer-checked:tw-opacity-100 tw-min-h-12 tw-flex tw-flex-col tw-gap-y-[1.2rem] tw-items-center tw-justify-center tw-select-none tw-rounded-[0.84613em] tw-border tw-border-white tw-bg-chuug-rackley tw-py-[0.62em] tw-w-full tw-transition-opacity" style="opacity: 0.85;">
                  <span class="tw-text-center tw-text-[2rem] tw-leading-[1] tw-font-bold tw-tracking-[0.0625em] tw-leading-5 tw-uppercase"
                    >2X</span
                  >
                  <div class="tw-whitespace-nowrap tw-flex tw-items-center tw-gap-x-[1rem]">
                    <span
                      class="product_amount_label_2_compare_at_price tw-opacity-40 tw-line-through tw-text-[1.6rem] tw-font-bold tw-leading-4 tw-tracking-tighter tw-flex tw-gap-x-[1rem]"
                      no_engraving_compare_at_price="{{ section.settings.two_chuug_product.compare_at_price | money }}"
                      engraving_compare_at_price="{{ section.settings.two_chuug_product.variants[1].compare_at_price | money }}"
                    >
                      {{ section.settings.two_chuug_product.variants[0].compare_at_price | money }}
                    </span>
                    <span
                      class="product_amount_label_2_price tw-text-[1.6rem] tw-font-bold tw-leading-4"
                      no_engraving_price="{{ section.settings.two_chuug_product.price | money }}"
                      engraving_price="{{ section.settings.two_chuug_product.variants[1].price | money }}"
                    >
                      {{- section.settings.two_chuug_product.variants[0].price | money -}}
                    </span>
                  </div>
                </div>
              </label>
            </div>
            <div class="tw-w-full">
              <label
                onclick="setProductAmount('3')"
                class="product_amount_label_3 tw-cursor-pointer tw-transition-opacity before:tw-bottom-0 before:tw-bg-[#ECC78C] before:tw-text-black before:tw-rounded-ss-lg before:tw-rounded-se-lg before:tw-text-xs before:tw-font-bold before:tw-tracking-[0.075em] before:tw-w-fit before:tw-inline-block before:tw-mx-[50%] before:-tw-translate-x-1/2 before:tw-text-center before:tw-text-nowrap before:tw-content-['Best_value'] before:tw-top-0 before:tw-px-2 before:tw-py-1 before:tw-uppercase"
              >
                <div class="peer-checked:tw-bg-chuug-pastel-yellow peer-checked:tw-text-black peer-checked:tw-opacity-100 tw-min-h-12 tw-flex tw-flex-col tw-gap-y-[1.2rem] tw-items-center tw-justify-center tw-select-none tw-rounded-[0.84613em] tw-border tw-border-white tw-bg-chuug-rackley tw-py-[0.62em] tw-w-full tw-transition-opacity" style="opacity: 0.85;">
                  <span class="tw-text-center tw-text-[2rem] tw-leading-[1] tw-font-bold tw-tracking-[0.0625em] tw-leading-5 tw-uppercase"
                    >3X</span
                  >
                  <div class="tw-whitespace-nowrap tw-flex tw-items-center tw-gap-x-[1rem]">
                    <span
                      class="product_amount_label_3_compare_at_price tw-opacity-40 tw-line-through tw-text-[1.6rem] tw-font-bold tw-leading-4 tw-tracking-tighter tw-flex tw-gap-x-[1rem]"
                      no_engraving_compare_at_price="{{ section.settings.three_chuug_product.compare_at_price | money }}"
                      engraving_compare_at_price="{{ section.settings.three_chuug_product.variants[1].compare_at_price | money }}"
                    >
                      {{ section.settings.three_chuug_product.variants[0].compare_at_price | money }}
                    </span>
                    <span
                      class="product_amount_label_3_price tw-text-[1.6rem] tw-font-bold tw-leading-4"
                      no_engraving_price="{{ section.settings.three_chuug_product.price | money }}"
                      engraving_price="{{ section.settings.three_chuug_product.variants[1].price | money }}"
                    >
                      {{- section.settings.three_chuug_product.variants[0].price | money -}}
                    </span>
                  </div>
                </div>
              </label>
            </div>
            {% comment %} 4X–10X: £39/unit (derived from three_chuug_product) {% endcomment %}
            {% if max_bundle_qty >= 4 %}
            {% assign three_unit_price = section.settings.three_chuug_product.price | divided_by: 3 %}
            {% assign three_unit_compare = section.settings.three_chuug_product.compare_at_price | divided_by: 3 %}
            {% assign three_unit_price_engraving = section.settings.three_chuug_product.variants[1].price | divided_by: 3 %}
            {% assign three_unit_compare_engraving = section.settings.three_chuug_product.variants[1].compare_at_price | divided_by: 3 %}
            {% for qty in (4..max_bundle_qty) %}
              {% assign bundle_price = three_unit_price | times: qty %}
              {% assign bundle_compare = three_unit_compare | times: qty %}
              {% assign bundle_price_engraving = three_unit_price_engraving | times: qty %}
              {% assign bundle_compare_engraving = three_unit_compare_engraving | times: qty %}
              {% assign badge_setting = 'product_label_' | append: qty | append: '_text' %}
              {% assign badge_content = section.settings[badge_setting] | default: '' | strip %}
            <div class="tw-w-full">
              <label
                onclick="setProductAmount('{{ qty }}')"
                class="product_amount_label_{{ qty }} tw-cursor-pointer tw-transition-opacity tw-min-h-12 {% if badge_content != '' %}before:tw-bottom-0 before:tw-bg-[#ECC78C] before:tw-text-black before:tw-rounded-ss-lg before:tw-rounded-se-lg before:tw-text-xs before:tw-font-bold before:tw-tracking-[0.075em] before:tw-w-fit before:tw-inline-block before:tw-mx-[50%] before:-tw-translate-x-1/2 before:tw-text-center before:tw-text-nowrap before:tw-top-0 before:tw-px-2 before:tw-py-1 before:tw-uppercase{% endif %}"
                {% if badge_content != '' %}data-badge-text="{{ badge_content }}"{% endif %}
              >
                <div class="peer-checked:tw-bg-chuug-pastel-yellow peer-checked:tw-text-black peer-checked:tw-opacity-100 tw-min-h-12 tw-flex tw-flex-col tw-gap-y-[1.2rem] tw-items-center tw-justify-center tw-select-none tw-rounded-[0.84613em] tw-border tw-border-white tw-bg-chuug-rackley tw-py-[0.62em] tw-w-full tw-transition-opacity" style="opacity: 0.85;">
                  <span class="tw-text-center tw-text-[2rem] tw-leading-[1] tw-font-bold tw-tracking-[0.0625em] tw-leading-5 tw-uppercase">{{ qty }}X</span>
                  <div class="tw-whitespace-nowrap tw-flex tw-items-center tw-gap-x-[1rem]">
                    <span
                      class="product_amount_label_{{ qty }}_compare_at_price tw-opacity-40 tw-line-through tw-text-[1.6rem] tw-font-bold tw-leading-4 tw-tracking-tighter tw-flex tw-gap-x-[1rem]"
                      no_engraving_compare_at_price="{{ bundle_compare | money }}"
                      engraving_compare_at_price="{{ bundle_compare_engraving | money }}"
                    >
                      {{ bundle_compare | money }}
                    </span>
                    <span
                      class="product_amount_label_{{ qty }}_price tw-text-[1.6rem] tw-font-bold tw-leading-4"
                      no_engraving_price="{{ bundle_price | money }}"
                      engraving_price="{{ bundle_price_engraving | money }}"
                    >
                      {{ bundle_price | money }}
                    </span>
                  </div>
                </div>
              </label>
            </div>
            {% endfor %}
            {% endif %}
          </div>
        </div>
        <div class="tw-flex tw-flex-col tw-gap-y-2 tw-text-white">
          <div class="tw-flex tw-whitespace-nowrap tw-gap-x-[1rem] tw-text-[1.6rem] tw-font-semibold">
            <span>{{ section.settings.engraving_question }}</span>
            {% render 'icon-question-mark-tooltip', tooltip_text: section.settings.engraving_question_tooltip_text %}
          </div>

          <div class="tw-flex tw-items-center tw-gap-x-[0.62em] tw-px-2">
            <div class="tw-w-full">
              <label
                class="tw-cursor-pointer"
              >
                <div
                  class="product_variant_0 active tw-h-[5rem] tw-flex tw-items-center tw-justify-center tw-select-none tw-rounded-[0.84613em] tw-border tw-border-white tw-bg-chuug-rackley tw-py-[0.62em] tw-w-full tw-transition-opacity" style="opacity: 0.85;"
                  onclick="setEngraving(0);"
                >
                  <span class="tw-text-center tw-text-base tw-leading-4 tw-tracking-tighter tw-font-bold">NO</span>
                </div>
              </label>
            </div>
            <div class="tw-w-full">
              <label
                class="tw-cursor-pointer"
              >
                <div
                  class="product_variant_1 tw-h-[5rem] tw-flex tw-items-center tw-justify-center tw-select-none  tw-rounded-[0.84613em] tw-border tw-border-white tw-bg-chuug-rackley tw-py-[0.62em] tw-w-full tw-transition-opacity" style="opacity: 0.85;"
                  onclick="setEngraving(1);"
                >
                  <span class="tw-text-center tw-text-base tw-leading-4 tw-tracking-tighter tw-font-bold">YES</span>
                </div>
              </label>
            </div>
          </div>
        </div>

        <div class="customize-your-vessel tw-flex tw-flex-col tw-gap-y-2 tw-text-white tw-text-[1.6rem] tw-font-semibold">
          <div class="tw-flex tw-gap-[1rem]">
            <span>{{ section.settings.customise_vessel_question }}</span>
            {% for block in section.blocks %}
              {%- case block.type -%}
                {%- when 'modal' -%}
                  <button id="openModal">See options</button>
                  {% render 'pdp-chuug-vessel-modal', block: block %}
              {%- endcase -%}
            {% endfor %}
          </div>

          {% for i in (1..max_bundle_qty) %}
            <div
              class="tw-flex tw-flex-col tw-gap-y-1 vessel_number_{{ forloop.index }}"
              {% if forloop.index > 3 %}
                style="display: none;"
              {% endif %}
            >
              <span>Vessel #{{ forloop.index }}</span>
              <div class="tw-flex tw-flex-col tw-items-center tw-gap-y-[1rem] tw-gap-x-[0.62em] tw-py-2 md:tw-flex-row">
                <div
                  class="inputs tw-flex tw-w-full tw-gap-x-[1rem]"
                  variant_id=""
                  variant_monogram_initials_id=""
                  variant_index="0"
                  product_amount="1"
                  monogram_initials=""
                >
                  <div
                    id="select_{{ forloop.index }}_material"
                    class="js-dropdown-container material tw-w-1/2 tw-bg-chuug-rackley input tw-relative tw-mx-auto tw-rounded-2xl tw-h-[4.8rem] hover:tw-cursor-pointer">
                    <div class="wood-type tw-bg-chuug-rackley tw-px-4 tw-py-2 tw-border tw-border-white tw-rounded-2xl tw-cursor-pointer js-dropdown-trigger">
                      <span class="tw-text-white js-selected-option">WOOD FINISH</span>
                      {% render 'icon-arrow-down' %}
                    </div>

                    <div class="wood-type-modal tw-absolute tw-w-full tw-bg-white tw-border tw-border-white tw-rounded-2xl tw-hidden tw-z-10 js-dropdown">
                      <label class="wood-type-label tw-flex tw-items-center tw-px-4 tw-py-2 tw-cursor-pointer">
                        <input type="radio" name="wood_material_{{ forloop.index }}" value="DUSK" class="tw-hidden js-option">
                        <span class="wood-type-name tw-uppercase">DUSK</span>
                        {% if section.settings.wood_finish_dusk_wood != blank %}
                          <img src="{{ section.settings.wood_finish_dusk_wood | image_url }}" width="180" height="48">
                        {% endif %}
                      </label>

                      <label class="wood-type-label tw-flex tw-items-center tw-px-4 tw-py-2 tw-cursor-pointer hover:tw-bg-chuug-pastel-yellow">
                        <input type="radio" name="wood_material_{{ forloop.index }}" value="DAWN" class="tw-hidden js-option">
                        <span class="wood-type-name tw-uppercase">DAWN</span>
                        {% if section.settings.wood_finish_dawn_wood != blank %}
                          <img src="{{ section.settings.wood_finish_dawn_wood | image_url }}" width="180" height="48">
                        {% endif %}
                      </label>

                      <label class="wood-type-label tw-flex tw-items-center tw-px-4 tw-py-2 tw-cursor-pointer hover:tw-bg-chuug-pastel-yellow">
                        <input type="radio" name="wood_material_{{ forloop.index }}" value="MIDNIGHT" class="tw-hidden js-option">
                        <span class="wood-type-name tw-uppercase">MIDNIGHT</span>
                        {% if section.settings.wood_finish_midnight_wood != blank %}
                          <img
                            src="{{ section.settings.wood_finish_midnight_wood | image_url }}"
                            width="180"
                            height="48"
                          >
                        {% endif %}
                      </label>
                    </div>
                  </div>

                  <div
                    id="select_{{ forloop.index }}_rope"
                    disabled
                    class="js-dropdown-container rope tw-w-1/2 tw-bg-chuug-rackley input tw-relative tw-mx-auto tw-rounded-2xl tw-h-[4.8rem]">
                    <div class="rope-type tw-bg-chuug-rackley tw-px-4 tw-py-2 tw-border tw-border-white tw-rounded-2xl js-dropdown-trigger">
                      <span class="tw-text-white js-selected-option">ROPE TYPE</span>
                      {% render 'icon-arrow-down' %}
                    </div>

                    <div class="rope-type-modal tw-absolute tw-w-full tw-bg-white tw-border tw-border-white tw-rounded-2xl tw-hidden tw-z-10 js-dropdown">
                      <label class="rope-type-label tw-flex tw-items-center tw-px-4 tw-py-2">
                        <input type="radio" name="rope_material_{{ forloop.index }}" value="CHARCOAL" class="tw-hidden js-option">
