<script>
  document.querySelectorAll('.js-dropdown-container').forEach((container) => {
    const trigger = container.querySelector('.js-dropdown-trigger');
    const dropdown = container.querySelector('.js-dropdown');
    const selectedText = container.querySelector('.js-selected-option');
    const options = container.querySelectorAll('.js-option');

    trigger.addEventListener('click', () => {
      if (trigger.parentElement.hasAttribute('disabled')) return;
      dropdown.classList.toggle('tw-hidden');
      trigger.classList.toggle('active');
    });

    options.forEach((option) => {
      option.addEventListener('click', () => {
        if (option.hasAttribute('disabled')) return;
        const label = option.closest('label');
        const nameSpan = label.querySelector('span');
        selectedText.textContent = nameSpan.textContent;
        dropdown.classList.add('tw-hidden');
        trigger.classList.remove('active');
      });
    });

    document.addEventListener('click', (event) => {
      if (!container.contains(event.target)) {
        dropdown.classList.add('tw-hidden');
        trigger.classList.remove('active');
      }
    });
  });
</script>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    addEventListenerToMaterialAndRopeInputs();
    addEventListenerToMonogramInitialsInput();
    setProductAmount('2');
    disableUnavailableMaterials();
    setEngraving('0');

    setTimeout(function () {
      const elements = document.querySelectorAll('.bottom-autoplay-carousel .bss_pl_img');
      elements.forEach(function (element) {
        element.remove();
      });
    }, 1000);
  });

  function disableUnavailableMaterials() {
    const options = [];
  
    for (let i = 1; i <= 3; i++) {
      const materialType = document.getElementById(`select_${i}_material`);
  
      if (materialType) {
        const option = {
          dusk: materialType.querySelector(`input[value="DUSK"]`),
          dawn: materialType.querySelector(`input[value="DAWN"]`),
          midnight: materialType.querySelector(`input[value="MIDNIGHT"]`)
        };
        options.push(option);
      }
    }
  
    const availability = {
      dusk: { charcoal: duskCharcoalAvailable, natural: duskNaturalAvailable },
      dawn: { charcoal: dawnCharcoalAvailable, natural: dawnNaturalAvailable },
      midnight: { charcoal: midnightCharcoalAvailable, natural: midnightNaturalAvailable }
    };
  
    options.forEach(optionGroup => {
      Object.entries(availability).forEach(([key, materials]) => {
        const option = optionGroup[key];
        if (option && (!materials.charcoal && !materials.natural)) {
          option.disabled = true;
          option.closest("label").classList.add("tw-opacity-50", "tw-pointer-events-none"); 
        }
      });
    });
  }  

  function addEventListenerToMaterialAndRopeInputs() {
    for (let i = 1; i <= 3; i++) {
      const materialInputs = document.querySelectorAll(`#select_${i}_material input[type="radio"]`);
      const ropeSelect = document.getElementById(`select_${i}_rope`);
  
      materialInputs.forEach(input => {
        input.addEventListener("change", (event) => {
          updateAvailableRopes(event.target);
        });
      });
  
      if (ropeSelect) {
        ropeSelect.addEventListener("change", (event) => {
          updateSelectedProduct(event.target);
        });
      }
    }
  }
  
  function updateAvailableRopes(selectedMaterial) {
    const materialContainer = selectedMaterial.closest(".js-dropdown-container.material");
    const ropeSelect = materialContainer?.nextElementSibling;

    if (!ropeSelect) return;
  
    populateAvailableRopes(ropeSelect, selectedMaterial.value);
  
    if (ropeSelect.hasAttribute("disabled")) {
      ropeSelect.removeAttribute("disabled");
    }
  }
  
  function populateAvailableRopes(ropeSelect, materialValue) {
    const optionCharcoal = ropeSelect.querySelector(`option[value="charcoal"]`);
    const optionNatural = ropeSelect.querySelector(`option[value="natural"]`);
  
    [optionCharcoal, optionNatural].forEach(option => option?.setAttribute("disabled", "true"));
  
    const availability = {
      dusk: { charcoal: false, natural: false },
      dawn: { charcoal: dawnCharcoalAvailable, natural: dawnNaturalAvailable },
      midnight: { charcoal: midnightCharcoalAvailable, natural: midnightNaturalAvailable }
    };
  
    const currentAvailability = availability[materialValue];
  
    if (currentAvailability) {
      if (currentAvailability.charcoal) {
        optionCharcoal?.removeAttribute("disabled");
      }
      if (currentAvailability.natural) {
        optionNatural?.removeAttribute("disabled");
      }
    }
  }  

function addEventListenerToMonogramInitialsInput() {
  const fields = document.querySelectorAll('.monogram_initials');

  const enforceUppercaseLettersOnly = (el) => {
    const start = el.selectionStart;
    const end = el.selectionEnd;

    // Remove non-letters, force uppercase
    const clean = el.value.replace(/[^A-Za-z]/g, '').toUpperCase();

    if (el.value !== clean) {
      el.value = clean;
      try { el.setSelectionRange(start, end); } catch (e) {}
    }
  };

  fields.forEach((field, i) => {
    if (i >= 3) return;

    // As-you-type: block non-letters, force uppercase
    field.addEventListener('input', () => {
      enforceUppercaseLettersOnly(field);
      updateMonogramInitials();
    });

    // Clean paste: allow only letters, uppercase, respect maxlength
    field.addEventListener('paste', (e) => {
      e.preventDefault();
      const text = (e.clipboardData || window.clipboardData).getData('text') || '';
      const insert = text.replace(/[^A-Za-z]/g, '').toUpperCase();

      const start = field.selectionStart;
      const end = field.selectionEnd;
      const before = field.value.slice(0, start);
      const after = field.value.slice(end);

      const max = field.maxLength && field.maxLength > 0 ? field.maxLength : Infinity;
      const spaceLeft = Math.max(0, max - before.length - after.length);
      const clipped = insert.slice(0, spaceLeft);

      field.value = before + clipped + after;
      const caret = before.length + clipped.length;
      try { field.setSelectionRange(caret, caret); } catch (err) {}

      updateMonogramInitials();
    });

    // Final check on blur
    field.addEventListener('blur', () => {
      enforceUppercaseLettersOnly(field);
      updateMonogramInitials();
    });
  });
}


  function setProductAmount(productAmount) {
    const cta_product_price = document.querySelector('.cta-product-price');
 
    changeProductAmount(productAmount, cta_product_price);
    hideInputs(productAmount);
    updateCarouselsImages();
    disableCTAbutton(productAmount);
    
    // Also validate button status with POMC system and update multiplier
    if (window.pomcSystem) {
      // Update multiplier to match product amount
      window.pomcSystem.setMultiplier(parseInt(productAmount));
      
      // Update selected product amount data for mini ATC modal
      window.pomcSystem.setSelectedProductAmount(parseInt(productAmount));
      
      const vesselValidation = window.pomcSystem.validateAllVesselsForAddToCart();
      const cta_button = document.querySelector('.cta-button');
      const incompletText = document.querySelector('.incompleted-inputs-text');
      
      if (!vesselValidation.isValid) {
        if (cta_button) {
          cta_button.setAttribute('disabled', true);
        }
        if (incompletText) {
          incompletText.style.display = 'block';
        }
      } else {
        // Only enable if other validations also pass
        const originalValidation = thereAreNoIncompleteInputs(productAmount);
        if (originalValidation && cta_button) {
          cta_button.removeAttribute('disabled');
          if (incompletText) {
            incompletText.style.display = 'none';
          }
        }
      }
    }
  }

  function disableCTAbutton(productAmount) {
    const cta_button = document.querySelector('.cta-button');
    const incompletText = document.querySelector('.incompleted-inputs-text');

    // Check both the original validation and POMC vessel validation
    const originalValidation = thereAreNoIncompleteInputs(productAmount);
    const pomcValidation = window.pomcSystem ? window.pomcSystem.validateAllVesselsForAddToCart().isValid : false;
    
    if (!originalValidation || !pomcValidation) {
      cta_button.setAttribute('disabled', true);
      if (incompletText) {
        incompletText.style.display = 'block';
      }
    } else {
      cta_button.removeAttribute('disabled');
      if (incompletText) {
        incompletText.style.display = 'none';
      }
    }
  }



  function setEngraving(index) {
    const inputs = document.querySelectorAll('.inputs');
    const currentVariantIndex = parseInt(inputs[0].getAttribute('variant_index'), 10);
  
    if (parseInt(index, 10) === currentVariantIndex) return;
  
    inputs.forEach(input => {
      input.setAttribute('variant_index', index);

      if (index === 0) {
        input.setAttribute('monogram_initials', '');
      }
    });
  
    const variant0 = document.querySelector('.product_variant_0');
    const variant1 = document.querySelector('.product_variant_1');
  
    if (index === 0) {
      variant0.classList.add('active');
      variant1.classList.remove('active');
    } else if (index === 1) {
      variant0.classList.remove('active');
      variant1.classList.add('active');
    }
  
    toggleClass('monogram_initials', 'tw-hidden', true);
    updateCarouselsImages();
    updatePrices(index);
  }

  function showVesselValidationError(message) {
    // Use existing incompleted-inputs-text element
    const errorElement = document.querySelector('.incompleted-inputs-text');
    const addButton = document.getElementById('add-multiple-products');
    
    if (errorElement) {
      errorElement.textContent = message;
      errorElement.classList.remove('tw-hidden');
    }
    
    // Disable the button when validation fails
    if (addButton) {
      addButton.setAttribute('disabled', true);
    }
  }

  function hideVesselValidationError() {
    // Enable the button and hide the error message
    const addButton = document.getElementById('add-multiple-products');
    const errorElement = document.querySelector('.incompleted-inputs-text');
    
    if (addButton) {
      addButton.removeAttribute('disabled');
    }
    
    if (errorElement) {
      errorElement.style.display = 'none';
    }
  }

  // Expose functions globally for POMC system to use
  window.showVesselValidationError = showVesselValidationError;
  window.hideVesselValidationError = hideVesselValidationError;
  window.thereAreNoIncompleteInputs = thereAreNoIncompleteInputs;
  
  // Set current product ID and handle for POMC system
  // POMC system loads synchronously with high priority, so it's available immediately
  if (window.pomcSystem) {
    window.pomcSystem.setCurrentProductId({{ product.id }});
    window.pomcSystem.setCurrentProductHandle('{{ product.handle }}');
  }

  // Add event listener for the button when DOM is ready
  document.addEventListener('DOMContentLoaded', function() {
    const addMultipleProductsBtn = document.getElementById('add-multiple-products');
    if (addMultipleProductsBtn) {
      addMultipleProductsBtn.addEventListener('click', function(event) {
        event.preventDefault();
        handlePersonalizeVessel();
      });
    }
  });

  // Also listen for when the modal system is ready
  document.addEventListener('miniATCModalReady', function() {
    // Modal system ready
  });

  function handlePersonalizeVessel() {
    if (window.pomcSystem) {
      // Validate all vessels before proceeding
      const validation = window.pomcSystem.validateAllVesselsForAddToCart();
      if (!validation.isValid) {
        showVesselValidationError(validation.message);
        return;
      }
    } else {
      return;
    }
    
    // Find the mini ATC modal element on the page
    const miniATCModal = document.querySelector('.mini-atc-modal');
    
    if (!miniATCModal) {
      return;
    }

    const modalId = miniATCModal.id;
    
    // Try multiple approaches to open the modal
    const tryOpenModal = () => {
      // Method 1: Use the main MiniATCModal API
      if (window.MiniATCModal && typeof window.MiniATCModal.getInstance === 'function') {
        const instance = window.MiniATCModal.getInstance(modalId);
        if (instance) {
          instance.open('add-multiple-products');
          return true;
        }
      }
      
      // Fallback: Use the openModal method
      if (window.MiniATCModal && typeof window.MiniATCModal.openModal === 'function') {
        window.MiniATCModal.openModal(modalId);
        // Set context after opening
        setTimeout(() => {
          const instance = window.MiniATCModal.getInstance(modalId);
          if (instance) {
            instance.openingContext = 'add-multiple-products';
          }
        }, 10);
        return true;
      }
      
      // Method 2: Use the global helper function
      if (window.openMiniATCModal && typeof window.openMiniATCModal === 'function') {
        window.openMiniATCModal(modalId, 'add-multiple-products');
        return true;
      }
      
      return false;
    };

    // Try immediately
    if (tryOpenModal()) {
      return;
    }

    // If not available, wait for script to load with a more efficient approach
    
    // Listen for the modal ready event
    document.addEventListener('miniATCModalReady', () => {
      if (tryOpenModal()) {
        return;
      }
    });
    
    // Method 3: Wait for the script to load by checking periodically (reduced retries)
    let retryCount = 0;
    const maxRetries = 10; // 1 second max (reduced from 2 seconds)
    
    const retryInterval = setInterval(() => {
      retryCount++;
      
      if (tryOpenModal()) {
        clearInterval(retryInterval);
        return;
      }
      
      if (retryCount >= maxRetries) {
        clearInterval(retryInterval);
        
        // Method 4: Fallback - try to manually trigger the modal
        if (miniATCModal) {
          // Try to find the modal instance and call open() properly
          const modalInstance = window[`miniATCModal_${miniATCModal.dataset.modalId || miniATCModal.id}`];
          if (modalInstance && typeof modalInstance.open === 'function') {
            modalInstance.open();
          } else {
            miniATCModal.classList.add('mini-atc-modal--active');
            miniATCModal.setAttribute('aria-hidden', 'false');
            document.body.style.overflow = 'hidden';
            
            // Try to set isActive state on any available modal instance
            setTimeout(() => {
              const modalInstance = window[`miniATCModal_${miniATCModal.dataset.modalId || miniATCModal.id}`];
              if (modalInstance) {
                modalInstance.isActive = true;
                
                // Manually trigger the fetchVesselSelectionsAndUpdateImages function
                if (typeof modalInstance.fetchVesselSelectionsAndUpdateImages === 'function') {
                  modalInstance.fetchVesselSelectionsAndUpdateImages();
                }
              } else {
                // If still no instance, wait a bit more and try again
                setTimeout(() => {
                  const delayedInstance = window[`miniATCModal_${miniATCModal.dataset.modalId || miniATCModal.id}`];
                  if (delayedInstance && typeof delayedInstance.fetchVesselSelectionsAndUpdateImages === 'function') {
                    delayedInstance.fetchVesselSelectionsAndUpdateImages();
                  }
                }, 200);
              }
            }, 50); // Reduced timeout
          }
        }
      }
    }, 100);
  }

  function handleATCbutton() {
  const inputs = document.querySelectorAll('.inputs');
  const variant_index = inputs[0].getAttribute('variant_index');
  const product_amount = parseInt(inputs[0].getAttribute('product_amount'), 10);

  const variant_ids = Array.from(inputs).map((input) => ({
    variant_id: input.getAttribute('variant_id'),
    variant_monogram_initials_id: input.getAttribute('variant_monogram_initials_id')
  }));
  const monogram_initials = Array.from(inputs).map((input) => input.getAttribute('monogram_initials'));

  const products = [];

  for (let i = 0; i < product_amount; i++) {
    const initials = monogram_initials[i] && monogram_initials[i].trim() !== '' ? monogram_initials[i].trim() : 'NONE';

    const product = {
      id: initials === 'NONE' ? variant_ids[i].variant_id : variant_ids[i].variant_monogram_initials_id,
      quantity: 1,
      properties: {
        "PERSONALISED INITIAL": initials
      }
    };

    products.push(product);
  }

  addProductsToCart(products);
}

  function addProductsToCart(products){
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ items: products }),
    })
      .then((response) => {
        if (!response.ok) throw new Error('Error adding products');
        return response.json();
      })
      .then((data) => {
        window.location.href = '/cart';
      })
      .catch((error) => {
        alert('There was a problem adding products to the cart.');
      });
  }


  function handleToggleHeroSwiperState(elm) {
    if (bottom_autoplay_carousel.autoplay.running) {
      bottom_autoplay_carousel.autoplay.stop();
      elm.title = 'play';
      elm.dataset.play = 'false';
      elm.querySelector('.play-icon').style.display = 'block';
    } else {
      bottom_autoplay_carousel.autoplay.start();
      elm.title = 'pause';
      elm.dataset.play = 'true';
      elm.querySelector('.play-icon').style.display = 'none';
    }
  }

  function toggleClass(elementClasses, classToToggle, toggleState) {
    const classesArray = Array.isArray(elementClasses) ? elementClasses : [elementClasses];

    classesArray.forEach((elementClass) => {
      if (toggleState) {
        const elements = document.querySelectorAll(`.${elementClass}`);
        elements.forEach((element) => {
          element.classList.toggle(classToToggle);
        });
      } else {
        const element = document.querySelector(`.${elementClass}`);
        if (element) {
          element.classList.toggle(classToToggle);
        }
      }
    });
  }

  function changeProductAmount(productAmount, cta_product_price) {
    removeActiveClass();
    const variant_index = parseInt(document.querySelector('.inputs').getAttribute('variant_index'), 10);
    
    const one_product_no_engraving_price = "{{ section.settings.one_chuug_product.price | money }}";
    const one_product_engraving_price = "{{ section.settings.one_chuug_product.variants[1].price | money }}";
  
    const two_products_no_engraving_price = "{{ section.settings.two_chuug_product.price | money }}";
    const two_products_engraving_price = "{{ section.settings.two_chuug_product.variants[1].price | money }}";
  
    const three_products_no_engraving_price = "{{ section.settings.three_chuug_product.price | money }}";
    const three_products_engraving_price = "{{ section.settings.three_chuug_product.variants[1].price | money }}";
  
    if (productAmount === '1') {
        cta_product_price.innerHTML = variant_index === 0 ? one_product_no_engraving_price : one_product_engraving_price;
        changeProductAmountInputValue('1');
        document.querySelector('.product_amount_label_1').classList.add('active');
    } else if (productAmount === '2') {
        cta_product_price.innerHTML = variant_index === 0 ? two_products_no_engraving_price : two_products_engraving_price;
        changeProductAmountInputValue('2');
        document.querySelector('.product_amount_label_2').classList.add('active');
    } else if (productAmount === '3') {
        cta_product_price.innerHTML = variant_index === 0 ? three_products_no_engraving_price : three_products_engraving_price;
        changeProductAmountInputValue('3');
        document.querySelector('.product_amount_label_3').classList.add('active');
    }
    
    // Trigger charcoal price recalculation after product amount changes
    if (window.pomcSystem) {
      setTimeout(() => {
        const upgradePrice = window.pomcSystem.getCharcoalUpgradePrice();
        document.dispatchEvent(new CustomEvent("pomcCharcoalUpgradePrice", {
          detail: {
            upgradePrice: upgradePrice,
            upgradePriceFormatted: window.pomcSystem.getCharcoalUpgradePriceFormatted(),
            charcoalCount: Math.floor(upgradePrice / window.pomcSystem.CHARCOAL_UPGRADE_PRICE),
          }
        }));
      }, 50);
    }
  }
  
  function removeActiveClass() {
    document.querySelector('.product_amount_label_1').classList.remove('active');
    document.querySelector('.product_amount_label_2').classList.remove('active');
    document.querySelector('.product_amount_label_3').classList.remove('active');
  }

  function changeProductAmountInputValue(product_amount) {
    const inputs = document.querySelectorAll('.inputs');
    inputs.forEach(input => input.setAttribute('product_amount', product_amount));
  }
  
  function updateSelectedProduct(elementId) {
    const inputs = document.querySelectorAll('.inputs');
    const productAmount = parseInt(inputs[0].getAttribute('product_amount'), 10);
    const selectedValues = addSelectedValues(productAmount);
    const cta_button = document.querySelector('.cta-button');
    const incompleted_inputs_text = document.querySelector('.incompleted-inputs-text');
  
    const updateInputAttributes = (input, selectedProduct) => {
      if (selectedProduct) {
        input.setAttribute('variant_id', selectedProduct.variants[0].id);
        input.setAttribute('variant_monogram_initials_id', selectedProduct.variants[1].id);
      }
    };
    
    const monogram_initials = elementId.parentElement.parentElement.parentElement.parentElement.nextElementSibling;

    if (monogram_initials?.hasAttribute('disabled')) {
      monogram_initials.removeAttribute('disabled');
    }

    inputs.forEach((input, index) => {
      if (index < productAmount) {
        const selectedProduct = getSelectedProduct(selectedValues[index]);
        updateInputAttributes(input, selectedProduct);
      }
    });

    // Check both the original validation and POMC vessel validation
    const originalValidation = thereAreNoIncompleteInputs(productAmount);
    const pomcValidation = window.pomcSystem ? window.pomcSystem.validateAllVesselsForAddToCart().isValid : false;
    
    if (originalValidation && pomcValidation){
      if (cta_button?.hasAttribute('disabled')) {
        cta_button.removeAttribute('disabled');
      }
      if (incompleted_inputs_text) {
        incompleted_inputs_text.style.display = 'none';
      }
    }
  }  

  function thereAreNoIncompleteInputs(productAmount) {
    const inputs = document.querySelectorAll('.inputs');
    for (let i = 0; i < productAmount; i++) {
      const input = inputs[i];
      const materialText = input.querySelector('.wood-type')?.textContent.trim().toLowerCase().replace(/\s+/g, '-');
      const ropeText = input.querySelector('.rope-type')?.textContent.trim().toLowerCase().replace(/\s+/g, '-');      

      if (materialText === 'wood-finish' || ropeText === 'rope-type' ) {
        return false;
      }
    }
    return true;
  }  
  
  function addSelectedValues(productAmount){
    let selectedValues = [];
    for (let i = 1; i <= parseInt(productAmount); i++) {
      const materialContainer = document.getElementById(`select_${i}_material`);
      const ropeContainer = document.getElementById(`select_${i}_rope`);
      
      const materialSelect = materialContainer?.querySelector('.wood-type span');
      const ropeSelect = ropeContainer?.querySelector('.rope-type span');
      
      const materialText = materialSelect?.textContent.trim().toLowerCase().replace(/\s+/g, '-');
      const ropeText = ropeSelect?.textContent.trim().toLowerCase().replace(/\s+/g, '-');
      
      if (materialText && ropeText) {
        selectedValues.push([materialText, ropeText]);
      }
    }
    return selectedValues;
  }

  function hideInputs(productAmount){
    for (let i = 1; i <= 3; i++) {
      const vessel = document.querySelector(`.vessel_number_${i}`);
      vessel.style.display = i <= parseInt(productAmount) ? 'flex' : 'none';
    }
  }
  
  function updateMonogramInitials() {
    const inputs = document.querySelectorAll('.inputs');
    const monogram_initials = document.querySelectorAll('.monogram_initials');
    for (let i = 0; i < inputs.length && i < monogram_initials.length && i < 3; i++) {
      const monogram_initials_value = monogram_initials[i].value;
      inputs[i].setAttribute('monogram_initials', monogram_initials_value);
    }
  }

  const possible_product_values = [
    ['dusk', 'charcoal'],
    ['dusk', 'natural'],
    ['dawn', 'charcoal'],
    ['dawn', 'natural'],
    ['midnight', 'charcoal'],
    ['midnight', 'natural'],
    ['wood-finish', 'rope-type'],
  ];

  function getSelectedProduct(selectedValues) {
    let selected_product;
  
    for (let i = 0; i < possible_product_values.length; i++) {
      if (selectedValues[0] !== "" && selectedValues[1] !== "") {
        if (
          possible_product_values[i][0] === selectedValues[0] &&
          possible_product_values[i][1] === selectedValues[1]
        ) {
          if(i == '0'){
            return {{ dusk_charcoal | json }};
            }else if(i == '1'){
              return {{ dusk_natural | json }};
            }else if(i == '2'){
              return {{ dawn_charcoal | json }};
            }else if(i == '3'){
              return {{ dawn_natural | json }};
            }else if(i == '4'){
              return {{ midnight_charcoal | json }};
            }else if(i == '5'){
              selected_product = {{ midnight_natural | json }};
              if(selected_product.error) return null
              return selected_product;
            }else if(i == '6'){
              return undefined;
            }
        }
      }
    }
    return null;
  }

  function updateCarouselsImages() {
    const input = document.querySelector('.inputs');
    const variant_index = parseInt(input.getAttribute('variant_index'), 10);
    const product_amount = parseInt(input.getAttribute('product_amount'), 10);
    const images_src = window.pdp_chuug_vessel.src;
    let image_index;
  
    if (product_amount === 1) {
      image_index = variant_index === 0 ? 1 : 0;
    } else if (product_amount === 2) {
      image_index = variant_index === 0 ? 3 : 2;
    } else if (product_amount === 3) {
      image_index = variant_index === 0 ? 5 : 4;
    }
  
    if(images_src[image_index]){
      document.querySelector('.main_carousel_first_image').src = images_src[image_index];
      document.querySelector('.thumbnails_carousel_first_image').src = images_src[image_index];
    }
  }

  function updatePrices(index) {
    const cta_product_price = document.querySelector('.cta-product-price');
    const product_amount = parseInt(document.querySelector('.inputs').getAttribute('product_amount'), 10);
  
    const labels = [
      {
        compare: document.querySelector('.product_amount_label_1_compare_at_price'),
        price: document.querySelector('.product_amount_label_1_price')
      },
      {
        compare: document.querySelector('.product_amount_label_2_compare_at_price'),
        price: document.querySelector('.product_amount_label_2_price')
      },
      {
        compare: document.querySelector('.product_amount_label_3_compare_at_price'),
        price: document.querySelector('.product_amount_label_3_price')
      }
    ];
  
    function getTextContentFromHTML(htmlString) {
      // If the string doesn't contain HTML tags, return it wrapped in dualPrice
      if (!htmlString || htmlString.indexOf('<') === -1) {
        // Plain text price - wrap it in dualPrice span
        return '<span class="dualPrice">' + htmlString + '</span>';
      }
      
      const tempDiv = document.createElement('div');
      tempDiv.innerHTML = htmlString;
      
      const dualPriceElement = tempDiv.querySelector('.dualPrice');
      if (dualPriceElement) {
        // Return the full HTML to preserve the dualPrice wrapper
        return dualPriceElement.outerHTML;
      } else {
        // If no dualPrice element found but has HTML, wrap the text content
        const textContent = tempDiv.textContent || htmlString;
        return '<span class="dualPrice">' + textContent + '</span>';
      }
    }
  
    function updateLabelPrices(label, engravingType) {
      label.compare.innerHTML = getTextContentFromHTML(label.compare.getAttribute(`${engravingType}_compare_at_price`));
      label.price.innerHTML = getTextContentFromHTML(label.price.getAttribute(`${engravingType}_price`));
    }
  
    const engravingType = index === 0 ? 'no_engraving' : 'engraving';
    labels.forEach(label => updateLabelPrices(label, engravingType));
  
    const selectedLabel = product_amount === 1 ? labels[0] : product_amount === 2 ? labels[1] : labels[2];
    cta_product_price.innerHTML = selectedLabel.price.innerHTML;
    
    // Trigger charcoal price recalculation after engraving changes
    if (window.pomcSystem) {
      setTimeout(() => {
        const upgradePrice = window.pomcSystem.getCharcoalUpgradePrice();
        document.dispatchEvent(new CustomEvent("pomcCharcoalUpgradePrice", {
          detail: {
            upgradePrice: upgradePrice,
            upgradePriceFormatted: window.pomcSystem.getCharcoalUpgradePriceFormatted(),
            charcoalCount: Math.floor(upgradePrice / window.pomcSystem.CHARCOAL_UPGRADE_PRICE),
          }
        }));
      }, 50);
    }
  }

  // Store base prices (in cents) for charcoal upgrade calculations
  // These prices are in the shop's default currency, but we need to handle currency conversion
  const BASE_PRICES = {
    one_no_engraving: {{ section.settings.one_chuug_product.price }},
    one_engraving: {{ section.settings.one_chuug_product.variants[1].price }},
    two_no_engraving: {{ section.settings.two_chuug_product.price }},
    two_engraving: {{ section.settings.two_chuug_product.variants[1].price }},
    three_no_engraving: {{ section.settings.three_chuug_product.price }},
    three_engraving: {{ section.settings.three_chuug_product.variants[1].price }}
  };
  
  // Get the shop's default currency (these prices are in this currency)
  const SHOP_DEFAULT_CURRENCY = {{ shop.currency | json }};
  const CURRENT_CURRENCY = window.CURRENT_CURRENCY || SHOP_DEFAULT_CURRENCY;

  // Helper function to format money with fallback
  function formatMoneyWithFallback(cents) {
    // Try Shopify.formatMoney first
    if (typeof Shopify !== 'undefined' && typeof Shopify.formatMoney === 'function') {
      return Shopify.formatMoney(cents, "{{ shop.money_format }}");
    }
    
    // Fallback: simple formatter
    const dollars = (cents / 100).toFixed(2);
    const moneyFormat = "{{ shop.money_format }}";
    
    // Replace {% raw %}{{amount}}{% endraw %} or {% raw %}{{ amount }}{% endraw %} with the dollar amount
    if (moneyFormat.indexOf('{' + '{') !== -1) {
      return moneyFormat.replace(/\{\{\s*amount\s*\}\}/g, dollars);
    }
    
    // Default fallback
    return '$' + dollars;
  }

  // Listen for charcoal upgrade price changes
  document.addEventListener('pomcCharcoalUpgradePrice', function(e) {
    
    const upgradePrice = e.detail.upgradePrice; // in cents
    const inputs = document.querySelector('.inputs');
    if (!inputs) return;
    
    const variant_index = parseInt(inputs.getAttribute('variant_index'), 10);
    const product_amount = parseInt(inputs.getAttribute('product_amount'), 10);
    
    // Determine which base prices to use
    const isEngraving = variant_index === 1;
    
    // Check if we need currency conversion
    const needsCurrencyConversion = CURRENT_CURRENCY !== SHOP_DEFAULT_CURRENCY;
    
    // Calculate new prices with upgrade
    let newPriceForOne, newPriceForTwo, newPriceForThree;
    
    if (isEngraving) {
      newPriceForOne = BASE_PRICES.one_engraving + upgradePrice;
      newPriceForTwo = BASE_PRICES.two_engraving + upgradePrice;
      newPriceForThree = BASE_PRICES.three_engraving + upgradePrice;
    } else {
      newPriceForOne = BASE_PRICES.one_no_engraving + upgradePrice;
      newPriceForTwo = BASE_PRICES.two_no_engraving + upgradePrice;
      newPriceForThree = BASE_PRICES.three_no_engraving + upgradePrice;
    }
    
    // If currency conversion is needed, we need to get the correct prices for the current currency
    if (needsCurrencyConversion) {
      // Try to get current currency prices using CurrencyManager
      if (window.CurrencyManager && window.CurrencyManager.fetchProductData) {
        // Get the product IDs for the current amount
        const productAmountData = window.pomcSystem?.getSelectedProductAmountData();
        
        if (productAmountData && productAmountData.id) {
          
          // Add timeout to prevent hanging
          const fetchPromise = window.CurrencyManager.fetchProductData(productAmountData.id);
          const timeoutPromise = new Promise((_, reject) => 
            setTimeout(() => reject(new Error('Currency fetch timeout')), 3000)
          );
          
          Promise.race([fetchPromise, timeoutPromise])
            .then(productData => {
              if (productData && productData.variants) {
                const variants = productData.variants.edges.map(edge => edge.node);
                const variantIndex = isEngraving ? 1 : 0;
                const variant = variants[variantIndex];
                
                if (variant && variant.price) {
                  const currentCurrencyBasePrice = Math.round(parseFloat(variant.price.amount) * 100); // Convert to cents
                  
                  // Update prices with current currency base price + upgrade price
                  newPriceForOne = currentCurrencyBasePrice + upgradePrice;
                  newPriceForTwo = currentCurrencyBasePrice + upgradePrice;
                  newPriceForThree = currentCurrencyBasePrice + upgradePrice;
                  
                  // Update the CTA price with the converted price
                  updateCTAPriceWithCharcoalUpgrade(product_amount, newPriceForOne, newPriceForTwo, newPriceForThree, e.detail);
                } else {
                  fallbackToSimpleCalculation();
                }
              } else {
                fallbackToSimpleCalculation();
              }
            })
            .catch(error => {
              fallbackToSimpleCalculation();
            });
        } else {
          fallbackToSimpleCalculation();
        }
      } else {
        fallbackToSimpleCalculation();
      }
      
      // Fallback function for when currency conversion fails
      function fallbackToSimpleCalculation() {
        // Try to extract current currency prices from existing price elements
        const currentPrices = extractCurrentCurrencyPrices();
        
        if (currentPrices) {
          // Use the extracted prices + upgrade price
          newPriceForOne = currentPrices.one + upgradePrice;
          newPriceForTwo = currentPrices.two + upgradePrice;
          newPriceForThree = currentPrices.three + upgradePrice;
        } else {
          // Last resort: just use the upgrade price
          newPriceForOne = upgradePrice;
          newPriceForTwo = upgradePrice;
          newPriceForThree = upgradePrice;
        }
        
        updateCTAPriceWithCharcoalUpgrade(product_amount, newPriceForOne, newPriceForTwo, newPriceForThree, e.detail);
      }
      
      // Helper function to extract current currency prices from page elements
      function extractCurrentCurrencyPrices() {
        try {
          // Try to get prices from the vessel number labels (1x, 2x, 3x)
          const onePriceEl = document.querySelector('.product_amount_label_1_price');
          const twoPriceEl = document.querySelector('.product_amount_label_2_price');
          const threePriceEl = document.querySelector('.product_amount_label_3_price');
          
          if (onePriceEl && twoPriceEl && threePriceEl) {
            // Extract price text and convert to cents
            const onePriceText = onePriceEl.textContent || onePriceEl.innerText;
            const twoPriceText = twoPriceEl.textContent || twoPriceEl.innerText;
            const threePriceText = threePriceEl.textContent || threePriceEl.innerText;
            
            // Parse prices (remove currency symbols and convert to cents)
            const parsePrice = (priceText) => {
              if (!priceText) return null;
              
              // Remove currency symbols and extract number
              const cleanPrice = priceText.replace(/[^\d.,]/g, '');
              const price = parseFloat(cleanPrice.replace(',', '.'));
              
              if (isNaN(price)) return null;
              
              // Convert to cents
              return Math.round(price * 100);
            };
            
            const onePrice = parsePrice(onePriceText);
            const twoPrice = parsePrice(twoPriceText);
            const threePrice = parsePrice(threePriceText);
            
            if (onePrice && twoPrice && threePrice) {
              return {
                one: onePrice,
                two: twoPrice,
                three: threePrice
              };
            }
          }
          
          return null;
        } catch (error) {
          return null;
        }
      }
      
      return; // Exit early as we're handling the update asynchronously
    }
    
    // For same currency, update normally
    updateCTAPriceWithCharcoalUpgrade(product_amount, newPriceForOne, newPriceForTwo, newPriceForThree, e.detail);
  });
  
  // Helper function to update CTA price with charcoal upgrade
  function updateCTAPriceWithCharcoalUpgrade(product_amount, newPriceForOne, newPriceForTwo, newPriceForThree, eventDetail) {
    // Determine engraving state from the inputs
    const inputs = document.querySelector('.inputs');
    const variant_index = inputs ? parseInt(inputs.getAttribute('variant_index'), 10) : 0;
    const isEngraving = variant_index === 1;
    
    // Update CTA price based on current product amount
    const cta_product_price = document.querySelector('.cta-product-price');
    if (cta_product_price) {
      let currentPrice;
      if (product_amount === 1) {
        currentPrice = newPriceForOne;
      } else if (product_amount === 2) {
        currentPrice = newPriceForTwo;
      } else {
        currentPrice = newPriceForThree;
      }
      cta_product_price.innerHTML = formatMoneyWithFallback(currentPrice);
    }
    
  }
</script>

<script>
  var bottom_autoplay_carousel;

  // Function to initialize Swiper when library is ready
  function initializeSwipers() {
    if (typeof Swiper === 'undefined') {
      // Swiper not loaded yet, wait and try again
      setTimeout(initializeSwipers, 50);
      return;
    }

    const thumbs_swiper = new Swiper('.thumbsSlider', {
      slidesPerView: 5.5,
      freeMode: true,
      watchSlidesProgress: true,
      spaceBetween: 10,
      breakpoints: {
        0: {
          slidesPerView: 5.5,
        },
        767: {
          slidesPerView: 6,
          spaceBetween: 20,
        },
      },
    });

    const main_swiper = new Swiper('.pdp-chuug-vessel-main-swiper', {
      slidesPerView: 'auto',
      spaceBetween: 5,
      thumbs: {
        swiper: thumbs_swiper,
      },
    });

    bottom_autoplay_carousel = new Swiper('.bottom-autoplay-carousel', {
      slidesPerView: 1,
      spaceBetween: 15,
      loop: true,
      simulateTouch: false,
      autoplay: {
        delay: 3000,
        disableOnInteraction: false,
      },
      breakpoints: {
        0: {
          slidesPerView: 1,
        },
        1024: {
          slidesPerView: 4,
        },
        1366: {
          slidesPerView: 6,
        },
      },
    });
  }

  // Start initialization when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initializeSwipers);
  } else {
    // DOM already loaded
    initializeSwipers();
  }
</script>

