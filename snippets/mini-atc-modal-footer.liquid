{% comment %}
  Mini ATC Modal - Footer Component
  
  Semantic footer with pricing display and primary action button.
{% endcomment %}

<div class="mini-atc-modal__subtotal-row" role="region" aria-labelledby="{{ modal_id }}-pricing-heading">
  <h3 id="{{ modal_id }}-pricing-heading" class="visually-hidden">Order Pricing</h3>
  
  <div class="mini-atc-modal__left-section">
    <span class="mini-atc-modal__subtotal-label">Subtotal</span>
  </div>
  
  <div class="mini-atc-modal__right-section">
    <div class="mini-atc-modal__pricing">
      <div class="mini-atc-modal__prices">
        <span 
          class="mini-atc-modal__current-price" 
          data-current-price="true"
          aria-label="Current total price"
        >
          {% comment %} Dynamic pricing integration point - will be updated by JavaScript {% endcomment %}
          {%- if cart.total_price -%}
            <span class="pricing-placeholder">{{ cart.total_price | money }}</span>
          {%- else -%}
            <span class="pricing-placeholder">...</span>
          {%- endif -%}
        </span>
        <span 
          class="mini-atc-modal__original-price" 
          data-original-price="true"
          aria-label="Original price before discounts"
        >
          {%- comment -%} Calculate total original price from compare at prices {%- endcomment -%}
          {%- assign modal_total_compare_at_price = 0 -%}
          {%- for item in cart.items -%}
            {%- if item.properties["_Compare At Price"] -%}
              {%- assign compare_at_line_price = item.properties["_Compare At Price"] | times: item.quantity -%}
              {%- assign modal_total_compare_at_price = modal_total_compare_at_price | plus: compare_at_line_price -%}
            {%- else -%}
              {%- assign modal_total_compare_at_price = modal_total_compare_at_price | plus: item.original_line_price -%}
            {%- endif -%}
          {%- endfor -%}
          <span class="pricing-dynamic">{{ modal_total_compare_at_price | money }}</span>
        </span>
      </div>
    </div>
    
    <div class="mini-atc-modal__savings" aria-label="Total savings amount">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none">
        <g clip-path="url(#clip0_2485_1866)">
          <path fill-rule="evenodd" clip-rule="evenodd" d="M0.5 8.21826L8 0.718262H15.5V8.21826L8 15.7183L0.5 8.21826ZM11.2812 6.34326C10.5046 6.34326 9.875 5.71367 9.875 4.93701C9.875 4.16036 10.5046 3.53076 11.2812 3.53076C12.0579 3.53076 12.6875 4.16036 12.6875 4.93701C12.6875 5.71367 12.0579 6.34326 11.2812 6.34326Z" fill="#A43223"/>
        </g>
        <defs>
          <clipPath id="clip0_2485_1866">
            <rect width="15" height="15" fill="white" transform="matrix(-1 0 0 1 15.5 0.718262)"/>
          </clipPath>
        </defs>
      </svg>
      {%- comment -%} Calculate total savings amount {%- endcomment -%}
      {%- assign modal_total_compare_at_price = 0 -%}
      {%- for item in cart.items -%}
        {%- if item.properties["_Compare At Price"] -%}
          {%- assign compare_at_line_price = item.properties["_Compare At Price"] | times: item.quantity -%}
          {%- assign modal_total_compare_at_price = modal_total_compare_at_price | plus: compare_at_line_price -%}
        {%- else -%}
          {%- assign modal_total_compare_at_price = modal_total_compare_at_price | plus: item.original_line_price -%}
        {%- endif -%}
      {%- endfor -%}
      {%- assign modal_total_savings = modal_total_compare_at_price | minus: cart.total_price -%}
      
      <span class="mini-atc-modal__savings-text" data-savings-amount="{{ modal_total_savings }}">
        <span class="pricing-dynamic">You Saved {{ modal_total_savings | money }}</span>
      </span>
    </div>
  </div>
</div>

<button 
  type="button"
  class="mini-atc-modal__add-to-cart-btn" 
  data-modal-action="add-to-cart"
  aria-describedby="{{ modal_id }}-cart-description"
  {% comment %} Future cart integration {% endcomment %}
  data-cart-action="add"
  data-cart-redirect="{{ routes.cart_url }}"
>
  <span class="mini-atc-modal__btn-text">ADD TO CART</span>
</button>

<div id="{{ modal_id }}-cart-description" class="visually-hidden">
  Add all selected items to your shopping cart and proceed to checkout
</div>

{% comment %} 
  Future integration points for cart data:
  - data-cart-items: JSON of selected items
  - data-cart-totals: Pricing calculation data
  - data-cart-properties: Custom properties for personalization
{% endcomment %}
