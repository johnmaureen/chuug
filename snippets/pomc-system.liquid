                ONLY £39 EACH!
              </span>
            </div>
            

          </label>
        </div>
        <div class="tw-w-full">
          <label
            class="tw-cursor-pointer"
          >
            <div
            onclick="setProductAmount('3')"
            class="vessel_number_item product_amount_label_3">
              <span class="promo-label">BEST VALUE</span>

              <span class="vessel-multiplier tw-text-center tw-text-[2rem] tw-leading-[1] tw-font-bold tw-tracking-[0.0625em] tw-leading-5"
                >3x</span
              >
              <div class="vessel-price-wrap tw-whitespace-nowrap tw-flex tw-items-center">
                <span
                  class="product_amount_original_price product_amount_label_3_compare_at_price tw-line-through tw-text-[1.6rem] tw-font-bold tw-leading-4 tw-tracking-tighter tw-flex tw-gap-x-[1rem]"
                  no_engraving_compare_at_price="{{ section.settings.three_chuug_product.compare_at_price | money }}"
                  engraving_compare_at_price="{{ section.settings.three_chuug_product.variants[1].compare_at_price | money }}"
                >
                  {{ section.settings.three_chuug_product.variants[0].compare_at_price | money }}
                </span>
                <span
                  class="product_amount_price product_amount_label_3_price tw-text-[1.6rem] tw-font-bold tw-leading-4"
                  no_engraving_price="{{ section.settings.three_chuug_product.price | money }}"
                  engraving_price="{{ section.settings.three_chuug_product.variants[1].price | money }}"
                >
                  {{- section.settings.three_chuug_product.variants[0].price | money -}}
