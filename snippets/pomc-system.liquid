<!-- Mini ATC Modal -->
<div id="mini-atc-modal" class="mini-atc-modal">
  <div class="mini-atc-modal__overlay"></div>
  <div class="mini-atc-modal__container">
    <!-- Fixed Header -->
    <div class="mini-atc-modal__header">
      <h2 class="mini-atc-modal__title">Personalise Your CHUUG</h2>
      <button class="mini-atc-modal__close" onclick="closeMiniATCModal()">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M18 6L6 18M6 6L18 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
    
    <!-- Scrollable Content -->
    <div class="mini-atc-modal__content">
      <!-- Personalise Content Wrapper -->
      <div class="mini-atc-modal__personalise-wrap mini-atc-modal__content-wrap--active">
        <!-- Product Image -->
        <div class="mini-atc-modal__product-image">
          <div class="swiper mini-atc-product-swiper">
            <div class="swiper-wrapper">
              <div class="swiper-slide">
                <div class="product-image-wrap">
                  <div class="img-wrap">
                    <img src="{{ 'vessel-sample.png' | asset_url }}" alt="CHUUG Vessel" width="400" height="400" />
                  </div>
                </div>
              </div>
              <div class="swiper-slide">
                <div class="product-image-wrap">
                  <div class="img-wrap">
                    <img src="{{ 'dusk_natural.png' | asset_url }}" alt="CHUUG Vessel - Dusk Natural" width="400" height="400" />
                  </div>
                </div>
              </div>
              <div class="swiper-slide">
                <div class="product-image-wrap">
                  <div class="img-wrap">
                    <img src="{{ 'dawn_charcoal.png' | asset_url }}" alt="CHUUG Vessel - Dawn Charcoal" width="400" height="400" />
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="mini-atc-modal__image-dots">
            <span class="dot active"></span>
            <span class="dot"></span>
            <span class="dot"></span>
          </div>
        </div>
        <div class="personalization-cards">
          <!-- Personalization Options -->
          <div class="mini-atc-modal__personalization mini-vessel-names">
            <div class="mini-atc-modal__personalization-header">
              <div class="mini-atc-modal__personalization-header-content">
                <div class="mini-atc-modal__personalization-icon">
                  {% render 'personalization-icon', icon_type: 'pencil' %}
                </div>
                <h3>Add a Personalised <br/>Coin Engraving?</h3>
              </div>
              <div class="mini-atc-modal__personalization-header-content_right">
                <a href="#" class="mini-atc-modal__design-link">Can I see the design?</a>
                {% render 'icon-question-mark-tooltip', tooltip_text: section.settings.vessel_question_tooltip_text %}
                <div class="mini-atc-modal__toggle-container">
                  <label class="mini-atc-modal__toggle">
                    <input type="checkbox" id="engraving-toggle" checked>
                    <span class="mini-atc-modal__toggle-slider"></span>
                  </label>
                </div>
                </div>
              </div>
            <div class="mini-atc-modal__complete-options">
              <button class="mini-atc-modal__complete-set-btn">Complete Set</button>
              <div class="modal__personalization-vessel-name-wrap">
                <!-- Vessel #1 -->
                <div class="vessel-personalization-row">
                  <div class="vessel-info">
                    <span class="vessel-label">Vessel #1</span>
                    <div class="mini-atc-modal__toggle-container">
                      <label class="mini-atc-modal__toggle">
                        <input type="checkbox" id="vessel-1-toggle" checked>
                        <span class="mini-atc-modal__toggle-slider"></span>
                      </label>
                    </div>
                  </div>
                  <div class="vessel-input-container">
                    <input 
                      type="text" 
                      id="vessel-1-name" 
                      class="vessel-name-input" 
                      placeholder="Maximum of 3 Letters"
                      maxlength="3"
                      disabled
                    >
                  </div>
                </div>

                <!-- Vessel #2 -->
                <div class="vessel-personalization-row">
                  <div class="vessel-info">
                    <span class="vessel-label">Vessel #2</span>
                    <div class="mini-atc-modal__toggle-container">
                      <label class="mini-atc-modal__toggle">
                        <input type="checkbox" id="vessel-2-toggle" checked>
                        <span class="mini-atc-modal__toggle-slider"></span>
                      </label>
                    </div>
                  </div>
                  <div class="vessel-input-container">
                    <input 
                      type="text" 
                      id="vessel-2-name" 
                      class="vessel-name-input" 
                      placeholder="Maximum of 3 Letters"
                      maxlength="3"
                      disabled
                    >
                  </div>
                </div>
              </div>
            </div>
           
          </div>


          <!-- Mix & Match Container -->
          <div class="mini-atc-modal__personalization mini-atc-modal__mix-match">
            <div class="mini-atc-modal__personalization-header">
              <div class="mini-atc-modal__personalization-header-content">
                <div class="mini-atc-modal__personalization-icon">
                  {% render 'personalization-icon', icon_type: 'cup' %}
                </div>
                <h3>Add Extra Insulated Cups?</h3>
              </div>
              <div class="mini-atc-modal__personalization-header-content_right">
                  <a href="#" class="mini-atc-modal__design-link">See preview</a>
                  {% render 'icon-question-mark-tooltip', tooltip_text: section.settings.vessel_question_tooltip_text %}
                  <div class="mini-atc-modal__toggle-container">
                    <label class="mini-atc-modal__toggle">
                      <input type="checkbox" id="mix-match-toggle" checked>
                      <span class="mini-atc-modal__toggle-slider"></span>
                    </label>
                  </div>
                </div>
              </div>
            <div class="mini-atc-modal__complete-options">
              <button class="mini-atc-modal__complete-set-btn bg-green">Mix & Match Set</button>
              <!-- Mix & Match Content -->
              <div class="mini-atc-modal__mix-match-content">
                <!-- Info Box -->
                <div class="mini-atc-modal__mix-match-info">
                  <div class="mini-atc-modal__mix-match-info-content">
                    <p>💡 You already get 1 free silver insulated cup with each CHUUG. Add backup insulated cups so you're never without your CHUUG!</p>
                  </div>
                </div>
                
                <!-- Product Variants -->
                <div class="mini-atc-modal__mix-match-variants">
                  <!-- Midnight Black -->
                  <div class="mini-atc-modal__variant-row">
                    <div class="mini-atc-modal__variant-image">
                      <img src="{{ 'midnight_charcoal.png' | asset_url }}" alt="Midnight Black Cup" width="37" height="64" />
                    </div>
                    <div class="mini-atc-modal__variant-details">
                      <div class="mini-atc-modal__variant-info">
                        <h4 class="mini-atc-modal__variant-name">Midnight Black</h4>
                        <p class="mini-atc-modal__variant-description">Matches most CHUUGs</p>
