
{%- liquid
  assign dusk_charcoal = all_products[section.settings.dusk_charcoal]
  assign dusk_natural = all_products[section.settings.dusk_natural]
  assign dawn_charcoal = all_products[section.settings.dawn_charcoal]
  assign dawn_natural = all_products[section.settings.dawn_natural]
  assign midnight_charcoal = all_products[section.settings.midnight_charcoal]
  assign midnight_natural = all_products[section.settings.midnight_natural]
-%}

<script>
  // Make product IDs available to JavaScript
  window.PRODUCT_IDS = {
    dusk_charcoal: {{ dusk_charcoal.id | json }},
    dusk_natural: {{ dusk_natural.id | json }},
    dawn_charcoal: {{ dawn_charcoal.id | json }},
    dawn_natural: {{ dawn_natural.id | json }},
    midnight_charcoal: {{ midnight_charcoal.id | json }},
    midnight_natural: {{ midnight_natural.id | json }}
  };
  
  // Make product handles available to JavaScript
  window.PRODUCT_HANDLES = {
    dusk_charcoal: {{ dusk_charcoal.handle | json }},
    dusk_natural: {{ dusk_natural.handle | json }},
    dawn_charcoal: {{ dawn_charcoal.handle | json }},
    dawn_natural: {{ dawn_natural.handle | json }},
    midnight_charcoal: {{ midnight_charcoal.handle | json }},
    midnight_natural: {{ midnight_natural.handle | json }}
  };
  
  // Make product amount products available to JavaScript
  window.PRODUCT_AMOUNT_PRODUCTS = {
    1: {
      id: {{ section.settings.one_chuug_product.id | json }},
      handle: {{ section.settings.one_chuug_product.handle | json }},
      price: {{ section.settings.one_chuug_product.price | json }},
      compare_at_price: {{ section.settings.one_chuug_product.compare_at_price | json }},
      variants: [
        {
          id: {{ section.settings.one_chuug_product.variants[0].id | json }},
          price: {{ section.settings.one_chuug_product.variants[0].price | json }},
          compare_at_price: {{ section.settings.one_chuug_product.variants[0].compare_at_price | json }}
        },
        {
          id: {{ section.settings.one_chuug_product.variants[1].id | json }},
          price: {{ section.settings.one_chuug_product.variants[1].price | json }},
          compare_at_price: {{ section.settings.one_chuug_product.variants[1].compare_at_price | json }}
        }
      ]
    },
    2: {
      id: {{ section.settings.two_chuug_product.id | json }},
      handle: {{ section.settings.two_chuug_product.handle | json }},
      price: {{ section.settings.two_chuug_product.price | json }},
      compare_at_price: {{ section.settings.two_chuug_product.compare_at_price | json }},
      variants: [
        {
          id: {{ section.settings.two_chuug_product.variants[0].id | json }},
          price: {{ section.settings.two_chuug_product.variants[0].price | json }},
          compare_at_price: {{ section.settings.two_chuug_product.variants[0].compare_at_price | json }}
        },
        {
          id: {{ section.settings.two_chuug_product.variants[1].id | json }},
          price: {{ section.settings.two_chuug_product.variants[1].price | json }},
          compare_at_price: {{ section.settings.two_chuug_product.variants[1].compare_at_price | json }}
        }
      ]
    },
    3: {
      id: {{ section.settings.three_chuug_product.id | json }},
      handle: {{ section.settings.three_chuug_product.handle | json }},
      price: {{ section.settings.three_chuug_product.price | json }},
      compare_at_price: {{ section.settings.three_chuug_product.compare_at_price | json }},
      variants: [
        {
          id: {{ section.settings.three_chuug_product.variants[0].id | json }},
          price: {{ section.settings.three_chuug_product.variants[0].price | json }},
          compare_at_price: {{ section.settings.three_chuug_product.variants[0].compare_at_price | json }}
        },
        {
          id: {{ section.settings.three_chuug_product.variants[1].id | json }},
          price: {{ section.settings.three_chuug_product.variants[1].price | json }},
          compare_at_price: {{ section.settings.three_chuug_product.variants[1].compare_at_price | json }}
        }
      ]
    }
  };
  
  // Helper function to get product data for a specific amount
  window.getProductAmountData = function(amount) {
    return window.PRODUCT_AMOUNT_PRODUCTS[amount] || null;
  };
</script>

<div class="tw-flex tw-flex-col tw-gap-y-2 tw-text-white">
      <div class="tw-flex tw-whitespace-nowrap">
        <div class="label-text"><span>1</span>{{ section.settings.vessel_question }} 
          {% render 'icon-question-mark-tooltip', tooltip_text: section.settings.vessel_question_tooltip_text %}
        </div>
      </div>

      <div class="vessel-number-wrap tw-flex tw-flex-wrap tw-items-end tw-gap-y-[1rem] tw-gap-x-[0.62em] tw-px-2 md:tw-flex-nowrap">
        <div class="tw-w-full">
          <label
            class="tw-cursor-pointer"
          >
            <div
              onclick="setProductAmount('1')" class="vessel_number_item product_amount_label_1"
            >
              <span class="vessel-multiplier tw-text-center tw-text-[2rem] tw-leading-[1] tw-font-bold tw-tracking-[0.0625em] tw-leading-5"
                >1x</span
              >
              <div class="vessel-price-wrap tw-whitespace-nowrap tw-flex tw-items-center">
                <span
                  class="product_amount_original_price product_amount_label_1_compare_at_price tw-line-through tw-text-[1.6rem] tw-font-bold tw-leading-4 tw-tracking-tighter tw-flex tw-gap-x-[1rem]"
                  no_engraving_compare_at_price="{{ section.settings.one_chuug_product.compare_at_price | money }}"
                  engraving_compare_at_price="{{  section.settings.one_chuug_product.variants[1].compare_at_price | money }}"
                >
                  {{ section.settings.one_chuug_product.variants[0].compare_at_price | money }}
                </span>
                <span
                  class="product_amount_price product_amount_label_1_price tw-text-[1.6rem] tw-font-bold tw-leading-4"
                  no_engraving_price="{{ section.settings.one_chuug_product.price | money }}"
                  engraving_price="{{ section.settings.one_chuug_product.variants[1].price | money }}"
                >
                  {{ section.settings.one_chuug_product.variants[0].price | money }}
                </span>
              </div>
            </div>
          </label>
        </div>
        <div class="tw-w-full">
          <label
            class="tw-cursor-pointer"
          >
            <div onclick="setProductAmount('2')"
            class="vessel_number_item product_amount_label_2">
              <span class="promo-label">MOST POPULAR</span>
              <span class="vessel-multiplier tw-text-center tw-text-[2rem] tw-leading-[1] tw-font-bold tw-tracking-[0.0625em] tw-leading-5"
                >2x</span
              >
              <div class="vessel-price-wrap tw-whitespace-nowrap tw-flex tw-items-center">
                <span
                  class="product_amount_original_price product_amount_label_2_compare_at_price tw-line-through tw-text-[1.6rem] tw-font-bold tw-leading-4 tw-tracking-tighter tw-flex tw-gap-x-[1rem]"
                  no_engraving_compare_at_price="{{ section.settings.two_chuug_product.compare_at_price | money }}"
                  engraving_compare_at_price="{{ section.settings.two_chuug_product.variants[1].compare_at_price | money }}"
                >
                  {{ section.settings.two_chuug_product.variants[0].compare_at_price | money }}
                </span>
                <span
                  class="product_amount_price product_amount_label_2_price tw-text-[1.6rem] tw-font-bold tw-leading-4"
                  no_engraving_price="{{ section.settings.two_chuug_product.price | money }}"
                  engraving_price="{{ section.settings.two_chuug_product.variants[1].price | money }}"
                >
                  {{- section.settings.two_chuug_product.variants[0].price | money -}}
                </span>
              </div>
              <span class="discount-label">
                <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 11 11" fill="none">
                  <g clip-path="url(#clip0_2058_1100)">
