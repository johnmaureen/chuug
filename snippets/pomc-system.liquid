  // Function to update the selection display
  function updateSelectionDisplay(isTabSwitch = false) {
    const selectionWrap = document.querySelector('.selection-result-wrap');
    const noSelectionText = selectionWrap.querySelector('.no-selection-text');
    
    // Clear CSS classes
    selectionWrap.classList.remove('result-1', 'result-2', 'result-3');
    
    // Check if we have any selections (complete or partial)
    let hasAnySelections = false;
    let hasCompleteSelections = false;
    
    // First pass: check what we have
    for (let vesselNum = 1; vesselNum <= 3; vesselNum++) {
      const selection = vesselSelections[vesselNum];
      if (selection.woodType || selection.ropeType) {
        hasAnySelections = true;
      }
      if (selection.woodType && selection.ropeType) {
        hasCompleteSelections = true;
      }
    }
    
    // Hide the "Your selection will appear here" text if we have any selections or if we're updating the active vessel
    if (hasAnySelections || vesselSelections[activeVessel].woodType || vesselSelections[activeVessel].ropeType) {
      noSelectionText.style.display = 'none';
    } else {
      // If no selections at all, show the "Your selection will appear here" text
      noSelectionText.style.display = 'block';
      return;
    }
    
    console.log('updateSelectionDisplay:', {
      currentVesselCount,
      activeVessel,
      vesselSelections,
      hasAnySelections,
      hasCompleteSelections
    });

    // Update/create result items for ALL vessels in the current count, maintaining their order
    for (let vesselNum = 1; vesselNum <= currentVesselCount; vesselNum++) {
      const selection = vesselSelections[vesselNum];
      console.log(`Checking vessel ${vesselNum}:`, selection);
      
      // Create/update result item for this vessel (regardless of whether it has selections)
      let resultItem = selectionWrap.querySelector(`.result-item[data-vessel="${vesselNum}"]`);
      
      if (!resultItem) {
        console.log(`Creating new result item for vessel ${vesselNum}`);
        // Create new result item if it doesn't exist
        resultItem = document.createElement('div');
        resultItem.className = 'result-item';
        resultItem.setAttribute('data-vessel', vesselNum);
        
          // Make result item clickable to switch to that vessel
          resultItem.addEventListener('click', function() {
            console.log(`🖱️ Result item clicked for vessel ${vesselNum}`);
            switchToVessel(vesselNum);
          });
        
        // Insert at the correct position based on vessel number
        insertResultItemAtPosition(selectionWrap, resultItem, vesselNum);
      } else {
        console.log(`Result item already exists for vessel ${vesselNum}, updating content`);
      }
      
      // Always update the content of the result item (will show placeholder if no selections)
      updateResultItemContent(resultItem, selection, vesselNum, isTabSwitch);
    }
    
    // Only remove result items that are beyond the current vessel count
    const allResultItems = selectionWrap.querySelectorAll('.result-item');
    allResultItems.forEach(item => {
      const itemVesselNum = parseInt(item.getAttribute('data-vessel'));
      if (itemVesselNum > currentVesselCount) {
        console.log(`Removing result item for vessel ${itemVesselNum} (beyond current count)`);
        item.remove();
      }
    });
    
    // Apply the correct CSS class based on number of vessels shown
    const vesselCount = selectionWrap.querySelectorAll('.result-item').length;
    console.log(`Final result: ${vesselCount} result items displayed`);
    if (vesselCount > 0) {
      selectionWrap.classList.add(`result-${vesselCount}`);
    }
  }

  // Function to insert result item at the correct position
  function insertResultItemAtPosition(container, newItem, vesselNum) {
    const existingItems = container.querySelectorAll('.result-item');
    let insertBefore = null;
    
    // Find the correct position based on vessel number
    for (let i = 0; i < existingItems.length; i++) {
      const existingVesselNum = parseInt(existingItems[i].getAttribute('data-vessel'));
      if (vesselNum < existingVesselNum) {
        insertBefore = existingItems[i];
        break;
      }
    }
    
    if (insertBefore) {
      container.insertBefore(newItem, insertBefore);
    } else {
      container.appendChild(newItem);
    }
  }

  // Function to update the content of a result item
  function updateResultItemContent(resultItem, selection, vesselNum, isTabSwitch) {
    // Get or create existing elements
    let imgWrap = resultItem.querySelector('.img-wrap');
    let img = resultItem.querySelector('.img-wrap img');
    let text = resultItem.querySelector('p');
    
    // If elements don't exist, create them
    if (!imgWrap) {
      imgWrap = document.createElement('div');
      imgWrap.className = 'img-wrap';
      resultItem.appendChild(imgWrap);
    }
    
    if (!img) {
      img = document.createElement('img');
      imgWrap.appendChild(img);
    }
    
    if (!text) {
      text = document.createElement('p');
      resultItem.appendChild(text);
    }
    
    // Determine what content should be displayed
    let newImageSrc = '';
    let newAltText = '';
    let newTextContent = '';
    let shouldShowLoading = false;
    
    if (selection.woodType && selection.ropeType) {
      // Complete selection - show actual image
      const imageName = `${selection.woodType.toLowerCase()}_${selection.ropeType.toLowerCase()}.png`;
      newAltText = `${selection.woodType} ${selection.ropeType} Vessel #${vesselNum}`;
      newTextContent = `${selection.woodType} • ${selection.ropeType}`;
      
      // Check if this image is already loaded in the DOM to avoid loading state
      const existingImg = document.querySelector(`img[src*="${imageName}"]`);
      if (existingImg && existingImg.complete) {
        // Image already exists and is loaded, use it directly
        newImageSrc = existingImg.src;
      } else {
        // Need to load the image
        newImageSrc = `{{ 'dusk_natural.png' | asset_url }}`.replace('dusk_natural.png', imageName);
        shouldShowLoading = !isTabSwitch && vesselNum === activeVessel;
      }
    } else if (selection.woodType || selection.ropeType) {
      // Partial selection
      newImageSrc = 'data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMTI0IiBoZWlnaHQ9IjE1MiIgdmlld0JveD0iMCAwIDEyNCAxNTIiIGZpbGw9Im5vbmUiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+CjxyZWN0IHdpZHRoPSIxMjQiIGhlaWdodD0iMTUyIiBmaWxsPSIjMWExYTFhIi8+Cjwvc3ZnPgo=';
      newAltText = (isTabSwitch || vesselNum !== activeVessel) ? 'Partial selection' : 'Loading...';
      shouldShowLoading = !isTabSwitch && vesselNum === activeVessel;
      
      // Show partial selection text with vessel number
      const selectedParts = [];
      if (selection.woodType) selectedParts.push(selection.woodType);
      if (selection.ropeType) selectedParts.push(selection.ropeType);
      newTextContent = `${selectedParts.join(' • ')} • ...`;
    } else {
      // No selections
      newImageSrc = 'data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMTI0IiBoZWlnaHQ9IjE1MiIgdmlld0JveD0iMCAwIDEyNCAxNTIiIGZpbGw9Im5vbmUiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+CjxyZWN0IHdpZHRoPSIxMjQiIGhlaWdodD0iMTUyIiBmaWxsPSIjMWExYTFhIi8+Cjwvc3ZnPgo=';
      newAltText = 'No selection';
      newTextContent = `Vessel #${vesselNum}`;
    }
    
    // Only update elements if content has actually changed
    if (img.src !== newImageSrc) {
      if (selection.woodType && selection.ropeType) {
        // For complete selections, check if we can reuse existing loaded image
        const imageName = `${selection.woodType.toLowerCase()}_${selection.ropeType.toLowerCase()}.png`;
        const existingImg = document.querySelector(`img[src*="${imageName}"]`);
        if (existingImg && existingImg.complete) {
          img.src = existingImg.src;
          img.style.display = 'block';
        } else {
          // Load new image
          img.style.display = 'none';
          const preloadImg = new Image();
          preloadImg.onload = function() {
            img.src = preloadImg.src;
            img.style.display = 'block';
            if (shouldShowLoading) {
              resultItem.classList.remove('loading');
            }
          };
          preloadImg.onerror = function() {
            img.style.display = 'block';
            img.src = 'data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMTI0IiBoZWlnaHQ9IjE1MiIgdmlld0JveD0iMCAwIDEyNCAxNTIiIGZpbGw9Im5vbmUiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+CjxyZWN0IHdpZHRoPSIxMjQiIGhlaWdodD0iMTUyIiBmaWxsPSIjMWExYTFhIi8+Cjwvc3ZnPgo=';
            if (shouldShowLoading) {
              resultItem.classList.remove('loading');
            }
            console.error('Failed to load image:', imageName);
          };
          preloadImg.src = newImageSrc;
        }
      } else {
        // For partial selections or placeholders, set directly
        img.src = newImageSrc;
        img.style.display = 'block';
      }
    }
    
    // Update alt text if changed
    if (img.alt !== newAltText) {
      img.alt = newAltText;
    }
    
    // Always update text content to ensure vessel number is displayed
    if (selection.woodType || selection.ropeType) {
      // For complete or partial selections, show only the selection text (no vessel label)
      const selectionText = document.createElement('div');
      if (selection.woodType && selection.ropeType) {
        selectionText.textContent = `${selection.woodType} • ${selection.ropeType}`;
      } else {
        const selectedParts = [];
        if (selection.woodType) selectedParts.push(selection.woodType);
        if (selection.ropeType) selectedParts.push(selection.ropeType);
        selectionText.textContent = `${selectedParts.join(' • ')} • ...`;
      }
      
      text.innerHTML = '';
      text.appendChild(selectionText);
      text.style.opacity = '';
    } else {
      // For empty vessels, just show vessel number
      text.innerHTML = '';
      text.textContent = `Vessel #${vesselNum}`;
      text.style.opacity = '0.5';
    }
    
    // Update loading state
    if (shouldShowLoading) {
      resultItem.classList.add('loading');
    } else {
      resultItem.classList.remove('loading');
    }
    
    // Update active vessel class
    if (!selection.woodType && !selection.ropeType) {
      resultItem.classList.add('active-vessel');
    } else {
      resultItem.classList.remove('active-vessel');
    }
  }

  // Function to switch to a specific vessel
  function switchToVessel(vesselNumber) {
    console.log(`🔄 switchToVessel called: requesting switch to vessel ${vesselNumber}`);
    if (vesselNumber >= 1 && vesselNumber <= 3) {
      // Find and click the corresponding vessel tab button
      const tabButton = document.querySelector(`[data-tab="tab${vesselNumber}"]`);
      if (tabButton) {
        console.log(`📝 Found tab button for vessel ${vesselNumber}, clicking it`);
        tabButton.click();
      } else {
        console.warn(`❌ Tab button not found for vessel ${vesselNumber}`);
      }
    } else {
      console.warn(`❌ Invalid vessel number: ${vesselNumber}`);
    }
  }

  // Function to switch to vessel #1 (called when vessel count changes)
  function switchToVesselOne() {
    switchToVessel(1);
  }

  // Function to update vessel tab visibility based on count
  function updateVesselTabVisibility(vesselCount) {
    const vesselCountNum = parseInt(vesselCount);
    currentVesselCount = vesselCountNum; // Update global vessel count
    
    console.log('updateVesselTabVisibility called:', {
      vesselCount,
      vesselCountNum,
      currentActiveVessel: activeVessel,
      currentVesselCount,
      previousVesselCount: currentVesselCount
    });
    
    // Check if current active vessel is beyond the new count
    if (activeVessel > vesselCountNum) {
      console.log('Active vessel beyond count, switching to vessel #1');
      // If active vessel is beyond new count, switch to vessel #1
      activeVessel = 1;
    }
    
    // Update vessel tab buttons visibility
    for (let i = 1; i <= 3; i++) {
      const tabButton = document.querySelector(`.vessel_number_${i}`);
      const tabPanel = document.querySelector(`#tab${i}`);
      
      if (tabButton && tabPanel) {
        if (i <= vesselCountNum) {
          tabButton.style.display = 'flex';
          // Show only the active vessel panel, hide others
          if (i === activeVessel) {
            console.log(`🎯 Setting vessel ${i} as ACTIVE (matches activeVessel ${activeVessel})`);
            tabPanel.style.display = 'block';
            tabButton.classList.remove('inactive');
            tabButton.classList.add('active');
          } else {
            console.log(`📋 Setting vessel ${i} as INACTIVE (activeVessel is ${activeVessel})`);
            tabPanel.style.display = 'none';
            tabButton.classList.remove('active');
            tabButton.classList.add('inactive');
          }
        } else {
          console.log(`🚫 Hiding vessel ${i} (beyond vessel count ${vesselCountNum})`);
          // Hide tabs beyond the vessel count
          tabButton.style.display = 'none';
          tabPanel.style.display = 'none';
          tabButton.classList.remove('active', 'inactive');
        }
      }
    }
    
    // Clear selections for vessels beyond the new vessel count
    for (let i = vesselCountNum + 1; i <= 3; i++) {
      if (vesselSelections[i] && (vesselSelections[i].woodType || vesselSelections[i].ropeType)) {
        console.log(`🧹 Clearing selections for hidden vessel ${i}:`, vesselSelections[i]);
        vesselSelections[i] = { woodType: null, ropeType: null };
        
        // Also clear any radio button selections for this vessel
        const vesselWoodInputs = document.querySelectorAll(`input[name="wood_material_${i}"]`);
        const vesselRopeInputs = document.querySelectorAll(`input[name="rope_material_${i}"]`);
        
        vesselWoodInputs.forEach(input => {
          input.checked = false;
          input.closest('label').classList.remove('active');
        });
        
        vesselRopeInputs.forEach(input => {
          input.checked = false;
          input.closest('label').classList.remove('active');
        });
        
        console.log(`✅ Cleared vessel ${i} selections and UI state`);
      }
    }
    
    // Save the updated selections to localStorage
    localStorage.setItem('vesselSelections', JSON.stringify(vesselSelections));
    console.log('💾 Saved updated vessel selections to localStorage');
    
    // Clear any pre-selected options after vessel count change
    setTimeout(() => {
      clearAllPreselectedOptions();
    }, 100); // Small delay to ensure DOM is updated
    
    // Update selection display to reflect new vessel count
    updateSelectionDisplay(false); // false indicates this is not a tab switch
  }

  // Setup function override after a delay to ensure original function is loaded
  function setupSetProductAmountOverride() {
    console.log('Setting up setProductAmount override...');
    
    // Store the original function
    if (typeof window.setProductAmount === 'function') {
      console.log('Found original setProductAmount, storing backup');
      window.originalSetProductAmount = window.setProductAmount;
    } else {
      console.log('Original setProductAmount not found yet');
      return false;
    }

    // Override the function
    window.setProductAmount = function(amount) {
      console.log('🔧 POMC setProductAmount called with:', amount);
      
      // Call the original function
      if (window.originalSetProductAmount) {
        console.log('Calling original setProductAmount');
        window.originalSetProductAmount(amount);
      }
      
      // Update vessel tab visibility
      console.log('Updating vessel tab visibility for amount:', amount);
      updateVesselTabVisibility(amount);
    };
    
    console.log('✅ setProductAmount override complete');
    return true;
  }

  // Try to setup override immediately
  if (!setupSetProductAmountOverride()) {
    // If it fails, try again after delays
    setTimeout(function() {
      if (!setupSetProductAmountOverride()) {
        setTimeout(function() {
          if (!setupSetProductAmountOverride()) {
            console.warn('⚠️ Could not override setProductAmount after multiple attempts');
          }
        }, 1000);
      }
    }, 100);
  }

  // Function to get current vessel selection
  function getCurrentVesselSelection() {
    return vesselSelections[activeVessel];
  }

  // Function to validate vessel selections
  function validateVesselSelections() {
    const errors = [];
    const warnings = [];
    
    for (let vesselNum = 1; vesselNum <= 3; vesselNum++) {
      const selection = vesselSelections[vesselNum];
      
      // Check for partial selections
      if ((selection.woodType && !selection.ropeType) || (!selection.woodType && selection.ropeType)) {
        warnings.push(`Vessel #${vesselNum} has incomplete selection`);
      }
      
      // Check for invalid combinations (if any business rules exist)
      if (selection.woodType && selection.ropeType) {
        // Add any specific validation rules here
        // Example: if (selection.woodType === 'MIDNIGHT' && selection.ropeType === 'NATURAL') {
        //   warnings.push(`Vessel #${vesselNum} has unusual combination`);
        // }
      }
    }
    
    return { errors, warnings };
  }

  // Function to show validation feedback
  function showValidationFeedback(validation) {
    // Remove existing feedback
    const existingFeedback = document.querySelector('.validation-feedback');
    if (existingFeedback) {
      existingFeedback.remove();
    }
    
    if (validation.warnings.length > 0) {
      const feedback = document.createElement('div');
      feedback.className = 'validation-feedback tw-mt-2 tw-p-2 tw-bg-yellow-100 tw-text-yellow-800 tw-rounded tw-text-sm';
      feedback.innerHTML = validation.warnings.map(warning => `⚠️ ${warning}`).join('<br>');
      
      const selectionWrap = document.querySelector('.selection-result-wrap');
      selectionWrap.parentNode.insertBefore(feedback, selectionWrap.nextSibling);
    }
  }

  // Function to set vessel selection programmatically
  function setVesselSelection(vesselNumber, woodType, ropeType) {
    if (vesselNumber >= 1 && vesselNumber <= 3) {
      vesselSelections[vesselNumber].woodType = woodType;
      vesselSelections[vesselNumber].ropeType = ropeType;
      
      // Update the UI for that vessel
      const vesselPanel = document.getElementById(`tab${vesselNumber}`);
      if (vesselPanel) {
        // Update wood type selection
        const woodInput = vesselPanel.querySelector(`input[name="wood_material_${vesselNumber}"][value="${woodType}"]`);
        if (woodInput) {
          woodInput.checked = true;
          vesselPanel.querySelectorAll('.wood-type-label').forEach(label => {
            label.classList.remove('active');
          });
          woodInput.closest('.wood-type-label').classList.add('active');
        }
        
        // Update rope type selection
        const ropeInput = vesselPanel.querySelector(`input[name="rope_material_${vesselNumber}"][value="${ropeType}"]`);
        if (ropeInput) {
          ropeInput.checked = true;
          vesselPanel.querySelectorAll('.rope-type-label').forEach(label => {
            label.classList.remove('active');
          });
          ropeInput.closest('.rope-type-label').classList.add('active');
        }
      }
      
      // Validate and show feedback
      const validation = validateVesselSelections();
      showValidationFeedback(validation);
      
      updateSelectionDisplay(false); // false indicates this is not a tab switch
    }
  }

