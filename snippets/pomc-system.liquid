<script>
  // Default vessel selections
  const defaultVesselSelections = {
    1: { woodType: null, ropeType: null }, // No pre-selections
    2: { woodType: null, ropeType: null },
    3: { woodType: null, ropeType: null }
  };

  // Global state to track vessel selections
  let vesselSelections = { ...defaultVesselSelections };
  let activeVessel = 1; // Default active vessel
  let updateTimeout; // For debouncing updates
  let validationTimeout; // For debouncing validation

  // localStorage key for vessel selections
  const STORAGE_KEY = 'chuug_vessel_selections';
  let currentVesselCount = 3; // Track current vessel count

  // Function to save vessel selections to localStorage
  function saveVesselSelections() {
    try {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(vesselSelections));
    } catch (error) {
      console.warn('Could not save vessel selections to localStorage:', error);
    }
  }

  // Function to load vessel selections from localStorage
  function loadVesselSelections() {
    try {
      const saved = localStorage.getItem(STORAGE_KEY);
      if (saved) {
        const parsed = JSON.parse(saved);
        // Merge with defaults to ensure all vessels exist
        vesselSelections = { ...defaultVesselSelections, ...parsed };
        return true;
      }
    } catch (error) {
      console.warn('Could not load vessel selections from localStorage:', error);
    }
    return false;
  }

  // Function to clear vessel selections from localStorage
  function clearVesselSelections() {
    try {
      localStorage.removeItem(STORAGE_KEY);
      vesselSelections = { ...defaultVesselSelections };
      updateSelectionDisplay(false); // false indicates this is not a tab switch
      console.log('Vessel selections cleared from localStorage');
    } catch (error) {
      console.warn('Could not clear vessel selections from localStorage:', error);
    }
  }

  // Initialize vessel selection functionality
  document.querySelectorAll("[data-tabs]").forEach(tabComponent => {
    const tabs = tabComponent.querySelectorAll("[data-tab]");
    const contents = tabComponent.querySelectorAll("[id^='tab']");

    tabs.forEach(btn => {
      btn.addEventListener("click", () => {
        const target = btn.getAttribute("data-tab");
        const vesselNumber = parseInt(target.replace('tab', ''));

        // update active tab styles only inside this component
        tabs.forEach(b => {
          b.classList.remove("active");
          b.classList.add("inactive");
        });
        btn.classList.remove("inactive");
        btn.classList.add("active");

        // toggle content only inside this component
        contents.forEach(c => {
          c.classList.remove("active");
          if (c.id === target) {
            c.classList.add("active");
          }
        });

        // Update active vessel
        activeVessel = vesselNumber;
        updateSelectionDisplay(true); // true indicates this is a tab switch
      });
    });
  });

  // Handle wood type selection
  document.addEventListener('DOMContentLoaded', function() {
    // Initialize vessel count to 3 by default
    currentVesselCount = 3;
    // Add event listeners for wood type selection
    document.querySelectorAll('input[name="wood_material"]').forEach(input => {
      input.addEventListener('change', function() {
        const woodType = this.value;
        const vesselPanel = this.closest('.vessel-tab-panel');
        const vesselNumber = parseInt(vesselPanel.id.replace('tab', ''));
        
        vesselSelections[vesselNumber].woodType = woodType;
        
        // Update active state for wood type labels
        vesselPanel.querySelectorAll('.wood-type-label').forEach(label => {
          label.classList.remove('active');
        });
        this.closest('.wood-type-label').classList.add('active');
        
        // Debounced updates for performance
        clearTimeout(updateTimeout);
        clearTimeout(validationTimeout);
        
        updateTimeout = setTimeout(() => {
          saveVesselSelections();
          updateSelectionDisplay(false); // false indicates this is an actual selection, not tab switch
        }, 100);
        
        validationTimeout = setTimeout(() => {
          const validation = validateVesselSelections();
          showValidationFeedback(validation);
        }, 300);
      });
    });

    // Add event listeners for rope type selection
    document.querySelectorAll('input[name="rope_material"]').forEach(input => {
      input.addEventListener('change', function() {
        const ropeType = this.value;
        const vesselPanel = this.closest('.vessel-tab-panel');
        const vesselNumber = parseInt(vesselPanel.id.replace('tab', ''));
        
        vesselSelections[vesselNumber].ropeType = ropeType;
        
        // Update active state for rope type labels
        vesselPanel.querySelectorAll('.rope-type-label').forEach(label => {
          label.classList.remove('active');
        });
        this.closest('.rope-type-label').classList.add('active');
        
        // Debounced updates for performance
        clearTimeout(updateTimeout);
        clearTimeout(validationTimeout);
        
        updateTimeout = setTimeout(() => {
          saveVesselSelections();
          updateSelectionDisplay(false); // false indicates this is an actual selection, not tab switch
        }, 100);
        
        validationTimeout = setTimeout(() => {
          const validation = validateVesselSelections();
          showValidationFeedback(validation);
        }, 300);
      });
    });

    // Load saved selections or show empty state
    const hasLoadedSelections = loadVesselSelections();
    if (hasLoadedSelections) {
      // Restore UI state from saved selections
      restoreUIFromSelections();
    }
    updateSelectionDisplay(false); // false indicates this is not a tab switch

    // Clear localStorage when user navigates away from the page
    window.addEventListener('beforeunload', function() {
      clearVesselSelections();
    });

    // Also clear on page visibility change (when user switches tabs)
    document.addEventListener('visibilitychange', function() {
      if (document.hidden) {
        clearVesselSelections();
      }
    });
  });

  // Function to restore UI from saved selections
  function restoreUIFromSelections() {
    for (let vesselNum = 1; vesselNum <= 3; vesselNum++) {
      const selection = vesselSelections[vesselNum];
      const vesselPanel = document.getElementById(`tab${vesselNum}`);
      
      if (vesselPanel && selection) {
        // Restore wood type selection
        if (selection.woodType) {
          const woodInput = vesselPanel.querySelector(`input[name="wood_material"][value="${selection.woodType}"]`);
          if (woodInput) {
            woodInput.checked = true;
            vesselPanel.querySelectorAll('.wood-type-label').forEach(label => {
              label.classList.remove('active');
            });
            woodInput.closest('.wood-type-label').classList.add('active');
          }
        }
        
        // Restore rope type selection
        if (selection.ropeType) {
          const ropeInput = vesselPanel.querySelector(`input[name="rope_material"][value="${selection.ropeType}"]`);
          if (ropeInput) {
            ropeInput.checked = true;
            vesselPanel.querySelectorAll('.rope-type-label').forEach(label => {
              label.classList.remove('active');
            });
            ropeInput.closest('.rope-type-label').classList.add('active');
          }
        }
      }
    }
  }


  // Function to update the selection display
  function updateSelectionDisplay(isTabSwitch = false) {
    const selectionWrap = document.querySelector('.selection-result-wrap');
    const noSelectionText = selectionWrap.querySelector('.no-selection-text');
    
    // Only remove the active vessel's result item, preserve others
    const activeResultItem = selectionWrap.querySelector(`.result-item[data-vessel="${activeVessel}"]`);
    if (activeResultItem) {
      activeResultItem.remove();
    }
    
    // Clear CSS classes
    selectionWrap.classList.remove('result-1', 'result-2', 'result-3');
    
    // Check if we have any selections (complete or partial)
    let hasAnySelections = false;
    let hasCompleteSelections = false;
    
    // First pass: check what we have
    for (let vesselNum = 1; vesselNum <= 3; vesselNum++) {
      const selection = vesselSelections[vesselNum];
      if (selection.woodType || selection.ropeType) {
        hasAnySelections = true;
      }
      if (selection.woodType && selection.ropeType) {
        hasCompleteSelections = true;
      }
    }
    
    // Hide the "Your selection will appear here" text if we have any selections or if we're updating the active vessel
    if (hasAnySelections || vesselSelections[activeVessel].woodType || vesselSelections[activeVessel].ropeType) {
      noSelectionText.style.display = 'none';
    } else {
      // If no selections at all, show the "Your selection will appear here" text
      noSelectionText.style.display = 'block';
      return;
    }
    
    console.log('updateSelectionDisplay:', {
      currentVesselCount,
      activeVessel,
      vesselSelections
    });

    // Only create/update the active vessel's result item
    const vesselNum = activeVessel;
    const selection = vesselSelections[vesselNum];
    
    // Create result item for this vessel
    const resultItem = document.createElement('div');
    resultItem.className = 'result-item';
    resultItem.setAttribute('data-vessel', vesselNum);
    
    // Create image element
    const imgWrap = document.createElement('div');
    imgWrap.className = 'img-wrap';
    
    const img = document.createElement('img');
    
    // Create text element
    const text = document.createElement('p');
    
    if (selection.woodType && selection.ropeType) {
      // Complete selection - show actual image
      const imageName = `${selection.woodType.toLowerCase()}_${selection.ropeType.toLowerCase()}.png`;
      
      // Set alt text
      img.alt = `${selection.woodType} ${selection.ropeType} Vessel`;
      text.textContent = `${selection.woodType} • ${selection.ropeType}`;
        
      // Check if this image is already loaded in the DOM to avoid loading state
      const existingImg = document.querySelector(`img[src*="${imageName}"]`);
      if (existingImg && existingImg.complete) {
        // Image already exists and is loaded, use it directly
        img.src = existingImg.src;
        img.style.display = 'block';
      } else {
        // Hide image initially and load it
        img.style.display = 'none';
        
        // Only add loading state if this is not just a tab switch AND this is the active vessel
        if (!isTabSwitch && vesselNum === activeVessel) {
          resultItem.classList.add('loading');
        }
          
        // Create a new image to preload
        const preloadImg = new Image();
        preloadImg.onload = function() {
          // Image loaded successfully, show it
          img.src = preloadImg.src;
          img.style.display = 'block';
          if (!isTabSwitch && vesselNum === activeVessel) {
            resultItem.classList.remove('loading');
          }
        };
        preloadImg.onerror = function() {
          // Image failed to load, show placeholder
          img.style.display = 'block';
          img.src = 'data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMTI0IiBoZWlnaHQ9IjE1MiIgdmlld0JveD0iMCAwIDEyNCAxNTIiIGZpbGw9Im5vbmUiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+CjxyZWN0IHdpZHRoPSIxMjQiIGhlaWdodD0iMTUyIiBmaWxsPSIjMWExYTFhIi8+Cjwvc3ZnPgo=';
          if (!isTabSwitch && vesselNum === activeVessel) {
            resultItem.classList.remove('loading');
          }
          console.error('Failed to load image:', imageName);
        };
        
        // Start loading the image
        preloadImg.src = `{{ 'dusk_natural.png' | asset_url }}`.replace('dusk_natural.png', imageName);
      }
    } else if (selection.woodType || selection.ropeType) {
      // Partial selection - show loading state only if not a tab switch AND this is the active vessel
      if (!isTabSwitch && vesselNum === activeVessel) {
        resultItem.classList.add('loading');
      }
      img.src = 'data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMTI0IiBoZWlnaHQ9IjE1MiIgdmlld0JveD0iMCAwIDEyNCAxNTIiIGZpbGw9Im5vbmUiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+CjxyZWN0IHdpZHRoPSIxMjQiIGhlaWdodD0iMTUyIiBmaWxsPSIjMWExYTFhIi8+Cjwvc3ZnPgo=';
      img.alt = (isTabSwitch || vesselNum !== activeVessel) ? 'Partial selection' : 'Loading...';
      
      // Show partial selection text
      const selectedParts = [];
      if (selection.woodType) selectedParts.push(selection.woodType);
      if (selection.ropeType) selectedParts.push(selection.ropeType);
      text.textContent = `${selectedParts.join(' • ')} • ...`;
    } else {
      // No selections but this is the active vessel - show placeholder
      img.src = 'data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMTI0IiBoZWlnaHQ9IjE1MiIgdmlld0JveD0iMCAwIDEyNCAxNTIiIGZpbGw9Im5vbmUiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+CjxyZWN0IHdpZHRoPSIxMjQiIGhlaWdodD0iMTUyIiBmaWxsPSIjMWExYTFhIi8+Cjwvc3ZnPgo=';
      img.alt = 'No selection';
      text.textContent = `Vessel #${vesselNum}`;
      text.style.opacity = '0.5';
      
      // Mark as active vessel (for opacity logic and indicator)
      resultItem.classList.add('active-vessel');
      
      // Add simple editing indicator
      {% comment %} const editingIndicator = document.createElement('div');
      editingIndicator.className = 'editing-indicator';
      editingIndicator.textContent = 'EDITING';
      resultItem.appendChild(editingIndicator); {% endcomment %}
    }
    
    imgWrap.appendChild(img);
    resultItem.appendChild(imgWrap);
    resultItem.appendChild(text);
      
    // Make result item clickable to switch to that vessel
    resultItem.addEventListener('click', function() {
      switchToVessel(vesselNum);
    });
    
    selectionWrap.appendChild(resultItem);
    
    // Apply the correct CSS class based on number of vessels shown
    const vesselCount = selectionWrap.querySelectorAll('.result-item').length;
    if (vesselCount > 0) {
      selectionWrap.classList.add(`result-${vesselCount}`);
    }
  }

  // Function to switch to a specific vessel
  function switchToVessel(vesselNumber) {
    if (vesselNumber >= 1 && vesselNumber <= 3) {
      // Find and click the corresponding vessel tab button
      const tabButton = document.querySelector(`[data-tab="tab${vesselNumber}"]`);
      if (tabButton) {
        tabButton.click();
      }
    }
  }

  // Function to switch to vessel #1 (called when vessel count changes)
  function switchToVesselOne() {
    switchToVessel(1);
  }

  // Function to update vessel tab visibility based on count
  function updateVesselTabVisibility(vesselCount) {
    const vesselCountNum = parseInt(vesselCount);
    currentVesselCount = vesselCountNum; // Update global vessel count
    
    console.log('updateVesselTabVisibility called:', {
      vesselCount,
      vesselCountNum,
      currentActiveVessel: activeVessel,
      currentVesselCount
    });
    
    // Check if current active vessel is beyond the new count
    if (activeVessel > vesselCountNum) {
      console.log('Active vessel beyond count, switching to vessel #1');
      // If active vessel is beyond new count, switch to vessel #1
      activeVessel = 1;
    }
    
    // Update vessel tab buttons visibility
    for (let i = 1; i <= 3; i++) {
      const tabButton = document.querySelector(`.vessel_number_${i}`);
      const tabPanel = document.querySelector(`#tab${i}`);
      
      if (tabButton && tabPanel) {
        if (i <= vesselCountNum) {
          tabButton.style.display = 'flex';
          // Show only the active vessel panel, hide others
          if (i === activeVessel) {
            tabPanel.style.display = 'block';
            tabButton.classList.remove('inactive');
            tabButton.classList.add('active');
          } else {
            tabPanel.style.display = 'none';
            tabButton.classList.remove('active');
            tabButton.classList.add('inactive');
          }
        } else {
          // Hide tabs beyond the vessel count
          tabButton.style.display = 'none';
          tabPanel.style.display = 'none';
          tabButton.classList.remove('active', 'inactive');
        }
      }
    }
    
    // Update selection display to reflect new vessel count
    updateSelectionDisplay(false); // false indicates this is not a tab switch
  }

  // Store the original setProductAmount function if it exists
  if (typeof window.setProductAmount === 'function') {
    window.originalSetProductAmount = window.setProductAmount;
  }

  // Override the global setProductAmount function to switch to vessel #1
  window.setProductAmount = function(amount) {
    console.log('setProductAmount called with:', amount);
    
    // Call the original function if it exists
    if (window.originalSetProductAmount) {
      window.originalSetProductAmount(amount);
    } else {
      console.log('Original setProductAmount not found, handling vessel count change directly');
    }
    
    // Update vessel tab visibility and switch to vessel #1 immediately
    updateVesselTabVisibility(amount);
  };

  // Function to get current vessel selection
  function getCurrentVesselSelection() {
    return vesselSelections[activeVessel];
  }

  // Function to validate vessel selections
  function validateVesselSelections() {
    const errors = [];
    const warnings = [];
    
    for (let vesselNum = 1; vesselNum <= 3; vesselNum++) {
      const selection = vesselSelections[vesselNum];
      
      // Check for partial selections
      if ((selection.woodType && !selection.ropeType) || (!selection.woodType && selection.ropeType)) {
        warnings.push(`Vessel #${vesselNum} has incomplete selection`);
      }
      
      // Check for invalid combinations (if any business rules exist)
      if (selection.woodType && selection.ropeType) {
        // Add any specific validation rules here
        // Example: if (selection.woodType === 'MIDNIGHT' && selection.ropeType === 'NATURAL') {
        //   warnings.push(`Vessel #${vesselNum} has unusual combination`);
        // }
      }
    }
    
    return { errors, warnings };
  }

  // Function to show validation feedback
  function showValidationFeedback(validation) {
    // Remove existing feedback
    const existingFeedback = document.querySelector('.validation-feedback');
    if (existingFeedback) {
      existingFeedback.remove();
    }
    
    if (validation.warnings.length > 0) {
      const feedback = document.createElement('div');
      feedback.className = 'validation-feedback tw-mt-2 tw-p-2 tw-bg-yellow-100 tw-text-yellow-800 tw-rounded tw-text-sm';
      feedback.innerHTML = validation.warnings.map(warning => `⚠️ ${warning}`).join('<br>');
      
      const selectionWrap = document.querySelector('.selection-result-wrap');
      selectionWrap.parentNode.insertBefore(feedback, selectionWrap.nextSibling);
    }
  }

  // Function to set vessel selection programmatically
  function setVesselSelection(vesselNumber, woodType, ropeType) {
    if (vesselNumber >= 1 && vesselNumber <= 3) {
      vesselSelections[vesselNumber].woodType = woodType;
      vesselSelections[vesselNumber].ropeType = ropeType;
      
      // Update the UI for that vessel
      const vesselPanel = document.getElementById(`tab${vesselNumber}`);
      if (vesselPanel) {
        // Update wood type selection
        const woodInput = vesselPanel.querySelector(`input[name="wood_material"][value="${woodType}"]`);
        if (woodInput) {
          woodInput.checked = true;
          vesselPanel.querySelectorAll('.wood-type-label').forEach(label => {
            label.classList.remove('active');
          });
          woodInput.closest('.wood-type-label').classList.add('active');
        }
        
        // Update rope type selection
        const ropeInput = vesselPanel.querySelector(`input[name="rope_material"][value="${ropeType}"]`);
        if (ropeInput) {
          ropeInput.checked = true;
          vesselPanel.querySelectorAll('.rope-type-label').forEach(label => {
            label.classList.remove('active');
          });
          ropeInput.closest('.rope-type-label').classList.add('active');
        }
      }
      
      // Validate and show feedback
      const validation = validateVesselSelections();
      showValidationFeedback(validation);
      
      updateSelectionDisplay(false); // false indicates this is not a tab switch
    }
  }

