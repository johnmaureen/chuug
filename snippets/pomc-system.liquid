          </svg>
        </div>
        <span class="tw-text-[1.2rem] tw-leading-[1.5]">Not happy? We'll refund you. No questions asked.</span>
      </div>
    </div>

<!-- Include Modal CSS -->
{{ 'pomc-system.css' | asset_url | stylesheet_tag }}
{{ 'checkout-products-wrap.css' | asset_url | stylesheet_tag }}

<!-- Include Cart Manager JavaScript (defer for non-blocking) -->
<script src="{{ 'cart-manager.js' | asset_url }}" defer></script>

<!-- Include POMC System JavaScript (high priority for cart functionality) -->
<script>
  // Provide asset URL template for JavaScript
  window.SHOPIFY_ASSET_URL_TEMPLATE = "{{ 'dusk_natural.png' | asset_url }}";
</script>
<script src="{{ 'pomc-system.js' | asset_url }}" fetchpriority="high"></script>

{% comment %} Performance optimization: Using fetchpriority="high" for critical cart functionality
- Ensures script loads early to prevent cart icon redirection
- Critical for mini-ATC modal to work properly
- Prevents cart page redirect when clicking cart icon {% endcomment %}

