<script>
(function() {
  'use strict';



  

  // ========================================
  // CONSTANTS AND INITIAL STATE
  // ========================================
  const STORAGE_KEY = 'chuug_vessel_selections';
  const DEFAULT_VESSEL_COUNT = 3;
  const DEBOUNCE_DELAY = 100;
  const VALIDATION_DELAY = 200;
  
  const DEFAULT_VESSEL_SELECTIONS = {
    1: { woodType: null, ropeType: null },
    2: { woodType: null, ropeType: null },
    3: { woodType: null, ropeType: null }
  };

  // ========================================
  // STATE MANAGEMENT
  // ========================================
  let state = {
    vesselSelections: { ...DEFAULT_VESSEL_SELECTIONS },
    activeVessel: 1,
    currentVesselCount: DEFAULT_VESSEL_COUNT,
    updateTimeout: null,
    validationTimeout: null,
    imageCache: new Map(),
    domCache: new Map(),
    vesselUIState: new Map() // Track UI state per vessel
  };

  // ========================================
  // UTILITY FUNCTIONS
  // ========================================
  function debounce(func, delay) {
    let timeoutId;
    return function(...args) {
      clearTimeout(timeoutId);
      timeoutId = setTimeout(() => func.apply(this, args), delay);
    };
  }

  function getFromCache(key, selector) {
    if (!state.domCache.has(key)) {
      const element = document.querySelector(selector);
      if (element) state.domCache.set(key, element);
    }
    return state.domCache.get(key);
  }

  function getAllFromCache(key, selector) {
    if (!state.domCache.has(key)) {
      const elements = document.querySelectorAll(selector);
      if (elements.length) state.domCache.set(key, elements);
    }
    return state.domCache.get(key) || [];
  }

  function clearDomCache() {
    state.domCache.clear();
  }

  // ========================================
  // STORAGE FUNCTIONS
  // ========================================
  const storage = {
    save() {
      try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(state.vesselSelections));
      } catch (error) {
        // Silent fail for storage issues
      }
    },

    load() {
      try {
        const saved = localStorage.getItem(STORAGE_KEY);
        if (saved) {
          const parsed = JSON.parse(saved);
          state.vesselSelections = { ...DEFAULT_VESSEL_SELECTIONS, ...parsed };
          return true;
        }
      } catch (error) {
        // Silent fail for storage issues
      }
      return false;
    },

    clear() {
      try {
        localStorage.removeItem(STORAGE_KEY);
        state.vesselSelections = { ...DEFAULT_VESSEL_SELECTIONS };
      } catch (error) {
        // Silent fail for storage issues
      }
    }
  };

  // ========================================
  // SELECTION MANAGEMENT
  // ========================================
  function updateVesselSelection(vesselNumber, type, value) {
    state.vesselSelections[vesselNumber][type] = value;
    
    // Maintain UI state for this vessel
    maintainVesselUIState(vesselNumber);
    
    // Clear timeouts and debounce updates
    clearTimeout(state.updateTimeout);
    clearTimeout(state.validationTimeout);
    
    state.updateTimeout = setTimeout(() => {
      storage.save();
      updateSelectionDisplay(false);
    }, DEBOUNCE_DELAY);
    
    state.validationTimeout = setTimeout(() => {
      const validation = validateVesselSelections();
      showValidationFeedback(validation);
    }, VALIDATION_DELAY);
  }

  function maintainVesselUIState(vesselNumber) {
    const vesselPanel = document.getElementById(`tab${vesselNumber}`);
    if (!vesselPanel) return;

    const selection = state.vesselSelections[vesselNumber];
    
    // Store current UI state for this vessel
    const uiState = {
      woodType: selection.woodType,
      ropeType: selection.ropeType,
      woodInputs: [],
      ropeInputs: []
    };

    // Capture wood type input states
    const woodInputs = vesselPanel.querySelectorAll('input[name^="wood_material_"]');
    woodInputs.forEach(input => {
      uiState.woodInputs.push({
        value: input.value,
        checked: input.checked,
        labelActive: input.closest('.wood-type-label').classList.contains('active')
      });
    });

    // Capture rope type input states
    const ropeInputs = vesselPanel.querySelectorAll('input[name^="rope_material_"]');
    ropeInputs.forEach(input => {
      uiState.ropeInputs.push({
        value: input.value,
        checked: input.checked,
        labelActive: input.closest('.rope-type-label').classList.contains('active')
      });
    });

    state.vesselUIState.set(vesselNumber, uiState);
  }

  function restoreVesselUIState(vesselNumber) {
    const uiState = state.vesselUIState.get(vesselNumber);
    if (!uiState) return;

    const vesselPanel = document.getElementById(`tab${vesselNumber}`);
    if (!vesselPanel) return;

    // Restore wood type selections
    if (uiState.woodType) {
      const woodInput = vesselPanel.querySelector(`input[name="wood_material_${vesselNumber}"][value="${uiState.woodType}"]`);
      if (woodInput) {
        woodInput.checked = true;
        vesselPanel.querySelectorAll('.wood-type-label').forEach(label => {
          label.classList.remove('active');
        });
        woodInput.closest('.wood-type-label').classList.add('active');
      }
    }

    // Restore rope type selections
    if (uiState.ropeType) {
      const ropeInput = vesselPanel.querySelector(`input[name="rope_material_${vesselNumber}"][value="${uiState.ropeType}"]`);
      if (ropeInput) {
        ropeInput.checked = true;
        vesselPanel.querySelectorAll('.rope-type-label').forEach(label => {
          label.classList.remove('active');
        });
        ropeInput.closest('.rope-type-label').classList.add('active');
      }
    }
  }

  function clearAllPreselectedOptions() {
    const allInputs = getAllFromCache('allInputs', 'input[name^="wood_material_"], input[name^="rope_material_"]');
    allInputs.forEach(input => {
      input.checked = false;
      const label = input.closest('label');
      if (label) label.classList.remove('active');
    });
  }

  function clearPreselectedOptionsForHiddenVessels(maxVesselCount) {
    // Only clear options for vessels beyond the current count
    for (let i = maxVesselCount + 1; i <= 3; i++) {
      const vesselInputs = document.querySelectorAll(`input[name^="wood_material_${i}"], input[name^="rope_material_${i}"]`);
      vesselInputs.forEach(input => {
        input.checked = false;
        const label = input.closest('label');
        if (label) label.classList.remove('active');
      });
    }
  }

  function restoreValidVesselStates(maxVesselCount) {
    // Restore UI state for vessels that are still visible
    for (let vesselNum = 1; vesselNum <= maxVesselCount; vesselNum++) {
      const selection = state.vesselSelections[vesselNum];
      if (selection && (selection.woodType || selection.ropeType)) {
        const vesselPanel = document.getElementById(`tab${vesselNum}`);
        if (!vesselPanel) continue;

        // Restore wood type selection
        if (selection.woodType) {
          const woodInput = vesselPanel.querySelector(`input[name="wood_material_${vesselNum}"][value="${selection.woodType}"]`);
          if (woodInput) {
            woodInput.checked = true;
            vesselPanel.querySelectorAll('.wood-type-label').forEach(label => {
              label.classList.remove('active');
            });
            woodInput.closest('.wood-type-label').classList.add('active');
          }
        }
        
        // Restore rope type selection
        if (selection.ropeType) {
          const ropeInput = vesselPanel.querySelector(`input[name="rope_material_${vesselNum}"][value="${selection.ropeType}"]`);
          if (ropeInput) {
            ropeInput.checked = true;
            vesselPanel.querySelectorAll('.rope-type-label').forEach(label => {
              label.classList.remove('active');
            });
            ropeInput.closest('.rope-type-label').classList.add('active');
          }
        }

        // Update the UI state for this vessel
        maintainVesselUIState(vesselNum);
      }
    }
  }

  function restoreUIFromSelections() {
    for (let vesselNum = 1; vesselNum <= 3; vesselNum++) {
      const selection = state.vesselSelections[vesselNum];
      const vesselPanel = document.getElementById(`tab${vesselNum}`);
      
      if (!vesselPanel || !selection) continue;

      // Restore wood type selection
      if (selection.woodType) {
        const woodInput = vesselPanel.querySelector(`input[name="wood_material_${vesselNum}"][value="${selection.woodType}"]`);
        if (woodInput) {
          woodInput.checked = true;
          vesselPanel.querySelectorAll('.wood-type-label').forEach(label => {
            label.classList.remove('active');
          });
          woodInput.closest('.wood-type-label').classList.add('active');
        }
      }
      
      // Restore rope type selection
      if (selection.ropeType) {
        const ropeInput = vesselPanel.querySelector(`input[name="rope_material_${vesselNum}"][value="${selection.ropeType}"]`);
        if (ropeInput) {
          ropeInput.checked = true;
          vesselPanel.querySelectorAll('.rope-type-label').forEach(label => {
            label.classList.remove('active');
          });
          ropeInput.closest('.rope-type-label').classList.add('active');
        }
      }

      // Store initial UI state for this vessel
      maintainVesselUIState(vesselNum);
    }
  }

  // ========================================
  // TAB MANAGEMENT
  // ========================================
  function initializeTabs() {
    const tabComponent = getFromCache('tabComponent', '[data-tabs]');
    if (!tabComponent) return;

    const tabs = getAllFromCache('tabs', '[data-tab]');
    const contents = getAllFromCache('contents', '[id^="tab"]');

    // Use event delegation for better performance
    tabComponent.addEventListener('click', function(e) {
      const btn = e.target.closest('[data-tab]');
      if (!btn) return;

      const target = btn.getAttribute('data-tab');
      const vesselNumber = parseInt(target.replace('tab', ''));
      
      // Update active tab styles
      tabs.forEach(b => {
        b.classList.remove('active');
        b.classList.add('inactive');
      });
      btn.classList.remove('inactive');
      btn.classList.add('active');

      // Toggle content
      contents.forEach(c => {
        c.classList.remove('active');
        c.style.display = 'none';
        if (c.id === target) {
          c.classList.add('active');
          c.style.display = 'block';
        }
      });

      // Update active vessel
      state.activeVessel = vesselNumber;
      
      // Restore UI state for the newly active vessel
      restoreVesselUIState(vesselNumber);
      
      updateSelectionDisplay(true);
    });
  }

  // ========================================
  // SELECTION INPUT HANDLERS
  // ========================================
  function initializeSelectionInputs() {
    const customizeVessel = getFromCache('customizeVessel', '.customize-your-vessel');
    if (!customizeVessel) return;

    // Use event delegation for better performance
    customizeVessel.addEventListener('change', function(e) {
      const input = e.target;
      
      if (input.name && input.name.startsWith('wood_material_')) {
        handleWoodSelection(input);
      } else if (input.name && input.name.startsWith('rope_material_')) {
        handleRopeSelection(input);
      }
    });
  }

  function handleWoodSelection(input) {
    const vesselPanel = input.closest('.vessel-tab-panel');
    if (!vesselPanel) return;

    const vesselNumber = parseInt(vesselPanel.id.replace('tab', ''));
    const woodType = input.value;
    
    // Update active state for wood type labels
    vesselPanel.querySelectorAll('.wood-type-label').forEach(label => {
      label.classList.remove('active');
    });
    input.closest('.wood-type-label').classList.add('active');
    
    updateVesselSelection(vesselNumber, 'woodType', woodType);
  }

  function handleRopeSelection(input) {
    const vesselPanel = input.closest('.vessel-tab-panel');
    if (!vesselPanel) return;

    const vesselNumber = parseInt(vesselPanel.id.replace('tab', ''));
    const ropeType = input.value;
    
    // Update active state for rope type labels
    vesselPanel.querySelectorAll('.rope-type-label').forEach(label => {
      label.classList.remove('active');
    });
    input.closest('.rope-type-label').classList.add('active');
    
    updateVesselSelection(vesselNumber, 'ropeType', ropeType);
  }

  // ========================================
  // DISPLAY FUNCTIONS
  // ========================================
  function updateSelectionDisplay(isTabSwitch = false) {
    const selectionWrap = getFromCache('selectionWrap', '.selection-result-wrap');
    const noSelectionText = getFromCache('noSelectionText', '.no-selection-text');
    
    if (!selectionWrap || !noSelectionText) return;

    // Clear CSS classes
    selectionWrap.classList.remove('result-1', 'result-2', 'result-3');
    
    // Check if we have any selections
    let hasAnySelections = false;
    for (let vesselNum = 1; vesselNum <= 3; vesselNum++) {
      const selection = state.vesselSelections[vesselNum];
      if (selection.woodType || selection.ropeType) {
        hasAnySelections = true;
        break;
      }
    }
    
    // Show/hide no selection text
    if (hasAnySelections || state.vesselSelections[state.activeVessel].woodType || state.vesselSelections[state.activeVessel].ropeType) {
      noSelectionText.style.display = 'none';
    } else {
      noSelectionText.style.display = 'block';
      return;
    }

    // Update result items for current vessel count
    for (let vesselNum = 1; vesselNum <= state.currentVesselCount; vesselNum++) {
      const selection = state.vesselSelections[vesselNum];
      
      let resultItem = selectionWrap.querySelector(`.result-item[data-vessel="${vesselNum}"]`);
      
      if (!resultItem) {
        resultItem = createResultItem(vesselNum);
        insertResultItemAtPosition(selectionWrap, resultItem, vesselNum);
      }
      
      updateResultItemContent(resultItem, selection, vesselNum, isTabSwitch);
    }
    
    // Remove result items beyond current vessel count
    const allResultItems = selectionWrap.querySelectorAll('.result-item');
    allResultItems.forEach(item => {
      const itemVesselNum = parseInt(item.getAttribute('data-vessel'));
      if (itemVesselNum > state.currentVesselCount) {
        item.remove();
      }
    });
    
    // Apply CSS class based on number of vessels shown
    const vesselCount = selectionWrap.querySelectorAll('.result-item').length;
    if (vesselCount > 0) {
      selectionWrap.classList.add(`result-${vesselCount}`);
    }
  }

  function createResultItem(vesselNum) {
    const resultItem = document.createElement('div');
    resultItem.className = 'result-item';
    resultItem.setAttribute('data-vessel', vesselNum);
    
    // Add click handler to switch vessels
    resultItem.addEventListener('click', () => switchToVessel(vesselNum));
    
    return resultItem;
  }

  function insertResultItemAtPosition(container, newItem, vesselNum) {
    const existingItems = container.querySelectorAll('.result-item');
    let insertBefore = null;
    
    for (let i = 0; i < existingItems.length; i++) {
      const existingVesselNum = parseInt(existingItems[i].getAttribute('data-vessel'));
      if (vesselNum < existingVesselNum) {
        insertBefore = existingItems[i];
        break;
      }
    }
    
    if (insertBefore) {
      container.insertBefore(newItem, insertBefore);
    } else {
      container.appendChild(newItem);
    }
  }

  function updateResultItemContent(resultItem, selection, vesselNum, isTabSwitch) {
    // Get or create existing elements
    let imgWrap = resultItem.querySelector('.img-wrap');
    let img = resultItem.querySelector('.img-wrap img');
    let text = resultItem.querySelector('p');
    
    if (!imgWrap) {
      imgWrap = document.createElement('div');
      imgWrap.className = 'img-wrap';
      resultItem.appendChild(imgWrap);
    }
    
    if (!img) {
      img = document.createElement('img');
      imgWrap.appendChild(img);
    }
    
    if (!text) {
      text = document.createElement('p');
      resultItem.appendChild(text);
    }
    
    // Determine content
    let newImageSrc = '';
    let newAltText = '';
    let shouldShowLoading = false;
    
    if (selection.woodType && selection.ropeType) {
      // Complete selection
      const imageName = `${selection.woodType.toLowerCase()}_${selection.ropeType.toLowerCase()}.png`;
      newAltText = `${selection.woodType} ${selection.ropeType} Vessel #${vesselNum}`;
      
      // Check cache first
      if (state.imageCache.has(imageName)) {
        newImageSrc = state.imageCache.get(imageName);
      } else {
        newImageSrc = `{{ 'dusk_natural.png' | asset_url }}`.replace('dusk_natural.png', imageName);
        shouldShowLoading = !isTabSwitch && vesselNum === state.activeVessel;
      }
    } else {
      // Partial or no selection
      newImageSrc = 'data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMTI0IiBoZWlnaHQ9IjE1MiIgdmlld0JveD0iMCAwIDEyNCAxNTIiIGZpbGw9Im5vbmUiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+CjxyZWN0IHdpZHRoPSIxMjQiIGhlaWdodD0iMTUyIiBmaWxsPSIjMWExYTFhIi8+Cjwvc3ZnPgo=';
      newAltText = (isTabSwitch || vesselNum !== state.activeVessel) ? 'Partial selection' : 'Loading...';
      shouldShowLoading = !isTabSwitch && vesselNum === state.activeVessel;
    }
    
    // Update image efficiently
    if (img.src !== newImageSrc) {
      if (selection.woodType && selection.ropeType && !state.imageCache.has(`${selection.woodType.toLowerCase()}_${selection.ropeType.toLowerCase()}.png`)) {
        loadImageOptimized(img, newImageSrc, selection, shouldShowLoading, resultItem);
      } else {
        img.src = newImageSrc;
        img.style.display = 'block';
      }
    }
    
    img.alt = newAltText;
    
    // Update text content
    updateTextContent(text, selection, vesselNum);
    
    // Update loading and active states
    if (shouldShowLoading) {
      resultItem.classList.add('loading');
    } else {
      resultItem.classList.remove('loading');
    }
    
    if (!selection.woodType && !selection.ropeType) {
      resultItem.classList.add('active-vessel');
    } else {
      resultItem.classList.remove('active-vessel');
    }
  }

  function loadImageOptimized(img, src, selection, shouldShowLoading, resultItem) {
    const imageName = `${selection.woodType.toLowerCase()}_${selection.ropeType.toLowerCase()}.png`;
    
    img.style.display = 'none';
    const preloadImg = new Image();
    
    preloadImg.onload = function() {
      state.imageCache.set(imageName, preloadImg.src);
      img.src = preloadImg.src;
      img.style.display = 'block';
      if (shouldShowLoading) resultItem.classList.remove('loading');
    };
    
    preloadImg.onerror = function() {
      img.style.display = 'block';
      img.src = 'data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMTI0IiBoZWlnaHQ9IjE1MiIgdmlld0JveD0iMCAwIDEyNCAxNTIiIGZpbGw9Im5vbmUiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+CjxyZWN0IHdpZHRoPSIxMjQiIGhlaWdodD0iMTUyIiBmaWxsPSIjMWExYTFhIi8+Cjwvc3ZnPgo=';
      if (shouldShowLoading) resultItem.classList.remove('loading');
    };
    
    preloadImg.src = src;
  }

  function updateTextContent(text, selection, vesselNum) {
    if (selection.woodType || selection.ropeType) {
      if (selection.woodType && selection.ropeType) {
        text.textContent = `${selection.woodType} • ${selection.ropeType}`;
      } else {
        const selectedParts = [];
        if (selection.woodType) selectedParts.push(selection.woodType);
        if (selection.ropeType) selectedParts.push(selection.ropeType);
        text.textContent = `${selectedParts.join(' • ')} • ...`;
      }
      text.style.opacity = '';
    } else {
      text.textContent = `Vessel #${vesselNum}`;
      text.style.opacity = '0.5';
    }
  }

  function switchToVessel(vesselNumber) {
    if (vesselNumber >= 1 && vesselNumber <= 3) {
      const tabButton = document.querySelector(`[data-tab="tab${vesselNumber}"]`);
      if (tabButton) tabButton.click();
    }
  }

  // ========================================
  // VESSEL COUNT MANAGEMENT
  // ========================================
  function updateVesselTabVisibility(vesselCount) {
    const vesselCountNum = parseInt(vesselCount);
    state.currentVesselCount = vesselCountNum;
    
    // Check if current active vessel is beyond the new count
    if (state.activeVessel > vesselCountNum) {
      state.activeVessel = 1;
      // Immediately switch to vessel 1 to ensure proper state restoration
      switchToVessel(1);
    }
    
    // Update vessel tab buttons visibility
    for (let i = 1; i <= 3; i++) {
      const tabButton = document.querySelector(`.vessel_number_${i}`);
      const tabPanel = document.querySelector(`#tab${i}`);
      
      if (tabButton && tabPanel) {
        if (i <= vesselCountNum) {
          tabButton.style.display = 'flex';
          if (i === state.activeVessel) {
            tabPanel.style.display = 'block';
            tabButton.classList.remove('inactive');
            tabButton.classList.add('active');
          } else {
            tabPanel.style.display = 'none';
            tabButton.classList.remove('active');
            tabButton.classList.add('inactive');
          }
        } else {
          tabButton.style.display = 'none';
          tabPanel.style.display = 'none';
          tabButton.classList.remove('active', 'inactive');
        }
      }
    }
    
    // Clear selections for vessels beyond the new vessel count
    for (let i = vesselCountNum + 1; i <= 3; i++) {
      if (state.vesselSelections[i] && (state.vesselSelections[i].woodType || state.vesselSelections[i].ropeType)) {
        state.vesselSelections[i] = { woodType: null, ropeType: null };
        
        // Clear UI state for this vessel
        state.vesselUIState.delete(i);
        
        // Clear radio button selections for this vessel
        const vesselInputs = document.querySelectorAll(`input[name^="wood_material_${i}"], input[name^="rope_material_${i}"]`);
        vesselInputs.forEach(input => {
          input.checked = false;
          input.closest('label').classList.remove('active');
        });
      }
    }
    
    storage.save();
    
    // Clear pre-selected options only for vessels beyond the current count, then restore valid vessels
    requestAnimationFrame(() => {
      clearPreselectedOptionsForHiddenVessels(vesselCountNum);
      restoreValidVesselStates(vesselCountNum);
      
      // Ensure the current active vessel's state is properly restored
      if (state.activeVessel <= vesselCountNum) {
        restoreVesselUIState(state.activeVessel);
      }
      
      updateSelectionDisplay(false);
    });
  }

  // ========================================
  // VALIDATION
  // ========================================
  function validateVesselSelections() {
    const warnings = [];
    
    for (let vesselNum = 1; vesselNum <= 3; vesselNum++) {
      const selection = state.vesselSelections[vesselNum];
      
      if ((selection.woodType && !selection.ropeType) || (!selection.woodType && selection.ropeType)) {
        warnings.push(`Vessel #${vesselNum} has incomplete selection`);
      }
    }
    
    return { errors: [], warnings };
  }

  function showValidationFeedback(validation) {
    const existingFeedback = document.querySelector('.validation-feedback');
    if (existingFeedback) existingFeedback.remove();
    
    if (validation.warnings.length > 0) {
      const feedback = document.createElement('div');
      feedback.className = 'validation-feedback tw-mt-2 tw-p-2 tw-bg-yellow-100 tw-text-yellow-800 tw-rounded tw-text-sm';
      feedback.innerHTML = validation.warnings.map(warning => `⚠️ ${warning}`).join('<br>');
      
      const selectionWrap = getFromCache('selectionWrap', '.selection-result-wrap');
      if (selectionWrap && selectionWrap.parentNode) {
        selectionWrap.parentNode.insertBefore(feedback, selectionWrap.nextSibling);
      }
    }
  }

  // ========================================
  // PRODUCT AMOUNT OVERRIDE
  // ========================================
  function setupSetProductAmountOverride() {
    if (typeof window.setProductAmount === 'function') {
      window.originalSetProductAmount = window.setProductAmount;
    } else {
      return false;
    }

    window.setProductAmount = function(amount) {
      if (window.originalSetProductAmount) {
        window.originalSetProductAmount(amount);
      }
      updateVesselTabVisibility(amount);
    };
    
    return true;
  }

  // ========================================
  // INITIALIZATION
  // ========================================
  function initialize() {
    // Initialize state
    state.currentVesselCount = DEFAULT_VESSEL_COUNT;
    
    // Clear any pre-selected options
    clearAllPreselectedOptions();
    
    // Initialize components
    initializeTabs();
    initializeSelectionInputs();
    initializeModalEventListeners();
    
    // Load saved selections
    const hasLoadedSelections = storage.load();
    if (hasLoadedSelections) {
      restoreUIFromSelections();
    }
    updateSelectionDisplay(false);
    
    // Setup cleanup on page unload
    const cleanup = debounce(storage.clear, 100);
    window.addEventListener('beforeunload', cleanup);
    document.addEventListener('visibilitychange', function() {
      if (document.hidden) cleanup();
    });
  }

  // ========================================
  // ENTRY POINT
  // ========================================
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initialize);
  } else {
    initialize();
  }

  // Setup product amount override with fallback attempts
  if (!setupSetProductAmountOverride()) {
    const retrySetup = debounce(() => {
      if (!setupSetProductAmountOverride()) {
        setTimeout(() => setupSetProductAmountOverride(), 1000);
      }
    }, 100);
    retrySetup();
  }

  // ========================================
  // MINI ATC MODAL FUNCTIONS
  // ========================================
  function handlePersonalizeVessel() {
    // Get current vessel selections to populate modal
    const currentSelections = state.vesselSelections[state.activeVessel];
    const vesselCount = state.currentVesselCount;
    
    // Calculate pricing based on current selections
    updateModalPricing(vesselCount, currentSelections);
    
    // Update product image based on current selection
    updateModalProductImage(currentSelections);
    
    // Show the modal
    showMiniATCModal();
  }

  function showMiniATCModal() {
    const modal = document.getElementById('mini-atc-modal');
    if (modal) {
      // Reset modal to personalise view
      resetModalToPersonaliseView(modal);
      
      // Force reflow to ensure initial state is applied
      modal.offsetHeight;
      modal.classList.add('mini-atc-modal--active');
      document.body.style.overflow = 'hidden'; // Prevent background scrolling
      
      // Initialize swiper after modal is shown (with a small delay to ensure DOM is ready)
      setTimeout(() => {
        if (!window.miniATCProductSwiper) {
          window.miniATCProductSwiper = initProductSwiper();
        }
      }, 100);
    }
  }

  function resetModalToPersonaliseView(modal) {
    const header = modal.querySelector('.mini-atc-modal__title');
    const personaliseWrap = modal.querySelector('.mini-atc-modal__personalise-wrap');
    const checkoutWrap = modal.querySelector('.mini-atc-modal__checkout-wrap');
    
    if (!personaliseWrap || !checkoutWrap || !header) return;
    
    // Reset header text
    header.textContent = 'Personalise Your CHUUG';
    
    // Reset content wrappers
    personaliseWrap.classList.add('mini-atc-modal__content-wrap--active');
    checkoutWrap.classList.remove('mini-atc-modal__content-wrap--active');
    
    // Reset styles
    personaliseWrap.style.opacity = '1';
    personaliseWrap.style.transform = 'translateX(0)';
    checkoutWrap.style.opacity = '0';
    checkoutWrap.style.transform = 'translateX(20px)';
  }

  function closeMiniATCModal() {
    const modal = document.getElementById('mini-atc-modal');
    if (modal) {
      modal.classList.remove('mini-atc-modal--active');
      document.body.style.overflow = ''; // Restore scrolling
    }
  }

  // Add overlay click handler
  function initializeModalEventListeners() {
    const modal = document.getElementById('mini-atc-modal');
    const overlay = modal?.querySelector('.mini-atc-modal__overlay');
    
    if (overlay) {
      overlay.addEventListener('click', closeMiniATCModal);
    }
  }

  function updateModalPricing(vesselCount, selections) {
    // This would integrate with your existing pricing logic
    // For now, using placeholder values
    const currentPriceEl = document.getElementById('mini-atc-current-price');
    const originalPriceEl = document.getElementById('mini-atc-original-price');
    
    if (currentPriceEl && originalPriceEl) {
      // You can integrate this with your existing price calculation logic
      currentPriceEl.textContent = '$78.00';
      originalPriceEl.textContent = '$190.00';
    }
  }

  function updateModalProductImage(selections) {
    const swiper = window.miniATCProductSwiper;
    if (!swiper || !swiper.slides) return;
    
    if (selections.woodType && selections.ropeType) {
      // Update the first slide with the selected combination
      const imageName = `${selections.woodType.toLowerCase()}_${selections.ropeType.toLowerCase()}.png`;
      const firstSlideImg = swiper.slides[0]?.querySelector('img');
      if (firstSlideImg) {
        firstSlideImg.src = `{{ 'dusk_natural.png' | asset_url }}`.replace('dusk_natural.png', imageName);
        firstSlideImg.alt = `CHUUG Vessel - ${selections.woodType} ${selections.ropeType}`;
      }
      
      // Slide to the first image to show the selection
      swiper.slideTo(0);
    } else {
      // Show default image on first slide
      const firstSlideImg = swiper.slides[0]?.querySelector('img');
      if (firstSlideImg) {
        firstSlideImg.src = `{{ 'vessel-sample.png' | asset_url }}`;
        firstSlideImg.alt = 'CHUUG Vessel';
      }
    }
  }

  function addToCartFromModal() {
    // Switch to checkout view instead of closing modal
    switchToCheckoutView();
    
    // You can add your cart logic here
    console.log('Switching to checkout view...');
  }

  function switchToCheckoutView() {
    const modal = document.getElementById('mini-atc-modal');
    const header = modal.querySelector('.mini-atc-modal__title');
    const personaliseWrap = modal.querySelector('.mini-atc-modal__personalise-wrap');
    const checkoutWrap = modal.querySelector('.mini-atc-modal__checkout-wrap');
    
    if (!personaliseWrap || !checkoutWrap || !header) return;
    
    // Update header text
    header.textContent = 'Proceed to Checkout';
    
    // Start crossfade animation
    personaliseWrap.style.opacity = '0';
    personaliseWrap.style.transform = 'translateX(-20px)';
    
    setTimeout(() => {
      // Hide personalise content and show checkout content
      personaliseWrap.classList.remove('mini-atc-modal__content-wrap--active');
      checkoutWrap.classList.add('mini-atc-modal__content-wrap--active');
      
      // Reset and animate checkout content
      checkoutWrap.style.opacity = '0';
      checkoutWrap.style.transform = 'translateX(20px)';
      
      // Force reflow
      checkoutWrap.offsetHeight;
      
      // Animate in
      checkoutWrap.style.opacity = '1';
      checkoutWrap.style.transform = 'translateX(0)';
      
      // Populate checkout content
      populateCheckoutSummary();
    }, 300);
  }

  function goBackToPersonalise() {
    const modal = document.getElementById('mini-atc-modal');
    const header = modal.querySelector('.mini-atc-modal__title');
    const personaliseWrap = modal.querySelector('.mini-atc-modal__personalise-wrap');
    const checkoutWrap = modal.querySelector('.mini-atc-modal__checkout-wrap');
    
    if (!personaliseWrap || !checkoutWrap || !header) return;
    
    // Update header text
    header.textContent = 'Personalise Your CHUUG';
    
    // Start crossfade animation
    checkoutWrap.style.opacity = '0';
    checkoutWrap.style.transform = 'translateX(20px)';
    
    setTimeout(() => {
      // Hide checkout content and show personalise content
      checkoutWrap.classList.remove('mini-atc-modal__content-wrap--active');
      personaliseWrap.classList.add('mini-atc-modal__content-wrap--active');
      
      // Reset and animate personalise content
      personaliseWrap.style.opacity = '0';
      personaliseWrap.style.transform = 'translateX(-20px)';
      
      // Force reflow
      personaliseWrap.offsetHeight;
      
      // Animate in
      personaliseWrap.style.opacity = '1';
      personaliseWrap.style.transform = 'translateX(0)';
    }, 300);
  }

  function populateCheckoutSummary() {
    // Get current selections to populate checkout summary
    const currentSelections = state.vesselSelections;
    const vesselCount = state.currentVesselCount;
    
    // This would be implemented to show the actual selections
    // For now, just update the summary with current data
    console.log('Populating checkout summary with:', currentSelections, vesselCount);
  }

  function proceedToFullCheckout() {
    // This would proceed to the full Shopify checkout
    // For now, just close the modal and redirect
    closeMiniATCModal();
    
    // You can add your checkout logic here
    console.log('Proceeding to full checkout...');
  }

  // Make functions globally available
  window.handlePersonalizeVessel = handlePersonalizeVessel;
  window.closeMiniATCModal = closeMiniATCModal;
  window.addToCartFromModal = addToCartFromModal;
  window.goBackToPersonalise = goBackToPersonalise;
  window.proceedToFullCheckout = proceedToFullCheckout;

  // ========================================
  // PUBLIC API
  // ========================================
  window.pomcSystem = {
    getCurrentVesselSelection: () => state.vesselSelections[state.activeVessel],
    getAllVesselSelections: () => ({ ...state.vesselSelections }),
    getVesselSelection: (vesselNumber) => state.vesselSelections[vesselNumber] || null,
    setVesselSelection: function(vesselNumber, woodType, ropeType) {
      if (vesselNumber >= 1 && vesselNumber <= 3) {
        state.vesselSelections[vesselNumber].woodType = woodType;
        state.vesselSelections[vesselNumber].ropeType = ropeType;
        
        const vesselPanel = document.getElementById(`tab${vesselNumber}`);
        if (vesselPanel) {
          // Update wood type selection
          const woodInput = vesselPanel.querySelector(`input[name="wood_material_${vesselNumber}"][value="${woodType}"]`);
          if (woodInput) {
            woodInput.checked = true;
            vesselPanel.querySelectorAll('.wood-type-label').forEach(label => {
              label.classList.remove('active');
            });
            woodInput.closest('.wood-type-label').classList.add('active');
          }
          
          // Update rope type selection
          const ropeInput = vesselPanel.querySelector(`input[name="rope_material_${vesselNumber}"][value="${ropeType}"]`);
          if (ropeInput) {
            ropeInput.checked = true;
            vesselPanel.querySelectorAll('.rope-type-label').forEach(label => {
              label.classList.remove('active');
            });
            ropeInput.closest('.rope-type-label').classList.add('active');
          }
        }
        
        // Maintain UI state for this vessel
        maintainVesselUIState(vesselNumber);
        
        const validation = validateVesselSelections();
        showValidationFeedback(validation);
        updateSelectionDisplay(false);
      }
    },
    clearVesselSelection: function(vesselNumber) {
      if (vesselNumber >= 1 && vesselNumber <= 3) {
        state.vesselSelections[vesselNumber] = { woodType: null, ropeType: null };
        state.vesselUIState.delete(vesselNumber);
        
        const vesselPanel = document.getElementById(`tab${vesselNumber}`);
        if (vesselPanel) {
          // Clear all selections for this vessel
          const vesselInputs = vesselPanel.querySelectorAll('input[name^="wood_material_"], input[name^="rope_material_"]');
          vesselInputs.forEach(input => {
            input.checked = false;
            input.closest('label').classList.remove('active');
          });
        }
        
        storage.save();
        updateSelectionDisplay(false);
      }
    },
    clearSelections: function() {
      storage.clear();
      state.vesselUIState.clear();
      clearAllPreselectedOptions();
      updateSelectionDisplay(false);
    },
    switchToVessel: switchToVessel,
    maintainVesselState: maintainVesselUIState,
    restoreVesselState: restoreVesselUIState
  };

})();

// Vessel personalization toggle functionality
document.addEventListener('DOMContentLoaded', function() {
  // Initialize vessel toggle functionality
  function initVesselToggle() {
    const vessel1Toggle = document.getElementById('vessel-1-toggle');
    const vessel2Toggle = document.getElementById('vessel-2-toggle');
    const vessel1Input = document.getElementById('vessel-1-name');
    const vessel2Input = document.getElementById('vessel-2-name');

    // Toggle functionality for Vessel #1
    if (vessel1Toggle && vessel1Input) {
      // Initial state - input is disabled if toggle is unchecked
      vessel1Input.disabled = !vessel1Toggle.checked;
      
      vessel1Toggle.addEventListener('change', function() {
        vessel1Input.disabled = !this.checked;
        if (!this.checked) {
          vessel1Input.value = ''; // Clear the input when disabled
        }
      });
    }

    // Toggle functionality for Vessel #2
    if (vessel2Toggle && vessel2Input) {
      // Initial state - input is disabled if toggle is unchecked
      vessel2Input.disabled = !vessel2Toggle.checked;
      
      vessel2Toggle.addEventListener('change', function() {
        vessel2Input.disabled = !this.checked;
        if (!this.checked) {
          vessel2Input.value = ''; // Clear the input when disabled
        }
      });
    }

    // Add input validation for 3-character limit
    [vessel1Input, vessel2Input].forEach(input => {
      if (input) {
        input.addEventListener('input', function() {
          // Ensure uppercase and limit to 3 characters
          this.value = this.value.toUpperCase().slice(0, 3);
        });
      }
    });
  }

  // Initialize personalization toggles functionality
  function initPersonalizationToggles() {
    // Initialize all personalization section toggles
    const personalizationSections = document.querySelectorAll('.mini-atc-modal__personalization');
    
    personalizationSections.forEach(section => {
      const toggle = section.querySelector('input[type="checkbox"]');
      const completeOptions = section.querySelector('.mini-atc-modal__complete-options');
      
      if (!toggle || !completeOptions) return;
      
      // Set initial state based on toggle
      if (toggle.checked) {
        completeOptions.classList.remove('mini-atc-modal__complete-options--hidden');
      } else {
        completeOptions.classList.add('mini-atc-modal__complete-options--hidden');
      }
      
      // Add event listener for toggle
      toggle.addEventListener('change', function() {
        if (this.checked) {
          // Show the complete options with fade in
          completeOptions.classList.remove('mini-atc-modal__complete-options--hidden');
          
          // Update pricing when toggle is turned on
          if (toggle.id === 'mix-match-toggle') {
            updateMixMatchPricing();
          }
        } else {
          // Hide the complete options with fade out
          completeOptions.classList.add('mini-atc-modal__complete-options--hidden');
          
          // Handle specific section cleanup after animation
          setTimeout(() => {
            handleSectionToggleOff(section, toggle.id);
          }, 300); // Match the CSS transition duration
        }
      });
    });
  }
  
  // Handle section-specific cleanup when toggle is turned off
  function handleSectionToggleOff(section, toggleId) {
    if (toggleId === 'engraving-toggle') {
      // Handle vessel names section cleanup
      const vessel1Toggle = document.getElementById('vessel-1-toggle');
      const vessel2Toggle = document.getElementById('vessel-2-toggle');
      const vessel1Input = document.getElementById('vessel-1-name');
      const vessel2Input = document.getElementById('vessel-2-name');
      
      // Clear all input fields
      if (vessel1Input) vessel1Input.value = '';
      if (vessel2Input) vessel2Input.value = '';
      
      // Reset individual toggles to checked state (default)
      if (vessel1Toggle) vessel1Toggle.checked = true;
      if (vessel2Toggle) vessel2Toggle.checked = true;
      
      // Update input disabled states based on individual toggles
      if (vessel1Input) vessel1Input.disabled = !vessel1Toggle.checked;
      if (vessel2Input) vessel2Input.disabled = !vessel2Toggle.checked;
    } else if (toggleId === 'mix-match-toggle') {
      // Handle mix & match section cleanup
      const counters = section.querySelectorAll('.mini-atc-modal__counter-value');
      counters.forEach(counter => {
        counter.textContent = '1'; // Reset to default value
        // Update pricing for this counter
        const counterContainer = counter.closest('.mini-atc-modal__counter');
        if (counterContainer) {
          updateVariantPrice(counterContainer, 1);
        }
      });
      // Update overall mix & match pricing
      updateMixMatchPricing();
    }
  }

  // Initialize when DOM is ready
  initVesselToggle();
  
  // Initialize personalization toggles functionality
  initPersonalizationToggles();
  
  // Initialize mix & match counter functionality
  initMixMatchCounters();
  
  // Initialize variant prices on page load
  initializeVariantPrices();
});

// Initialize variant prices based on initial counter values
function initializeVariantPrices() {
  const counters = document.querySelectorAll('.mini-atc-modal__mix-match-variants .mini-atc-modal__counter');
  
  counters.forEach(counter => {
    const valueEl = counter.querySelector('.mini-atc-modal__counter-value');
    const initialValue = parseInt(valueEl.textContent) || 1;
    updateVariantPrice(counter, initialValue);
  });
}

// Mix & Match Counter Functionality
function initMixMatchCounters() {
  const mixMatchContainer = document.querySelector('.mini-atc-modal__mix-match-variants');
  
  if (!mixMatchContainer) return;
  
  // Use event delegation for better performance
  mixMatchContainer.addEventListener('click', function(e) {
    const btn = e.target.closest('.mini-atc-modal__counter-btn');
    if (!btn) return;
    
    e.preventDefault();
    
    const counter = btn.closest('.mini-atc-modal__counter');
    const valueEl = counter.querySelector('.mini-atc-modal__counter-value');
    const isIncrement = btn.classList.contains('mini-atc-modal__counter-increment');
    const isDecrement = btn.classList.contains('mini-atc-modal__counter-decrement');
    
    let currentValue = parseInt(valueEl.textContent) || 0;
    
    if (isIncrement) {
      currentValue = Math.min(currentValue + 1, 99); // Max 99
    } else if (isDecrement) {
      currentValue = Math.max(currentValue - 1, 0); // Min 0
    }
    
    valueEl.textContent = currentValue;
    
    // Update the individual variant price based on counter value
    updateVariantPrice(counter, currentValue);
    
    // Add visual feedback
    valueEl.style.transform = 'scale(1.1)';
    setTimeout(() => {
      valueEl.style.transform = 'scale(1)';
    }, 150);
    
    // Trigger any pricing updates or other logic here
    updateMixMatchPricing();
  });
}

// Update individual variant price based on counter value
function updateVariantPrice(counter, quantity) {
  const variantRow = counter.closest('.mini-atc-modal__variant-row');
  const priceElement = variantRow.querySelector('.mini-atc-modal__variant-price');
  const basePrice = 12.99; // Base price per item
  
  if (priceElement) {
    const totalPrice = quantity * basePrice;
    if (quantity === 0) {
      priceElement.textContent = '£0.00';
    } else if (quantity === 1) {
      priceElement.textContent = '£12.99';
    } else {
      priceElement.textContent = `£${totalPrice.toFixed(2)}`;
    }
  }
}

// Update pricing based on mix & match selections
function updateMixMatchPricing() {
  const mixMatchToggle = document.getElementById('mix-match-toggle');
  const counters = document.querySelectorAll('.mini-atc-modal__mix-match-variants .mini-atc-modal__counter-value');
  let totalItems = 0;
  let totalPrice = 0;
  const itemPrice = 12.99; // Base price per item
  
  // Only calculate variant prices if mix-match toggle is enabled
  if (mixMatchToggle && mixMatchToggle.checked) {
    counters.forEach(counter => {
      const quantity = parseInt(counter.textContent) || 0;
      totalItems += quantity;
      totalPrice += quantity * itemPrice;
    });
  }
  
  // Update modal pricing if needed
  const currentPriceEl = document.getElementById('mini-atc-current-price');
  const originalPriceEl = document.getElementById('mini-atc-original-price');
  
  if (currentPriceEl && originalPriceEl) {
    // This would integrate with your existing pricing logic
    // For now, just adding the mix & match items to base price
    const basePrice = 78.00; // Base CHUUG price
    const newTotal = basePrice + totalPrice;
    currentPriceEl.textContent = `£${newTotal.toFixed(2)}`;
  }
  
  console.log(`Mix & Match: ${totalItems} items, Total: £${totalPrice.toFixed(2)}`);
}

