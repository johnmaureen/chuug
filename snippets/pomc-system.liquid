<script>
  // Default vessel selections
  const defaultVesselSelections = {
    1: { woodType: null, ropeType: null }, // No pre-selections
    2: { woodType: null, ropeType: null },
    3: { woodType: null, ropeType: null }
  };

  // Global state to track vessel selections
  let vesselSelections = { ...defaultVesselSelections };
  
  // Debug: Watch for changes to vesselSelections
  console.log('🚀 Initial vesselSelections:', vesselSelections);
  let activeVessel = 1; // Default active vessel

  // Function to clear all pre-selected options
  function clearAllPreselectedOptions() {
    console.log('🧹 Clearing all pre-selected wood and rope options...');
    
    // Clear all wood type selections
    const allWoodInputs = document.querySelectorAll('input[name^="wood_material_"]');
    allWoodInputs.forEach(input => {
      input.checked = false;
      const label = input.closest('label');
      if (label) {
        label.classList.remove('active');
      }
    });
    
    // Clear all rope type selections
    const allRopeInputs = document.querySelectorAll('input[name^="rope_material_"]');
    allRopeInputs.forEach(input => {
      input.checked = false;
      const label = input.closest('label');
      if (label) {
        label.classList.remove('active');
      }
    });
    
    console.log(`✅ Cleared ${allWoodInputs.length} wood inputs and ${allRopeInputs.length} rope inputs`);
  }
  let updateTimeout; // For debouncing updates
  let validationTimeout; // For debouncing validation

  // localStorage key for vessel selections
  const STORAGE_KEY = 'chuug_vessel_selections';
  let currentVesselCount = 3; // Track current vessel count

  // Function to save vessel selections to localStorage
  function saveVesselSelections() {
    try {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(vesselSelections));
    } catch (error) {
      console.warn('Could not save vessel selections to localStorage:', error);
    }
  }

  // Function to load vessel selections from localStorage
  function loadVesselSelections() {
    try {
      const saved = localStorage.getItem(STORAGE_KEY);
      if (saved) {
        const parsed = JSON.parse(saved);
        console.log('📥 Loaded from localStorage:', parsed);
        // Merge with defaults to ensure all vessels exist
        vesselSelections = { ...defaultVesselSelections, ...parsed };
        console.log('🔄 After merge with defaults:', vesselSelections);
        return true;
      }
    } catch (error) {
      console.warn('Could not load vessel selections from localStorage:', error);
    }
    return false;
  }

  // Function to clear vessel selections from localStorage
  function clearVesselSelections() {
    try {
      localStorage.removeItem(STORAGE_KEY);
      vesselSelections = { ...defaultVesselSelections };
      
      // Remove all result items when clearing selections
      const selectionWrap = document.querySelector('.selection-result-wrap');
      if (selectionWrap) {
        selectionWrap.querySelectorAll('.result-item').forEach(item => item.remove());
        const noSelectionText = selectionWrap.querySelector('.no-selection-text');
        if (noSelectionText) {
          noSelectionText.style.display = 'block';
        }
      }
      
      console.log('Vessel selections cleared from localStorage');
    } catch (error) {
      console.warn('Could not clear vessel selections from localStorage:', error);
    }
  }

  // Function to remove a specific vessel's result item and clear its selections
  function clearVesselSelection(vesselNumber) {
    vesselSelections[vesselNumber] = { woodType: null, ropeType: null };
    
    const selectionWrap = document.querySelector('.selection-result-wrap');
    const resultItem = selectionWrap.querySelector(`.result-item[data-vessel="${vesselNumber}"]`);
    if (resultItem) {
      console.log(`Removing result item for vessel ${vesselNumber} (selection cleared)`);
      resultItem.remove();
    }
    
    // Update the display
    updateSelectionDisplay(false);
    saveVesselSelections();
  }

  // Initialize vessel selection functionality
  document.querySelectorAll("[data-tabs]").forEach(tabComponent => {
    const tabs = tabComponent.querySelectorAll("[data-tab]");
    const contents = tabComponent.querySelectorAll("[id^='tab']");

    tabs.forEach(btn => {
      btn.addEventListener("click", () => {
        const target = btn.getAttribute("data-tab");
        const vesselNumber = parseInt(target.replace('tab', ''));
        
        console.log(`🚢 Vessel tab clicked: switching from vessel ${activeVessel} to vessel ${vesselNumber}`);

        // update active tab styles only inside this component
        tabs.forEach(b => {
          b.classList.remove("active");
          b.classList.add("inactive");
        });
        btn.classList.remove("inactive");
        btn.classList.add("active");

        // toggle content only inside this component
        contents.forEach(c => {
          c.classList.remove("active");
          if (c.id === target) {
            c.classList.add("active");
            console.log(`✅ Activated panel: ${c.id}`);
          }
        });

        // Update active vessel
        const previousActiveVessel = activeVessel;
        activeVessel = vesselNumber;
        console.log(`🎯 Active vessel updated: ${previousActiveVessel} → ${activeVessel}`);
        
        // Debug: Check which panels are visible
        const allPanels = document.querySelectorAll('.vessel-tab-panel');
        console.log('🔍 Panel visibility check:');
        allPanels.forEach(panel => {
          const computed = window.getComputedStyle(panel);
          console.log(`Panel ${panel.id}: display=${computed.display}, hasActive=${panel.classList.contains('active')}`);
        });
        
