                  <path fill-rule="evenodd" clip-rule="evenodd" d="M0.206055 5.61713L5.20605 0.617126H10.2061V5.61713L5.20605 10.6171L0.206055 5.61713ZM7.39355 4.36713C6.87579 4.36713 6.45605 3.9474 6.45605 3.42963C6.45605 2.91186 6.87579 2.49213 7.39355 2.49213C7.91132 2.49213 8.33105 2.91186 8.33105 3.42963C8.33105 3.9474 7.91132 4.36713 7.39355 4.36713Z" fill="#A43223"/>
