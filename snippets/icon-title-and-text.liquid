<div class="tw-flex tw-items-center tw-justify-between tw-gap-x-3 {{ custom_classes }}">
    {% for block in section.blocks %}
      {%- case block.type -%}
        {%- when 'image_title_text' -%}
          <div class="tw-flex-col tw-flex tw-items-center tw-gap-y-3 tw-flex-1">
            <img
              src="{{ block.settings.block_image | image_url }}"
              class="tw-w-[4rem] tw-h-[4rem] lg:tw-w-[8rem] lg:tw-h-[8rem]"
              alt="{{ block.settings.block_image_alt }}"
              width="100%"
              height="100%"
            >
            <h6 class="tw-text-center tw-text-white tw-text-[1.4rem] tw-font-bold tw-leading-[1.1] lg:tw-text-[2.2rem] lg:tw-leading-[1.3]">
              {{ block.settings.block_title }}
            </h6>
            <span class="tw-text-center tw-text-[1.4rem] tw-leading-[1.5] tw-text-white">
              {{ block.settings.block_text }}
            </span>
          </div>
      {%- endcase -%}
    {% endfor %}
  </div>
  