{% comment %}
  Mini ATC Modal - Gift Box Component
  
  Semantic component for premium gift box add-on option.
{% endcomment %}

<article class="premium-gift-box" data-addon="gift-box">
  <h5 class="visually-hidden">Premium Gift Box Add-On</h5>
  
  <div class="premium-gift-box__container">
    <!-- Product Image -->
    <div class="premium-gift-box__image">
      <img 
        src="{{ 'premium-gift-box.png' | asset_url }}" 
        alt="Premium Gift Box & Wrap" 
        width="71" 
        height="89"
        data-gift-box-image
      />
    </div>
    
    <!-- Content Area -->
    <div class="premium-gift-box__content">
      <div class="premium-gift-box__details">
        <div class="premium-gift-box__text">
          <h6 class="premium-gift-box__title" data-gift-box-title>
            Loading...
          </h6>
        </div>
        <div 
          class="premium-gift-box__price" 
          aria-label="Gift box price"
          data-gift-box-price
        >
          Loading...
        </div>
      </div>
      
      <!-- Toggle Section -->
      <div class="premium-gift-box__toggle-section">
        <div class="premium-gift-box__toggle-container">
          <label class="premium-gift-box__toggle" for="{{ modal_id }}-premium-gift-box-toggle">
            <input 
              type="checkbox" 
              id="{{ modal_id }}-premium-gift-box-toggle" 
              class="premium-gift-box__toggle-input"
              data-addon-toggle="gift-box"
              aria-describedby="{{ modal_id }}-gift-box-description"
              {% comment %} Future integration {% endcomment %}
              data-property="properties[Premium Gift Box]"
              data-variant-id=""
              data-gift-box-variant-id=""
            >
            <span class="premium-gift-box__toggle-slider" aria-hidden="true"></span>
            <span class="visually-hidden">Add premium gift box to order</span>
          </label>
        </div>
      </div>
    </div>
  </div>
  
  <div id="{{ modal_id }}-gift-box-description" class="visually-hidden">
    Add premium gift box and wrapping to make your CHUUG order gift-ready
  </div>
</article>

<script>
  // Fetch gift box product data and update UI
  (function() {
    const giftBoxHandle = 'premium-gift-box-tissue-wrap';
    
    async function fetchGiftBoxProduct() {
      try {
        console.log(`Fetching gift box product: ${giftBoxHandle}`);
        
        const response = await fetch(`/products/${giftBoxHandle}.js`);
        if (!response.ok) {
          throw new Error(`Failed to fetch product ${giftBoxHandle}: ${response.status}`);
        }
        
        const productData = await response.json();
        console.log('Gift box product data:', productData);
        console.log('Product data keys:', Object.keys(productData));
        console.log('Featured image:', productData.featured_image);
        console.log('Images array:', productData.images);
        
        updateGiftBoxUI(productData);
        
      } catch (error) {
        console.error('Error fetching gift box product:', error);
        // Fallback to default values
        updateGiftBoxUI(null);
      }
    }
    
    function updateGiftBoxUI(productData) {
      const titleEl = document.querySelector('[data-gift-box-title]');
      const priceEl = document.querySelector('[data-gift-box-price]');
      const variantIdEl = document.querySelector('[data-gift-box-variant-id]');
      const imageEl = document.querySelector('[data-gift-box-image]');
      
      if (productData && productData.variants && productData.variants.length > 0) {
        const variant = productData.variants[0]; // Use first variant
        
        // Update title
        if (titleEl) {
          titleEl.innerHTML = `${productData.title}<br>With All CHUUG Orders`;
        }
        
        // Update price
        if (priceEl) {
          const price = (variant.price / 100).toFixed(2);
          priceEl.textContent = `£${price}`;
        }
        
        // Update variant ID for cart integration
        if (variantIdEl) {
          variantIdEl.value = variant.id;
        }
        
        // Update product image
        if (imageEl) {
          // Try different possible image properties
          let imageUrl = productData.featured_image || 
                        (productData.images && productData.images[0]) ||
                        (productData.featured_image_url);
          
          if (imageUrl) {
            console.log('Updating image to:', imageUrl);
            imageEl.src = imageUrl;
            imageEl.alt = productData.title || 'Premium Gift Box & Wrap';
          } else {
            console.log('No image found in product data');
          }
        }
        
        console.log('Updated gift box UI with product data:', {
          title: productData.title,
          price: variant.price,
          variantId: variant.id,
          image: productData.featured_image
        });
        
      } else {
        // Fallback values
        if (titleEl) {
          titleEl.innerHTML = 'Premium Gift Box & Wrap<br>With All CHUUG Orders';
        }
        
        if (priceEl) {
          priceEl.textContent = '£2.00';
        }
        
        console.log('Using fallback values for gift box');
      }
    }
    
    // Initialize when DOM is ready
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', fetchGiftBoxProduct);
    } else {
      // Add a small delay to ensure the modal is fully rendered
      setTimeout(fetchGiftBoxProduct, 100);
    }
  })();
</script>
