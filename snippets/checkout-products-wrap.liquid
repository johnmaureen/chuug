{% comment %}
  Checkout Products Wrap Component
  
  A pixel-perfect implementation of the checkout product toggle component
  based on Figma design specifications.
  
  Usage:
  {% render 'checkout-products-wrap', item: cart_item %}
{% endcomment %}
<div class="checkout-product-item-wrap">

  <div class="checkout-products-wrap" data-item-id="{{ item.id }}">
    <div class="checkout-products-wrap__container">
      <!-- Product Image Section -->
      <div class="checkout-products-wrap__image">
        <div class="checkout-products-wrap__image-container">
          {% if item.image %}
            <img 
              src="{{ item.image | image_url: width: 128, height: 128 }}"
              alt="{{ item.image.alt | escape }}"
              width="128"
              height="128"
              loading="lazy"
              class="checkout-products-wrap__product-image"
            />
          {% else %}
            <div class="checkout-products-wrap__placeholder">
              {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
          {% endif %}
        </div>
      </div>

      <!-- Product Details Section -->
      <div class="checkout-products-wrap__details">
        <!-- Product Title and Delete Button -->
        <div class="checkout-products-wrap__header">
          <h3 class="checkout-products-wrap__title">
            {{ item.product.title }}
          </h3>
          <button 
            type="button" 
            class="checkout-products-wrap__delete"
            data-remove-item="{{ item.id }}"
            aria-label="Remove {{ item.product.title }} from cart"
          >
            <svg width="25" height="25" viewBox="0 0 25 25" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M3 6H5H21" stroke="#969393" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M8 6V4C8 3.46957 8.21071 2.96086 8.58579 2.58579C8.96086 2.21071 9.46957 2 10 2H14C14.5304 2 15.0391 2.21071 15.4142 2.58579C15.7893 2.96086 16 3.46957 16 4V6M19 6V20C19 20.5304 18.7893 21.0391 18.4142 21.4142C18.0391 21.7893 17.5304 22 17 22H7C6.46957 22 5.96086 21.7893 5.58579 21.4142C5.21071 21.0391 5 20.5304 5 20V6H19Z" stroke="#969393" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M10 11V17" stroke="#969393" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M14 11V17" stroke="#969393" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>

        <!-- Product Options/Chips -->
        <div class="checkout-products-wrap__options">
          {% comment %} {% if item.properties.size > 0 %}
            {% for property in item.properties %}
              {% unless property.first contains '_' %}
                <div class="checkout-products-wrap__option-chip">
                  {{ property.first }}: {{ property.last }}
                </div>
              {% endunless %}
            {% endfor %}
          {% endif %} {% endcomment %}
          
          <!-- Default options for CHUUG products -->
          {% if item.product.title contains 'CHUUG' or item.product.title contains 'Chuug' %}
            {% assign engraving_text = '' %}
            {% assign has_insulated_cup = false %}
            {% for property in item.properties %}
              {% if property.first contains 'Engraving' %}
                {% assign engraving_text = property.last %}
              {% endif %}
              {% assign property_key_lower = property.first | downcase %}
              {% if property_key_lower contains 'insulated' or property_key_lower contains 'cup' or property_key_lower contains 'silver cup' %}
                {% assign has_insulated_cup = true %}
              {% endif %}
            {% endfor %}
            {% if engraving_text != blank %}
              <div class="checkout-products-wrap__option-chip">
                🔨 Engraved Initials, {{ engraving_text }}
              </div>
            {% endif %}
            {% if has_insulated_cup %}
              <div class="checkout-products-wrap__option-chip">
                🍺 Silver Insulated Cup
              </div>
            {% endif %}
          {% endif %}
        </div>

        <!-- Pricing Section -->
        <div class="checkout-products-wrap__pricing">
          {% if item.original_price != item.final_price %}
            <span class="checkout-products-wrap__current-price">
              {{ item.final_price | money }}
            </span>
            <span class="checkout-products-wrap__original-price">
              {{ item.original_price | money }}
            </span>
          {% else %}
            <span class="checkout-products-wrap__current-price">
              {{ item.original_price | money }}
            </span>
          {% endif %}
        </div>
      </div>
    </div>
  </div>

  <!-- Premium Gift Box - Hidden by default -->
  {% assign show_gift_box = false %}
  {% assign gift_box_item = null %}
  
  <!-- DEBUG: Show cart data -->
  <div style="background: #f0f0f0; padding: 10px; margin: 10px 0; font-size: 12px; border: 1px solid #ccc;">
    <strong>DEBUG - Cart Data:</strong><br>
    Cart items count: {{ cart.items.size }}<br>
    Cart note: "{{ cart.note }}"<br>
    Cart attributes: {{ cart.attributes | json }}<br>
    <br>
    <strong>All cart items:</strong><br>
    {% for debug_item in cart.items %}
      Item {{ forloop.index }}: "{{ debug_item.product.title }}" (ID: {{ debug_item.id }})<br>
    {% endfor %}
  </div>
  
  <!-- Check if Premium Gift Box is mentioned in cart note or attributes -->
  {% if cart.note contains 'Premium Gift Box' or cart.attributes['Premium Gift Box'] %}
    {% assign show_gift_box = true %}
    <!-- DEBUG: Found gift box in note/attributes -->
    <div style="background: #d4edda; padding: 5px; margin: 5px 0; font-size: 12px; border: 1px solid #c3e6cb;">
      DEBUG: Gift box found in cart note or attributes
    </div>
  {% endif %}
  
  <!-- Look for actual gift box item in cart -->
  {% for gift_item in cart.items %}
    {% if gift_item.product.title contains 'Premium Gift Box' or gift_item.product.title contains 'Gift Box' %}
      {% assign show_gift_box = true %}
      {% assign gift_box_item = gift_item %}
      <!-- DEBUG: Found gift box item -->
      <div style="background: #d4edda; padding: 5px; margin: 5px 0; font-size: 12px; border: 1px solid #c3e6cb;">
        DEBUG: Gift box item found - "{{ gift_item.product.title }}"
      </div>
      {% break %}
    {% endif %}
  {% endfor %}
  
  <!-- Gift box container is now hidden by default - show_gift_box remains false -->
  
  <!-- DEBUG: Final state -->
  <div style="background: {% if show_gift_box %}#d4edda{% else %}#f8d7da{% endif %}; padding: 5px; margin: 5px 0; font-size: 12px; border: 1px solid {% if show_gift_box %}#c3e6cb{% else %}#f5c6cb{% endif %};">
    DEBUG: show_gift_box = {{ show_gift_box }}, gift_box_item = {% if gift_box_item %}{{ gift_box_item.product.title }}{% else %}null{% endif %}
  </div>
  
  {% if show_gift_box %}
    <div class="premium-gift-box">
      <div class="premium-gift-box__container">
        <!-- Product Image -->
        <div class="premium-gift-box__image">
          {% if gift_box_item and gift_box_item.image %}
            <img src="{{ gift_box_item.image | image_url: width: 71, height: 89 }}" alt="{{ gift_box_item.image.alt | escape }}" width="71" height="89" />
          {% else %}
            <img src="{{ 'premium-gift-box.png' | asset_url }}" alt="Premium Gift Box & Wrap" width="71" height="89" />
          {% endif %}
        </div>
        
        <!-- Content Area -->
        <div class="premium-gift-box__content">
          <div class="premium-gift-box__details">
            <div class="premium-gift-box__text">
              <h4 class="premium-gift-box__title">
                {% if gift_box_item %}
                  {{ gift_box_item.product.title }}
                {% else %}
                  Premium Gift Box & Wrap<br>With All CHUUG Orders
                {% endif %}
              </h4>
            </div>
            <div class="premium-gift-box__price">
              {% if gift_box_item %}
                {{ gift_box_item.final_price | money }}
              {% else %}
                £2.00
              {% endif %}
            </div>
          </div>
          
          <!-- Toggle Section -->
          <button 
            type="button" 
            class="checkout-products-wrap__delete"
            data-remove-item="{% if gift_box_item %}{{ gift_box_item.id }}{% else %}gift-box{% endif %}"
            aria-label="Remove Premium Gift Box from cart"
          >
            <svg width="25" height="25" viewBox="0 0 25 25" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M3 6H5H21" stroke="#969393" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M8 6V4C8 3.46957 8.21071 2.96086 8.58579 2.58579C8.96086 2.21071 9.46957 2 10 2H14C14.5304 2 15.0391 2.21071 15.4142 2.58579C15.7893 2.96086 16 3.46957 16 4V6M19 6V20C19 20.5304 18.7893 21.0391 18.4142 21.4142C18.0391 21.7893 17.5304 22 17 22H7C6.46957 22 5.96086 21.7893 5.58579 21.4142C5.21071 21.0391 5 20.5304 5 20V6H19Z" stroke="#969393" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M10 11V17" stroke="#969393" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M14 11V17" stroke="#969393" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
      </div>
    </div>
  {% endif %}
</div>

<script>
// Log cart data for debugging - runs when this snippet loads
(function() {
  
  // Log Liquid cart data that was available at render time
  const liquidCartData = {
    itemCount: {{ cart.items.size }},
    note: {{ cart.note | json }},
    attributes: {{ cart.attributes | json }},
    items: [
      {% for debug_item in cart.items %}
        {
          id: {{ debug_item.id }},
          title: {{ debug_item.product.title | json }},
          variant_title: {{ debug_item.variant.title | json }},
          quantity: {{ debug_item.quantity }},
          price: {{ debug_item.price }},
          final_price: {{ debug_item.final_price }},
          properties: {{ debug_item.properties | json }},
          product_type: {{ debug_item.product.type | json }},
          vendor: {{ debug_item.product.vendor | json }}
        }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ]
  };
  
  // Console log the cart data for debugging
  console.log('🛒 LIQUID CART DATA:', liquidCartData);
  console.log('🛒 Cart items count:', liquidCartData.itemCount);
  console.log('🛒 Cart note:', liquidCartData.note);
  console.log('🛒 Cart attributes:', liquidCartData.attributes);
  console.log('🛒 All cart items:', liquidCartData.items);
  
  
  // Check for gift box items in Liquid data
  const giftBoxItems = liquidCartData.items.filter(item => {
    const title = (item.title || '').toLowerCase();
    return title.includes('gift') || title.includes('box');
  });
  
  console.log('🛒 Gift box items in Liquid data:', giftBoxItems);
  

  // Gift box state management - allow enabled state to persist
  // Removed forced disabling logic to allow gift box to display when enabled
  
  // Force update pricing display elements directly as backup
  function forceUpdatePricingDisplay() {
    // Look for pricing placeholder elements
    const pricingPlaceholders = document.querySelectorAll('.pricing-placeholder');
    const currentPriceElements = document.querySelectorAll('[data-current-price], .mini-atc-modal__current-price');

    // Check if we can get the correct price from POMC system
    if (window.pomcSystem && window.pomcSystem.getSelectedProductAmountData) {
      try {
        const productData = window.pomcSystem.getSelectedProductAmountData();

        if (productData && productData.price) {
          const correctPrice = (productData.price / 100).toFixed(2);
          const formattedPrice = `£${correctPrice}`;

          pricingPlaceholders.forEach(el => {
            if (el.textContent !== formattedPrice) {
              el.textContent = formattedPrice;
            }
          });

          currentPriceElements.forEach(el => {
            const placeholder = el.querySelector('.pricing-placeholder');
            if (placeholder && placeholder.textContent !== formattedPrice) {
              placeholder.textContent = formattedPrice;
            }
          });
        }
      } catch (error) {
      }
    }
  }
  
  // Force update pricing display immediately if systems are ready
  forceUpdatePricingDisplay();
  
  // Watch for dynamic price changes
  function watchForPriceChanges() {
    const targetNodes = document.querySelectorAll('.pricing-placeholder, [data-current-price]');

    if (targetNodes.length > 0) {
      const observer = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
          if (mutation.type === 'childList' || mutation.type === 'characterData') {
            const target = mutation.target;
            const element = target.nodeType === Node.TEXT_NODE ? target.parentElement : target;

            // Monitor price changes
            if (element && (element.classList.contains('pricing-placeholder') || element.hasAttribute('data-current-price'))) {
              // Price change detected - could add logic here if needed
            }
          }
        });
      });

      targetNodes.forEach(node => {
        observer.observe(node, {
          childList: true,
          subtree: true,
          characterData: true
        });
      });
    }
  }
  
  // Start watching for price changes
  watchForPriceChanges();
  
  // Gift box items are now allowed to remain in cart
  // Removed auto-removal logic to allow gift box display
  
  // Also fetch current cart data via JavaScript API
  if (window.cartManager) {
    window.cartManager.getCart()
      .then(cartData => {
        console.log('🛒 CART MANAGER DATA:', cartData);
        console.log('🛒 Cart Manager items:', cartData.items);
      })
      .catch(error => {
        console.error('🛒 Cart Manager error:', error);
      });
  } else {
    // Fallback if cart manager isn't available yet
    fetch('/cart.js')
      .then(response => response.json())
      .then(cartData => {
        console.log('🛒 FETCH CART DATA:', cartData);
        console.log('🛒 Fetch items:', cartData.items);
        
        // Check for gift box items in JavaScript data
        const jsGiftBoxItems = (cartData.items || []).filter(item => {
          const title = (item.product_title || item.title || '').toLowerCase();
          return title.includes('gift') || title.includes('box');
        });
        
        console.log('🛒 Gift box items found:', jsGiftBoxItems);
        
      })
      .catch(error => {
        console.error('🛒 Fetch cart error:', error);
      });
  }

})();
</script>