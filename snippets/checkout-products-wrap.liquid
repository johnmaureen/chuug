{% comment %}
  Checkout Products Wrap Component
  
  A pixel-perfect implementation of the checkout product toggle component
  based on Figma design specifications.
  
  Usage:
  {% render 'checkout-products-wrap', item: cart_item %}
{% endcomment %}
<div class="checkout-product-item-wrap">

  <div class="checkout-products-wrap" data-item-id="{{ item.id }}">
    <div class="checkout-products-wrap__container">
      <!-- Product Image Section -->
      <div class="checkout-products-wrap__image">
        <div class="checkout-products-wrap__image-container">
          {% if item.image %}
            <img 
              src="{{ item.image | image_url: width: 128, height: 128 }}"
              alt="{{ item.image.alt | escape }}"
              width="128"
              height="128"
              loading="lazy"
              class="checkout-products-wrap__product-image"
            />
          {% else %}
            <div class="checkout-products-wrap__placeholder">
              {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
          {% endif %}
        </div>
      </div>

      <!-- Product Details Section -->
      <div class="checkout-products-wrap__details">
        <!-- Product Title and Delete Button -->
        <div class="checkout-products-wrap__header">
          <h3 class="checkout-products-wrap__title">
            {{ item.product.title }}
          </h3>
          <button 
            type="button" 
            class="checkout-products-wrap__delete"
            data-remove-item="{{ item.id }}"
            aria-label="Remove {{ item.product.title }} from cart"
          >
            <svg width="25" height="25" viewBox="0 0 25 25" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M3 6H5H21" stroke="#969393" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M8 6V4C8 3.46957 8.21071 2.96086 8.58579 2.58579C8.96086 2.21071 9.46957 2 10 2H14C14.5304 2 15.0391 2.21071 15.4142 2.58579C15.7893 2.96086 16 3.46957 16 4V6M19 6V20C19 20.5304 18.7893 21.0391 18.4142 21.4142C18.0391 21.7893 17.5304 22 17 22H7C6.46957 22 5.96086 21.7893 5.58579 21.4142C5.21071 21.0391 5 20.5304 5 20V6H19Z" stroke="#969393" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M10 11V17" stroke="#969393" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M14 11V17" stroke="#969393" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>

        <!-- Product Options/Chips -->
        <div class="checkout-products-wrap__options">
          {% comment %} {% if item.properties.size > 0 %}
            {% for property in item.properties %}
              {% unless property.first contains '_' %}
                <div class="checkout-products-wrap__option-chip">
                  {{ property.first }}: {{ property.last }}
                </div>
              {% endunless %}
            {% endfor %}
          {% endif %} {% endcomment %}
          
          <!-- Default options for CHUUG products -->
          {% if item.product.title contains 'CHUUG' or item.product.title contains 'Chuug' %}
            {% assign engraving_text = '' %}
            {% assign has_insulated_cup = false %}
            {% for property in item.properties %}
              {% if property.first contains 'Engraving' %}
                {% assign engraving_text = property.last %}
              {% endif %}
              {% assign property_key_lower = property.first | downcase %}
              {% if property_key_lower contains 'insulated' or property_key_lower contains 'cup' or property_key_lower contains 'silver cup' %}
                {% assign has_insulated_cup = true %}
              {% endif %}
            {% endfor %}
            {% if engraving_text != blank %}
              <div class="checkout-products-wrap__option-chip">
                🔨 Engraved Initials, {{ engraving_text }}
              </div>
            {% endif %}
            {% if has_insulated_cup %}
              <div class="checkout-products-wrap__option-chip">
                🍺 Silver Insulated Cup
              </div>
            {% endif %}
          {% endif %}
        </div>

        <!-- Pricing Section -->
        <div class="checkout-products-wrap__pricing">
          {% if item.original_price != item.final_price %}
            <span class="checkout-products-wrap__current-price">
              {{ item.final_price | money }}
            </span>
            <span class="checkout-products-wrap__original-price">
              {{ item.original_price | money }}
            </span>
          {% else %}
            <span class="checkout-products-wrap__current-price">
              {{ item.original_price | money }}
            </span>
          {% endif %}
        </div>
      </div>
    </div>
  </div>

  <!-- Premium Gift Box - Hidden by default -->
  {% assign show_gift_box = false %}
  {% assign gift_box_item = null %}
  
  <!-- DEBUG: Show cart data -->
  <div style="background: #f0f0f0; padding: 10px; margin: 10px 0; font-size: 12px; border: 1px solid #ccc;">
    <strong>DEBUG - Cart Data:</strong><br>
    Cart items count: {{ cart.items.size }}<br>
    Cart note: "{{ cart.note }}"<br>
    Cart attributes: {{ cart.attributes | json }}<br>
    <br>
    <strong>All cart items:</strong><br>
    {% for debug_item in cart.items %}
      Item {{ forloop.index }}: "{{ debug_item.product.title }}" (ID: {{ debug_item.id }})<br>
    {% endfor %}
  </div>
  
  {% comment %}
  <!-- Check if Premium Gift Box is mentioned in cart note or attributes -->
  {% if cart.note contains 'Premium Gift Box' or cart.attributes['Premium Gift Box'] %}
    {% assign show_gift_box = true %}
    <!-- DEBUG: Found gift box in note/attributes -->
    <div style="background: #d4edda; padding: 5px; margin: 5px 0; font-size: 12px; border: 1px solid #c3e6cb;">
      DEBUG: Gift box found in cart note or attributes
    </div>
  {% endif %}
  
  <!-- Look for actual gift box item in cart -->
  {% for gift_item in cart.items %}
    {% if gift_item.product.title contains 'Premium Gift Box' or gift_item.product.title contains 'Gift Box' %}
      {% assign show_gift_box = true %}
      {% assign gift_box_item = gift_item %}
      <!-- DEBUG: Found gift box item -->
      <div style="background: #d4edda; padding: 5px; margin: 5px 0; font-size: 12px; border: 1px solid #c3e6cb;">
        DEBUG: Gift box item found - "{{ gift_item.product.title }}"
      </div>
      {% break %}
    {% endif %}
  {% endfor %}
  {% endcomment %}
  
  <!-- Gift box container is now hidden by default - show_gift_box remains false -->
  
  <!-- DEBUG: Final state -->
  <div style="background: {% if show_gift_box %}#d4edda{% else %}#f8d7da{% endif %}; padding: 5px; margin: 5px 0; font-size: 12px; border: 1px solid {% if show_gift_box %}#c3e6cb{% else %}#f5c6cb{% endif %};">
    DEBUG: show_gift_box = {{ show_gift_box }}, gift_box_item = {% if gift_box_item %}{{ gift_box_item.product.title }}{% else %}null{% endif %}
  </div>
  
  {% if show_gift_box %}
    <div class="premium-gift-box">
      <div class="premium-gift-box__container">
        <!-- Product Image -->
        <div class="premium-gift-box__image">
          {% if gift_box_item and gift_box_item.image %}
            <img src="{{ gift_box_item.image | image_url: width: 71, height: 89 }}" alt="{{ gift_box_item.image.alt | escape }}" width="71" height="89" />
          {% else %}
            <img src="{{ 'premium-gift-box.png' | asset_url }}" alt="Premium Gift Box & Wrap" width="71" height="89" />
          {% endif %}
        </div>
        
        <!-- Content Area -->
        <div class="premium-gift-box__content">
          <div class="premium-gift-box__details">
            <div class="premium-gift-box__text">
              <h4 class="premium-gift-box__title">
                {% if gift_box_item %}
                  {{ gift_box_item.product.title }}
                {% else %}
                  Premium Gift Box & Wrap<br>With All CHUUG Orders
                {% endif %}
              </h4>
            </div>
            <div class="premium-gift-box__price">
              {% if gift_box_item %}
                {{ gift_box_item.final_price | money }}
              {% else %}
                £2.00
              {% endif %}
            </div>
          </div>
          
          <!-- Toggle Section -->
          <button 
            type="button" 
            class="checkout-products-wrap__delete"
            data-remove-item="{% if gift_box_item %}{{ gift_box_item.id }}{% else %}gift-box{% endif %}"
            aria-label="Remove Premium Gift Box from cart"
          >
            <svg width="25" height="25" viewBox="0 0 25 25" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M3 6H5H21" stroke="#969393" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M8 6V4C8 3.46957 8.21071 2.96086 8.58579 2.58579C8.96086 2.21071 9.46957 2 10 2H14C14.5304 2 15.0391 2.21071 15.4142 2.58579C15.7893 2.96086 16 3.46957 16 4V6M19 6V20C19 20.5304 18.7893 21.0391 18.4142 21.4142C18.0391 21.7893 17.5304 22 17 22H7C6.46957 22 5.96086 21.7893 5.58579 21.4142C5.21071 21.0391 5 20.5304 5 20V6H19Z" stroke="#969393" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M10 11V17" stroke="#969393" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M14 11V17" stroke="#969393" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
      </div>
    </div>
  {% endif %}
</div>

<script>
// Log cart data for debugging - runs when this snippet loads
(function() {
  console.group('🛒 LIQUID CART DATA DEBUG');
  
  // Log Liquid cart data that was available at render time
  const liquidCartData = {
    itemCount: {{ cart.items.size }},
    note: {{ cart.note | json }},
    attributes: {{ cart.attributes | json }},
    items: [
      {% for debug_item in cart.items %}
        {
          id: {{ debug_item.id }},
          title: {{ debug_item.product.title | json }},
          variant_title: {{ debug_item.variant.title | json }},
          quantity: {{ debug_item.quantity }},
          price: {{ debug_item.price }},
          final_price: {{ debug_item.final_price }},
          properties: {{ debug_item.properties | json }},
          product_type: {{ debug_item.product.type | json }},
          vendor: {{ debug_item.product.vendor | json }}
        }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ]
  };
  
  console.log('Liquid cart data (server-side):', liquidCartData);
  
  // Check for gift box items in Liquid data
  const giftBoxItems = liquidCartData.items.filter(item => {
    const title = (item.title || '').toLowerCase();
    return title.includes('gift') || title.includes('box');
  });
  
  if (giftBoxItems.length > 0) {
    console.log('🎁 Gift box items found in Liquid data:', giftBoxItems);
  } else {
    console.log('❌ No gift box items found in Liquid data');
  }
  
  console.groupEnd();

  console.log('🚀 GIFT BOX DEBUG: Starting gift box fix script...');

  // Reset gift box state in localStorage to ensure it starts as disabled
  function resetGiftBoxState() {
    const storageKey = 'chuug_mini_atc_selections';
    try {
      const saved = localStorage.getItem(storageKey);
      console.log('🔍 DEBUG: Current localStorage state:', saved ? JSON.parse(saved) : 'null');

      if (saved) {
        const parsedState = JSON.parse(saved);
        console.log('🔍 DEBUG: Parsed localStorage state:', parsedState);
        console.log('🔍 DEBUG: giftBox state in localStorage:', parsedState.giftBox);

        if (parsedState.giftBox && parsedState.giftBox.enabled) {
          console.log('🔄 Resetting gift box state from enabled to disabled in localStorage');
          parsedState.giftBox.enabled = false;
          localStorage.setItem(storageKey, JSON.stringify(parsedState));
          console.log('✅ Gift box state reset to disabled');
          console.log('🔍 DEBUG: Updated localStorage state:', JSON.parse(localStorage.getItem(storageKey)));
        } else {
          console.log('✅ Gift box state already disabled in localStorage');
        }
      } else {
        console.log('✅ No saved state found in localStorage');
      }
    } catch (error) {
      console.error('❌ Error resetting gift box state:', error);
    }
  }
  
  // Reset gift box state first
  resetGiftBoxState();
  
  // Also ensure mini-atc modal respects the disabled state
  function ensureGiftBoxDisabled() {
    console.log('🔍 DEBUG: Checking mini-atc modal availability...');
    console.log('🔍 DEBUG: window.miniAtcModal:', !!window.miniAtcModal);
    console.log('🔍 DEBUG: window.miniAtcModal.state:', !!window.miniAtcModal?.state);
    console.log('🔍 DEBUG: window.miniAtcModal.pricing:', !!window.miniAtcModal?.pricing);

    // Wait for mini-atc modal to be available
    if (window.miniAtcModal && window.miniAtcModal.state && window.miniAtcModal.pricing) {
      console.log('🔄 Ensuring mini-atc modal gift box state is disabled');
      const currentState = window.miniAtcModal.state.getState();
      console.log('🔍 DEBUG: Current mini-atc modal state:', currentState);
      console.log('🔍 DEBUG: Current giftBox state:', currentState.giftBox);

      window.miniAtcModal.state.updatePersonalization('giftBox', { enabled: false });
      console.log('✅ Mini-atc modal gift box state set to disabled');

      // Force pricing recalculation to update the display
      console.log('🔄 Forcing pricing recalculation...');
      const newState = window.miniAtcModal.state.getState();
      console.log('🔍 DEBUG: State after update:', newState);
      const newPricing = window.miniAtcModal.pricing.calculateTotal(newState);
      console.log('🔍 DEBUG: New pricing calculation:', newPricing);
      window.miniAtcModal.updatePricingDisplay(newPricing);
      console.log('✅ Pricing recalculated and display updated');
    } else {
      console.log('⚠️ Mini-atc modal not ready, retrying...');
      // Retry if not available yet
      ensureGiftBoxDisabled();
    }
  }
  
  // Ensure gift box is disabled in mini-atc modal
  ensureGiftBoxDisabled();
  
  // Ensure gift box toggle UI reflects disabled state
  function ensureGiftBoxToggleOff() {
    const giftBoxToggles = document.querySelectorAll('[data-addon-toggle="gift-box"]');
    giftBoxToggles.forEach(toggle => {
      if (toggle.checked) {
        console.log('🔄 Setting gift box toggle to OFF in UI');
        toggle.checked = false;
        // Trigger change event to update any listeners
        toggle.dispatchEvent(new Event('change', { bubbles: true }));
        console.log('✅ Gift box toggle set to OFF');
      }
    });
  }
  
  // Set toggles to OFF state
  ensureGiftBoxToggleOff();
  
  // Force update pricing display elements directly as backup
  function forceUpdatePricingDisplay() {
    console.log('🔍 DEBUG: Force updating pricing display...');

    // Look for pricing placeholder elements
    const pricingPlaceholders = document.querySelectorAll('.pricing-placeholder');
    const currentPriceElements = document.querySelectorAll('[data-current-price], .mini-atc-modal__current-price');

    console.log('🔍 DEBUG: Found pricing placeholders:', pricingPlaceholders.length);
    console.log('🔍 DEBUG: Found current price elements:', currentPriceElements.length);

    // Check if we can get the correct price from POMC system
    if (window.pomcSystem && window.pomcSystem.getSelectedProductAmountData) {
      try {
        const productData = window.pomcSystem.getSelectedProductAmountData();
        console.log('🔍 DEBUG: POMC product data:', productData);

        if (productData && productData.price) {
          const correctPrice = (productData.price / 100).toFixed(2);
          const formattedPrice = `£${correctPrice}`;

          console.log('🔄 Force updating pricing display to correct price:', formattedPrice);
          console.log('🔍 DEBUG: Current pricing placeholders content:',
            Array.from(pricingPlaceholders).map(el => el.textContent));

          pricingPlaceholders.forEach(el => {
            if (el.textContent !== formattedPrice) {
              console.log('🔄 Updating placeholder from:', el.textContent, 'to:', formattedPrice);
              el.textContent = formattedPrice;
              console.log('✅ Updated pricing placeholder');
            } else {
              console.log('✅ Pricing placeholder already correct');
            }
          });

          currentPriceElements.forEach(el => {
            const placeholder = el.querySelector('.pricing-placeholder');
            if (placeholder && placeholder.textContent !== formattedPrice) {
              console.log('🔄 Updating current price element from:', placeholder.textContent, 'to:', formattedPrice);
              placeholder.textContent = formattedPrice;
              console.log('✅ Updated current price element');
            }
          });
        } else {
          console.log('⚠️ No product data or price available from POMC');
        }
      } catch (error) {
        console.error('❌ Error force updating pricing display:', error);
      }
    } else {
      console.log('⚠️ POMC system not available for price calculation');
      console.log('🔍 DEBUG: window.pomcSystem:', !!window.pomcSystem);
      console.log('🔍 DEBUG: window.pomcSystem.getSelectedProductAmountData:', !!window.pomcSystem?.getSelectedProductAmountData);
    }
  }
  
  // Force update pricing display immediately if systems are ready
  forceUpdatePricingDisplay();
  
  // Watch for dynamic price changes and log them for debugging
  function watchForPriceChanges() {
    const targetNodes = document.querySelectorAll('.pricing-placeholder, [data-current-price]');

    console.log('🔍 DEBUG: Setting up price change observer for', targetNodes.length, 'elements');

    if (targetNodes.length > 0) {
      const observer = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
          if (mutation.type === 'childList' || mutation.type === 'characterData') {
            const target = mutation.target;
            const element = target.nodeType === Node.TEXT_NODE ? target.parentElement : target;

            // Log price changes for debugging
            if (element && (element.classList.contains('pricing-placeholder') || element.hasAttribute('data-current-price'))) {
              const currentText = element.textContent;
              const elementInfo = {
                tagName: element.tagName,
                className: element.className,
                id: element.id,
                content: currentText
              };
              console.log('🔍 Price change detected:', elementInfo);
              console.log('🔍 Mutation details:', {
                type: mutation.type,
                target: mutation.target,
                oldValue: mutation.oldValue,
                newValue: mutation.target.textContent
              });
            }
          }
        });
      });

      targetNodes.forEach(node => {
        observer.observe(node, {
          childList: true,
          subtree: true,
          characterData: true
        });
      });

      console.log('👁️ Price change observer activated for debugging');
    } else {
      console.log('⚠️ No pricing elements found to observe');
    }
  }
  
  // Start watching for price changes
  watchForPriceChanges();
  
  // Auto-remove gift box items since container is disabled by default
  function autoRemoveGiftBoxItems() {
    console.log('🔍 DEBUG: Checking cart manager availability...');
    console.log('🔍 DEBUG: window.cartManager:', !!window.cartManager);

    if (window.cartManager) {
      console.log('🧹 Checking for gift box items to remove (container disabled by default)...');
      window.cartManager.getCart()
        .then(cartData => {
          console.log('🔍 DEBUG: Cart data received:', cartData);
          console.log('🔍 DEBUG: Cart items:', cartData.items);

          const giftBoxItems = (cartData.items || []).filter(item => {
            const title = (item.product_title || item.title || '').toLowerCase();
            const isGiftBox = title.includes('gift') && title.includes('box');
            const hasGiftBoxProperty = item.properties && item.properties['Premium Gift Box'];
            const matches = isGiftBox || hasGiftBoxProperty;

            if (matches) {
              console.log('🔍 DEBUG: Found potential gift box item:', {
                id: item.id,
                title: item.product_title || item.title,
                properties: item.properties,
                isGiftBox,
                hasGiftBoxProperty
              });
            }

            return matches;
          });

          console.log('🔍 DEBUG: Filtered gift box items:', giftBoxItems);

          if (giftBoxItems.length > 0) {
            console.log('🗑️ Found gift box items to remove:', giftBoxItems);
            // Remove each gift box item
            giftBoxItems.forEach(item => {
              console.log(`Removing gift box item: ${item.product_title || item.title} (ID: ${item.id})`);
              window.cartManager.removeItem(item.id)
                .then(() => console.log(`✅ Successfully removed gift box item ${item.id}`))
                .catch(error => console.error(`❌ Failed to remove gift box item ${item.id}:`, error));
            });
          } else {
            console.log('✅ No gift box items found in cart');
          }
        })
        .catch(error => {
          console.error('Failed to fetch cart data for gift box cleanup:', error);
        });
    } else {
      console.log('Cart manager not available for gift box cleanup, retrying...');
      autoRemoveGiftBoxItems();
    }
  }
  
  // Run gift box cleanup
  autoRemoveGiftBoxItems();
  
  // Also fetch current cart data via JavaScript API
  if (window.cartManager) {
    console.log('📡 Fetching current cart data via JavaScript API...');
    window.cartManager.getCart().catch(error => {
      console.error('Failed to fetch cart data via API:', error);
    });
  } else {
    // Fallback if cart manager isn't available yet
    fetch('/cart.js')
      .then(response => response.json())
      .then(cartData => {
        console.group('🛒 JAVASCRIPT CART DATA DEBUG');
        console.log('JavaScript cart data (client-side):', cartData);
        
        // Check for gift box items in JavaScript data
        const jsGiftBoxItems = (cartData.items || []).filter(item => {
          const title = (item.product_title || item.title || '').toLowerCase();
          return title.includes('gift') || title.includes('box');
        });
        
        if (jsGiftBoxItems.length > 0) {
          console.log('🎁 Gift box items found in JavaScript data:', jsGiftBoxItems);
        } else {
          console.log('❌ No gift box items found in JavaScript data');
        }
        
        console.groupEnd();
      })
      .catch(error => {
        console.error('Failed to fetch cart data:', error);
      });
  }

  console.log('✅ GIFT BOX DEBUG: Gift box fix script completed');
})();
</script>