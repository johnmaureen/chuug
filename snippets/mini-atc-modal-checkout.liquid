{% comment %}
  Mini ATC Modal - Checkout View
  
  Semantic checkout summary view with order details and progression indicators.
{% endcomment %}

<!-- Step Process Indicator -->
<section class="step-process-section" aria-labelledby="{{ modal_id }}-progress-heading">
  <h3 id="{{ modal_id }}-progress-heading" class="visually-hidden">Checkout Progress</h3>
  
  <div class="step-process-indicator" role="progressbar" aria-valuenow="2" aria-valuemin="1" aria-valuemax="3">
    <h4 class="step-process-indicator__header" data-progress-header>
      {%- comment -%} Dynamic header - will be updated by JavaScript based on cart total and currency {%- endcomment -%}
      🔥 You're only 1 CHUUG away to unlock <span>EXTRA £30 OFF</span>
    </h4>
    
    <div class="step-process-indicator__progress-bar" aria-hidden="true">
      <div class="step-process-indicator__progress-fill"></div>
    </div>
    
    <ol class="step-process-indicator__steps">
      <!-- Step 1: Free Shipping (Dynamic) -->
      <li class="step-process-indicator__step step-process-indicator__step--active" data-step="shipping">
        <div class="step-process-indicator__step-icon" aria-hidden="true">
          <div class="step-process-indicator__step-circle" data-step-1-icon>
            <svg class="step-process-indicator__truck-icon" fill="#fff" width="15" height="15" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg">
              <path d="M 0 6 L 0 8 L 19 8 L 19 23 L 12.84375 23 C 12.398438 21.28125 10.851563 20 9 20 C 7.148438 20 5.601563 21.28125 5.15625 23 L 4 23 L 4 18 L 2 18 L 2 25 L 5.15625 25 C 5.601563 26.71875 7.148438 28 9 28 C 10.851563 28 12.398438 26.71875 12.84375 25 L 21.15625 25 C 21.601563 26.71875 23.148438 28 25 28 C 26.851563 28 28.398438 26.71875 28.84375 25 L 32 25 L 32 16.84375 L 31.9375 16.6875 L 29.9375 10.6875 L 29.71875 10 L 21 10 L 21 6 Z M 1 10 L 1 12 L 10 12 L 10 10 Z M 21 12 L 28.28125 12 L 30 17.125 L 30 23 L 28.84375 23 C 28.398438 21.28125 26.851563 20 25 20 C 23.148438 20 21.601563 21.28125 21.15625 23 L 21 23 Z M 2 14 L 2 16 L 8 16 L 8 14 Z M 9 22 C 10.117188 22 11 22.882813 11 24 C 11 25.117188 10.117188 26 9 26 C 7.882813 26 7 25.117188 7 24 C 7 22.882813 7.882813 22 9 22 Z M 25 22 C 26.117188 22 27 22.882813 27 24 C 27 25.117188 26.117188 26 25 26 C 23.882813 26 23 25.117188 23 24 C 23 22.882813 23.882813 22 25 22 Z"></path>
            </svg>
            <svg class="step-process-indicator__checkmark" width="15" height="10" viewBox="0 0 15 10" fill="none" xmlns="http://www.w3.org/2000/svg" style="display: none;">
              <path d="M1 5L5 9L14 1" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </div>
        <div class="step-process-indicator__step-text">Free Shipping</div>
      </li>
      
      <!-- Step 2: Unlock Extra $30 OFF (Dynamic) -->
      <li class="step-process-indicator__step" data-step="discount-30">
        <div class="step-process-indicator__step-icon" aria-hidden="true">
          <div class="step-process-indicator__step-circle" data-step-2-icon>
            <span class="step-process-indicator__currency-symbol">£</span>
            <svg class="step-process-indicator__checkmark" width="15" height="10" viewBox="0 0 15 10" fill="none" xmlns="http://www.w3.org/2000/svg" style="display: none;">
              <path d="M1 5L5 9L14 1" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </div>
        </div>
        <div class="step-process-indicator__step-text" data-currency-text="Unlock Extra {amount} OFF" data-amount="3000">Unlock Extra {{ 3000 | money }} OFF</div>
      </li>
      
      <!-- Step 3: Unlock Extra $45 OFF (NEW - Dynamic) -->
      <li class="step-process-indicator__step" data-step="discount-45">
        <div class="step-process-indicator__step-icon" aria-hidden="true">
          <div class="step-process-indicator__step-circle" data-step-3-icon>
            <span class="step-process-indicator__currency-symbol">£</span>
            <svg class="step-process-indicator__checkmark" width="15" height="10" viewBox="0 0 15 10" fill="none" xmlns="http://www.w3.org/2000/svg" style="display: none;">
              <path d="M1 5L5 9L14 1" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </div>
        </div>
        <div class="step-process-indicator__step-text" data-currency-text="Unlock Extra {amount} OFF" data-amount="4500">Unlock Extra {{ 4500 | money }} OFF</div>
      </li>
    </ol>
  </div>
</section>

<!-- Progress Header Dynamic Update Script -->
<script>
(function() {
  'use strict';
  
  // ========================================
  // FREE SHIPPING CONFIGURATION
  // ========================================
  const FREE_SHIPPING_THRESHOLDS = {
    GBP: {
      threshold: 7500,        // £75.00 in cents
      shippingCost: 349,      // £3.49 in cents
      symbol: '£',
      message: '🔥 You\'re only {amount} away from <span>FREE Shipping!</span>'
    },
    AUD: {
      threshold: 20000,       // $200.00 in cents
      shippingCost: 1495,     // $14.95 in cents
      symbol: '$',
      message: '🔥 You\'re only {amount} away <span>FREE Shipping!</span>'
    },
    USD: {
      threshold: 1495,        // $14.95 in cents
      shippingCost: 0,        // Free shipping
      symbol: '$',
      message: '🔥 You\'re only {amount} away <span>FREE Shipping!</span>'
    }
  };
  
  // ========================================
  // HELPER FUNCTIONS
  // ========================================
  
  /**
   * Get current currency from multiple sources
   */
  function getCurrentCurrency() {
    // Try CURRENT_CURRENCY first (most reliable)
    if (window.CURRENT_CURRENCY) {
      return window.CURRENT_CURRENCY;
    }
    
    // Try Shopify currency
    if (window.Shopify?.currency?.active) {
      return window.Shopify.currency.active;
    }
    
    // Try shop currency
    if (window.Shopify?.shop?.currency) {
      return window.Shopify.shop.currency;
    }
    
    // Default to GBP
    return 'GBP';
  }
  
  /**
   * Get free shipping configuration for currency
   */
  function getFreeShippingConfig(currency) {
    return FREE_SHIPPING_THRESHOLDS[currency] || FREE_SHIPPING_THRESHOLDS.GBP;
  }
  
  /**
   * Calculate amount needed for free shipping
   */
  function calculateAmountNeeded(cartTotal, currency) {
    const config = getFreeShippingConfig(currency);
    const amountNeeded = config.threshold - cartTotal;
    
    return {
      amountNeeded: Math.max(0, amountNeeded),
      thresholdReached: amountNeeded <= 0,
      config: config
    };
  }
  
  /**
   * Format currency amount
   */
  function formatAmount(amountInCents, symbol) {
    const amount = (amountInCents / 100).toFixed(2);
    return symbol + amount;
  }
  
  /**
   * Format progress message based on cart state (4 states)
   */
  function formatProgressMessage(amountNeeded, config, thresholdReached, currency, itemCount) {
    const symbol = config.symbol;
    
    // STATE 1 (0%): Below shipping threshold - show amount needed
    if (!thresholdReached) {
      const formattedAmount = formatAmount(amountNeeded, symbol);
      return config.message.replace('{amount}', formattedAmount);
    }
    
    // STATE 2 (10%): Shipping unlocked, <2 CHUUGs - show "1 CHUUG away £30 OFF"
    if (itemCount < 2) {
      return `🔥 You're only 1 CHUUG away to unlock <span>EXTRA ${symbol}30 OFF</span>`;
    }
    
    // STATE 3 (50%): 2+ CHUUGs, <3 CHUUGs - show "1 CHUUG away £45 OFF"
    if (itemCount >= 2 && itemCount < 3) {
      return `🔥 You're only 1 CHUUG away to unlock <span>EXTRA ${symbol}45 OFF</span>`;
    }
    
    // STATE 4 (100%): 3+ CHUUGs - show "unlocked £45 OFF"
    return `🔥 You've unlocked <span>EXTRA ${symbol}45 OFF</span>`;
  }
  
  /**
   * Count non-gift-box items in cart (vessels/CHUUGs only)
   */
  function countNonGiftBoxItems(cartData) {
    if (!cartData || !cartData.items) {
      return 0;
    }
    
    const vessels = cartData.items.filter(item => {
      // Method 1: Check properties for 'Add-on' marker
      if (item.properties && item.properties['Add-on'] === 'Premium Gift Box') {
        console.log('🎁 Excluded gift box (by property):', item.title || item.product_title);
        return false;
      }
      
      // Method 2: Check product title for gift box keywords
      const title = (item.title || item.product_title || '').toLowerCase();
      if (title.includes('gift box') || title.includes('tissue wrap')) {
        console.log('🎁 Excluded gift box (by title):', item.title || item.product_title);
        return false;
      }
      
      // Method 3: Check product type
      const productType = (item.product_type || '').toLowerCase();
      if (productType.includes('gift') || productType.includes('add-on')) {
        console.log('🎁 Excluded add-on (by type):', item.title || item.product_title);
        return false;
      }
      
      // This is a vessel/CHUUG
      console.log('🍺 Counted vessel:', item.title || item.product_title);
      return true;
    });
    
    console.log(`📊 Item Count: ${vessels.length} vessels (excluded ${cartData.items.length - vessels.length} gift boxes/add-ons)`);
    return vessels.length;
  }
  
  /**
   * Update Step 1 icon (Free Shipping: truck or checkmark)
   */
  function updateStep1Icon(isCompleted) {
    const step1 = document.querySelector('[data-step="shipping"]');
    const step1Icon = document.querySelector('[data-step-1-icon]');
    
    if (!step1Icon) {
      console.warn('⚠️ Step 1 icon element not found');
      return;
    }
    
    const truckIcon = step1Icon.querySelector('.step-process-indicator__truck-icon');
    const checkmark = step1Icon.querySelector('.step-process-indicator__checkmark');
    
    if (isCompleted) {
      // Show checkmark, hide truck
      if (truckIcon) truckIcon.style.display = 'none';
      if (checkmark) checkmark.style.display = 'block';
      
      // Add completed class to step
      if (step1) {
        step1.classList.add('step-process-indicator__step--completed');
        step1.classList.remove('step-process-indicator__step--active');
      }
      
      console.log('✓ Step 1 (Shipping): Checkmark (completed)');
    } else {
      // Show truck, hide checkmark
      if (truckIcon) truckIcon.style.display = '';
      if (checkmark) checkmark.style.display = 'none';
      
      // Remove completed class, keep active
      if (step1) {
        step1.classList.remove('step-process-indicator__step--completed');
        step1.classList.add('step-process-indicator__step--active');
      }
      
      console.log('🚚 Step 1 (Shipping): Truck (active)');
    }
  }
  
  /**
   * Update Step 2 icon (£30 OFF: currency symbol or checkmark)
   */
  function updateStep2Icon(isCompleted, isActive = false) {
    const step2 = document.querySelector('[data-step="discount-30"]');
    const step2Icon = document.querySelector('[data-step-2-icon]');
    
    if (!step2Icon) {
      console.warn('⚠️ Step 2 icon element not found');
      return;
    }
    
    const currencySymbol = step2Icon.querySelector('.step-process-indicator__currency-symbol');
    const checkmark = step2Icon.querySelector('.step-process-indicator__checkmark');
    
    if (isCompleted) {
      // Show checkmark, hide currency symbol
      if (currencySymbol) currencySymbol.style.display = 'none';
      if (checkmark) checkmark.style.display = 'block';
      
      // Add completed class to step
      if (step2) {
        step2.classList.add('step-process-indicator__step--completed');
        step2.classList.remove('step-process-indicator__step--active');
      }
      
      console.log('✓ Step 2 (£30 OFF): Checkmark (completed)');
    } else {
      // Show currency symbol, hide checkmark
      if (currencySymbol) currencySymbol.style.display = '';
      if (checkmark) checkmark.style.display = 'none';
      
      // Set active or inactive state
      if (step2) {
        step2.classList.remove('step-process-indicator__step--completed');
        if (isActive) {
          step2.classList.add('step-process-indicator__step--active');
        } else {
          step2.classList.remove('step-process-indicator__step--active');
        }
      }
      
      console.log(`£ Step 2 (£30 OFF): Currency symbol (${isActive ? 'active' : 'inactive'})`);
    }
  }
  
  /**
   * Update Step 3 icon (£45 OFF: currency symbol or checkmark)
   */
  function updateStep3Icon(isCompleted, isActive = false) {
    const step3 = document.querySelector('[data-step="discount-45"]');
    const step3Icon = document.querySelector('[data-step-3-icon]');
    
    if (!step3Icon) {
      console.warn('⚠️ Step 3 icon element not found');
      return;
    }
    
    const currencySymbol = step3Icon.querySelector('.step-process-indicator__currency-symbol');
    const checkmark = step3Icon.querySelector('.step-process-indicator__checkmark');
    
    if (isCompleted) {
      // Show checkmark, hide currency symbol
      if (currencySymbol) currencySymbol.style.display = 'none';
      if (checkmark) checkmark.style.display = 'block';
      
      // Add completed class to step
      if (step3) {
        step3.classList.add('step-process-indicator__step--completed');
        step3.classList.remove('step-process-indicator__step--active');
      }
      
      console.log('✓ Step 3 (£45 OFF): Checkmark (completed)');
    } else {
      // Show currency symbol, hide checkmark
      if (currencySymbol) currencySymbol.style.display = '';
      if (checkmark) checkmark.style.display = 'none';
      
      // Set active or inactive state
      if (step3) {
        step3.classList.remove('step-process-indicator__step--completed');
        if (isActive) {
          step3.classList.add('step-process-indicator__step--active');
        } else {
          step3.classList.remove('step-process-indicator__step--active');
        }
      }
      
      console.log(`£ Step 3 (£45 OFF): Currency symbol (${isActive ? 'active' : 'inactive'})`);
    }
  }
  
  /**
   * Update the progress bar fill based on threshold progress and item count (4 states)
   */
  function updateProgressBar(thresholdReached, cartTotal, threshold, itemCount) {
    const progressFill = document.querySelector('.step-process-indicator__progress-fill');
    
    if (!progressFill) {
      console.warn('⚠️ Progress bar element not found');
      return;
    }
    
    // Remove all progress classes first
    progressFill.classList.remove('progress-zero', 'progress-ten', 'progress-half', 'progress-full');
    
    // STATE 1 (0%): Below shipping threshold
    if (!thresholdReached) {
      progressFill.classList.add('progress-zero');
      updateStep1Icon(false);        // Show truck (active)
      updateStep2Icon(false, false); // Show £ (inactive)
      updateStep3Icon(false, false); // Show £ (inactive)
      console.log('📊 Progress: 0% - Working toward free shipping');
    }
    
    // STATE 2 (10%): Shipping unlocked, <2 CHUUGs
    else if (itemCount < 2) {
      progressFill.classList.add('progress-ten');
      updateStep1Icon(true);         // Show checkmark (completed)
      updateStep2Icon(false, true);  // Show £ (active)
      updateStep3Icon(false, false); // Show £ (inactive)
      console.log('📊 Progress: 10% - Free shipping unlocked, working toward £30 OFF');
    }
    
    // STATE 3 (50%): 2+ CHUUGs, <3 CHUUGs
    else if (itemCount >= 2 && itemCount < 3) {
      progressFill.classList.add('progress-half');
      updateStep1Icon(true);         // Show checkmark (completed)
      updateStep2Icon(true, false);  // Show checkmark (completed)
      updateStep3Icon(false, true);  // Show £ (active)
      console.log('📊 Progress: 50% - £30 OFF unlocked, working toward £45 OFF');
    }
    
    // STATE 4 (100%): 3+ CHUUGs
    else if (itemCount >= 3) {
      progressFill.classList.add('progress-full');
      updateStep1Icon(true);         // Show checkmark (completed)
      updateStep2Icon(true, false);  // Show checkmark (completed)
      updateStep3Icon(true, false);  // Show checkmark (completed)
      console.log('📊 Progress: 100% - £45 OFF unlocked! All milestones complete.');
    }
  }
  
  /**
   * Update the progress header with dynamic message
   */
  async function updateProgressHeader(cartTotal, currency, cartData = null) {
    const header = document.querySelector('[data-progress-header]');
    if (!header) {
      console.warn('⚠️ Progress header element not found');
      return;
    }
    
    // Fetch cart data if not provided
    if (!cartData) {
      try {
        cartData = await getCart();
      } catch (error) {
        console.error('Failed to fetch cart data:', error);
        cartData = { items: [] };
      }
    }
    
    // Count non-gift-box items
    const itemCount = countNonGiftBoxItems(cartData);
    
    const result = calculateAmountNeeded(cartTotal, currency);
    const message = formatProgressMessage(
      result.amountNeeded, 
      result.config, 
      result.thresholdReached,
      currency,
      itemCount
    );
    
    header.innerHTML = message;
    
    // Also update the progress bar with item count
    updateProgressBar(result.thresholdReached, cartTotal, result.config.threshold, itemCount);
    
    console.log('📊 Progress Header & Bar Updated:', {
      currency: currency,
      cartTotal: formatAmount(cartTotal, result.config.symbol),
      threshold: formatAmount(result.config.threshold, result.config.symbol),
      amountNeeded: formatAmount(result.amountNeeded, result.config.symbol),
      thresholdReached: result.thresholdReached,
      itemCount: itemCount,
      percentage: ((cartTotal / result.config.threshold) * 100).toFixed(1) + '%',
      message: message.replace(/<[^>]*>/g, '') // Log without HTML tags
    });
  }
  
  /**
   * Get full cart data from multiple sources
   */
  function getCart() {
    return new Promise((resolve, reject) => {
      // Try cart manager first
      if (window.cartManager && window.cartManager.getCart) {
        window.cartManager.getCart()
          .then(cartData => {
            resolve(cartData);
          })
          .catch(() => {
            // Fallback to fetch
            fetchCart().then(resolve).catch(reject);
          });
      } else {
        // Fallback to fetch
        fetchCart().then(resolve).catch(reject);
      }
    });
  }
  
  /**
   * Get cart total from cart data
   */
  function getCartTotal() {
    return getCart()
      .then(cartData => cartData.total_price || 0)
      .catch(error => {
        console.error('❌ Failed to get cart total:', error);
        return 0;
      });
  }
  
  /**
   * Fetch cart data via Shopify API
   */
  function fetchCart() {
    return fetch('/cart.js')
      .then(response => response.json())
      .catch(error => {
        console.error('❌ Failed to fetch cart:', error);
        return { items: [], total_price: 0 };
      });
  }
  
  /**
   * Initialize progress header on load
   */
  async function initProgressHeader() {
    const currency = getCurrentCurrency();
    
    try {
      const cartData = await getCart();
      const cartTotal = cartData.total_price || 0;
      await updateProgressHeader(cartTotal, currency, cartData);
    } catch (error) {
      console.error('❌ Failed to initialize progress header:', error);
    }
  }
  
  // ========================================
  // EVENT LISTENERS
  // ========================================
  
  /**
   * Hook into modal instance when available
   */
  function hookIntoModalInstance() {
    // Find modal instances (they're stored globally)
    const modalInstances = window.MiniATCModal?.getAllInstances();
    
    if (modalInstances && modalInstances.size > 0) {
      modalInstances.forEach((instance, modalId) => {
        console.log('🔗 Hooking into modal instance:', modalId);
        
        // Listen to the modal's viewChanged event
        instance.on('viewChanged', async function(viewName) {
          console.log('📍 View changed to:', viewName);
          if (viewName === 'checkout') {
            // Small delay to ensure DOM is updated
            setTimeout(async () => {
              await initProgressHeader();
              // Setup DOM observer when checkout view is active
              setupCartDOMObserver();
            }, 100);
          }
        });
        
        // Listen to modal opened event
        instance.on('modalOpened', async function() {
          console.log('📍 Modal opened');
          // If checkout view is active, initialize
          const checkoutView = document.querySelector('[data-view="checkout"]');
          if (checkoutView && checkoutView.classList.contains('mini-atc-modal__view--active')) {
            setTimeout(async () => {
              await initProgressHeader();
              // Setup DOM observer
              setupCartDOMObserver();
            }, 100);
          }
        });
        
        // Listen to cart updates from the modal
        instance.on('cartUpdated', async function() {
          console.log('📍 Cart updated via modal');
          setTimeout(async () => await initProgressHeader(), 100);
        });
      });
      
      console.log('✅ Successfully hooked into modal instance(s)');
      return true;
    }
    
    return false;
  }
  
  /**
   * Wait for modal to be ready and hook into it
   */
  function waitForModal() {
    const maxAttempts = 50; // 5 seconds max
    let attempts = 0;
    
    const checkInterval = setInterval(() => {
      attempts++;
      
      if (hookIntoModalInstance()) {
        clearInterval(checkInterval);
        console.log('✅ Modal integration complete');
      } else if (attempts >= maxAttempts) {
        clearInterval(checkInterval);
        console.warn('⚠️ Modal instance not found after 5 seconds, falling back to document events');
        useFallbackEvents();
      }
    }, 100);
  }
  
  /**
   * Fallback to document-level events if modal instance not available
   */
  function useFallbackEvents() {
    // Update when cart changes
    document.addEventListener('cart:updated', async function(event) {
      console.log('📍 cart:updated event received');
      const currency = getCurrentCurrency();
      const cartTotal = event.detail?.total_price || 0;
      const cartData = event.detail?.cart || null;
      await updateProgressHeader(cartTotal, currency, cartData);
    });
    
    // Check periodically when checkout view is visible
    setInterval(async () => {
      const checkoutView = document.querySelector('[data-view="checkout"]');
      if (checkoutView && checkoutView.classList.contains('mini-atc-modal__view--active')) {
        await initProgressHeader();
      }
    }, 2000);
  }
  
  /**
   * Setup global cart event listeners
   * Catches cart updates from any source (product page, cart page, etc.)
   */
  function setupGlobalCartListeners() {
    // Listen to various cart update events
    const cartEvents = [
      'cart:updated',
      'cart:change', 
      'cart:refresh',
      'cartUpdated',
      'cartChanged'
    ];
    
    cartEvents.forEach(eventName => {
      document.addEventListener(eventName, async function(event) {
        console.log(`📍 Global cart event received: ${eventName}`);
        
        // Check if checkout view is active
        const checkoutView = document.querySelector('[data-view="checkout"]');
        if (checkoutView && checkoutView.classList.contains('mini-atc-modal__view--active')) {
          await initProgressHeader();
        }
      });
    });
    
    console.log('🎧 Global cart event listeners registered');
  }
  
  /**
   * Setup MutationObserver to watch for cart item changes
   * This catches when items are added/removed from the checkout view
   */
  function setupCartDOMObserver() {
    const checkoutContainer = document.querySelector('.checkout-products-container');
    
    if (!checkoutContainer) {
      console.warn('⚠️ Checkout container not found for DOM observer');
      return;
    }
    
    const observer = new MutationObserver(async (mutations) => {
      // Check if checkout view is active
      const checkoutView = document.querySelector('[data-view="checkout"]');
      if (!checkoutView || !checkoutView.classList.contains('mini-atc-modal__view--active')) {
        return;
      }
      
      // Check if mutations involve cart item changes
      const hasCartChanges = mutations.some(mutation => {
        return mutation.type === 'childList' || 
               (mutation.target.classList && mutation.target.classList.contains('checkout-products-wrap'));
      });
      
      if (hasCartChanges) {
        console.log('📍 Cart DOM change detected via MutationObserver');
        // Add small delay to ensure cart is updated
        setTimeout(async () => await initProgressHeader(), 200);
      }
    });
    
    observer.observe(checkoutContainer, {
      childList: true,
      subtree: true,
      attributes: false
    });
    
    console.log('👁️ Cart DOM observer activated');
  }
  
  // ========================================
  // INITIALIZATION
  // ========================================
  
  // Setup global cart event listeners immediately
  setupGlobalCartListeners();
  
  // Wait for modal system to be ready
  if (window.MiniATCModal && window.MiniATCModal.getAllInstances) {
    // Modal already initialized
    hookIntoModalInstance();
  } else {
    // Wait for modal to initialize
    document.addEventListener('miniATCModalReady', function() {
      console.log('📢 Mini ATC Modal Ready event received');
      setTimeout(waitForModal, 100);
    });
    
    // Also try waiting for it
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', waitForModal);
    } else {
      waitForModal();
    }
  }
  
  console.log('✅ Progress Header Dynamic Update Script Loaded (with item count tracking + global cart listeners + DOM observer)');
  
})();
</script>

<!-- Countdown Timer -->
