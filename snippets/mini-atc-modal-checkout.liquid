      {%- liquid
        assign countdown_default_text = 'Extra £30 off ends in'
        assign countdown_raw_text = settings.mini_atc_countdown_text | default: countdown_default_text
        assign countdown_display_text = countdown_raw_text | replace: '{amount}', '£30'
      -%}
      <span data-countdown-text data-currency-text="⏰ {{ countdown_display_text }}:" data-amount="3000">⏰ {{ countdown_display_text }}:</span> 
      <time class="countdown-timer__time" id="mini-atc-countdown-timer">
        <span data-countdown-hours>00</span>:<span data-countdown-minutes>00</span>:<span data-countdown-seconds>00</span>
