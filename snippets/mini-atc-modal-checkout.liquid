{% comment %}
  Mini ATC Modal - Checkout View
  
  Semantic checkout summary view with order details and progression indicators.
{% endcomment %}

<!-- Step Process Indicator -->
<section class="step-process-section" aria-labelledby="{{ modal_id }}-progress-heading">
  <h3 id="{{ modal_id }}-progress-heading" class="visually-hidden">Checkout Progress</h3>
  
  <div class="step-process-indicator" role="progressbar" aria-valuenow="2" aria-valuemin="1" aria-valuemax="3">
    <h4 class="step-process-indicator__header">
      🔥 You're only 1 CHUUG away to unlock <span>EXTRA £30 OFF</span>
    </h4>
    
    <div class="step-process-indicator__progress-bar" aria-hidden="true">
      <div class="step-process-indicator__progress-fill"></div>
    </div>
    
    <ol class="step-process-indicator__steps">
      <li class="step-process-indicator__step step-process-indicator__step--completed">
        <div class="step-process-indicator__step-icon" aria-hidden="true">
          <div class="step-process-indicator__step-circle">
            <svg width="15" height="10" viewBox="0 0 15 10" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M1 5L5 9L14 1" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </div>
        <div class="step-process-indicator__step-text">Buy More & Save</div>
      </li>
      
      <li class="step-process-indicator__step step-process-indicator__step--completed">
        <div class="step-process-indicator__step-icon" aria-hidden="true">
          <div class="step-process-indicator__step-circle">
            <svg width="15" height="10" viewBox="0 0 15 10" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M1 5L5 9L14 1" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </div>
        <div class="step-process-indicator__step-text">Free Shipping</div>
      </li>
      
      <li class="step-process-indicator__step step-process-indicator__step--active">
        <div class="step-process-indicator__step-icon" aria-hidden="true">
          <div class="step-process-indicator__step-circle">
            <span class="step-process-indicator__pound-symbol">£</span>
          </div>
        </div>
        <div class="step-process-indicator__step-text">Unlock Extra £30 OFF</div>
      </li>
    </ol>
  </div>
</section>

<!-- Countdown Timer -->
<section class="countdown-section" aria-labelledby="{{ modal_id }}-countdown-heading" data-countdown-section style="display: none;">
  <h3 id="{{ modal_id }}-countdown-heading" class="visually-hidden">Limited Time Offer</h3>
  
  <div class="countdown-timer" role="timer" aria-live="polite" aria-atomic="true">
    <span class="countdown-timer__text">
      <span data-countdown-text>⏰ Extra £30 off ends in:</span> 
      <time class="countdown-timer__time" data-countdown-timer>00:00:00</time>
    </span>
  </div>
</section>

<script>
  // Show countdown section and set dynamic text if flash sale is enabled and configured
  (function() {
    const countdownSection = document.querySelector('[data-countdown-section]');
    const countdownTextElement = document.querySelector('[data-countdown-text]');
    
    if (countdownSection && window.chuugFlashSale && window.chuugFlashSale.enabled && window.chuugFlashSale.endDate && window.chuugFlashSale.endTime) {
      // Show countdown section
      countdownSection.style.display = '';
      
      // Set dynamic text - use mini-ATC specific text, fallback to default
      if (countdownTextElement) {
        const miniAtcText = window.chuugFlashSale.miniAtcText || 'Extra £30 off ends in';
        countdownTextElement.textContent = '⏰ ' + miniAtcText + ':';
      }
      
      console.log('✅ Mini-ATC countdown displayed with text:', window.chuugFlashSale.miniAtcText || 'Extra £30 off ends in');
    } else {
      console.log('ℹ️ Mini-ATC countdown hidden - flash sale not configured');
    }
  })();
</script>

<!-- Order Summary -->
<section class="checkout-summary-section" aria-labelledby="{{ modal_id }}-summary-heading">
  <h3 id="{{ modal_id }}-summary-heading" class="visually-hidden">Order Summary</h3>
  
  <div class="checkout-products-container" data-checkout-items>
    {% comment %} Dynamic cart items will be populated here {% endcomment %}
    {% for item in cart.items %}
      {% render 'checkout-products-wrap', item: item, modal_id: modal_id %}
    {% endfor %}
    
    {% comment %} Placeholder for when no items {% endcomment %}
    <div class="checkout-empty-state" data-empty-state style="display: none;">
    </div>
  </div>
</section>

<!-- Additional Recommendations -->
{% comment %} <section class="additional-recommendations-section" aria-labelledby="{{ modal_id }}-additional-heading">
  <div class="recommendation-separator" role="separator">
    <h4 id="{{ modal_id }}-additional-heading" class="recommendation-separator-text">
      Last Chance Add-Ons
    </h4>
  </div>
  
  <article class="mini-atc-modal__personalization mini-atc-modal__add-extra-cups" data-personalization="extra-cups">
    <header class="mini-atc-modal__personalization-header">
      <div class="mini-atc-modal__personalization-header-content">
        <div class="mini-atc-modal__personalization-icon" aria-hidden="true">
          {% render 'personalization-icon', icon_type: 'cup' %}
        </div>
        <h5>Add Extra Insulated Cups?</h5>
      </div>
      
      <div class="mini-atc-modal__personalization-header-content_right">
        <a href="#" class="mini-atc-modal__design-link" aria-describedby="{{ modal_id }}-extra-preview-tooltip">
          See preview
        </a>
        {% render 'icon-question-mark-tooltip', 
          tooltip_text: 'Learn more about vessel personalization options',
          tooltip_id: modal_id | append: '-extra-preview-tooltip' 
        %}
        
        <div class="mini-atc-modal__toggle-container">
          <label class="mini-atc-modal__toggle" for="{{ modal_id }}-extra-cups-toggle">
            <input 
              type="checkbox" 
              id="{{ modal_id }}-extra-cups-toggle"
              data-personalization-toggle="extra-cups"
              aria-describedby="{{ modal_id }}-extra-cups-description"
            >
            <span class="mini-atc-modal__toggle-slider" aria-hidden="true"></span>
            <span class="visually-hidden">Enable extra cups at checkout</span>
          </label>
        </div>
      </div>
    </header>
    
    <div id="{{ modal_id }}-extra-cups-description" class="visually-hidden">
      Toggle to add extra insulated cups to your final order
    </div>
  </article>
</section> {% endcomment %}

<!-- Checkout Actions -->
{% comment %} <nav class="checkout-actions-section" aria-labelledby="{{ modal_id }}-actions-heading">
  <h3 id="{{ modal_id }}-actions-heading" class="visually-hidden">Checkout Actions</h3>
  
  <button 
    type="button"
    class="mini-atc-modal__back-btn"
    data-modal-action="back-to-personalize"
    aria-describedby="{{ modal_id }}-back-description"
  >
    ← Back to Personalization
  </button>
  
  <div id="{{ modal_id }}-back-description" class="visually-hidden">
    Return to the personalization view to modify your selections
  </div>
</nav> {% endcomment %}

<script>
// Log cart data for debugging - runs once when checkout view loads
(function() {
  // Prevent multiple executions
  if (window.checkoutDebugScriptLoaded) {
    return;
  }
  window.checkoutDebugScriptLoaded = true;
  
  // Log Liquid cart data that was available at render time
  const liquidCartData = {
    itemCount: {{ cart.items.size }},
    note: {{ cart.note | json }},
    attributes: {{ cart.attributes | json }},
    items: [
      {% for debug_item in cart.items %}
        {
          id: {{ debug_item.id }},
          title: {{ debug_item.product.title | json }},
          variant_title: {{ debug_item.variant.title | json }},
          quantity: {{ debug_item.quantity }},
          price: {{ debug_item.price }},
          final_price: {{ debug_item.final_price }},
          properties: {{ debug_item.properties | json }},
          product_type: {{ debug_item.product.type | json }},
          vendor: {{ debug_item.product.vendor | json }}
        }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ]
  };
  
  // Console log the cart data for debugging
  console.log('🛒 LIQUID CART DATA:', liquidCartData);
  console.log('🛒 Cart items count:', liquidCartData.itemCount);
  console.log('🛒 Cart note:', liquidCartData.note);
  console.log('🛒 Cart attributes:', liquidCartData.attributes);
  console.log('🛒 All cart items:', liquidCartData.items);
  
  
  // Check for gift box items in Liquid data
  const giftBoxItems = liquidCartData.items.filter(item => {
    const title = (item.title || '').toLowerCase();
    return title.includes('gift') || title.includes('box');
  });
  
  console.log('🛒 Gift box items in Liquid data:', giftBoxItems);
  

  // Gift box state management - allow enabled state to persist
  // Removed forced disabling logic to allow gift box to display when enabled
  
  // Force update pricing display elements directly as backup
  function forceUpdatePricingDisplay() {
    // Look for pricing placeholder elements
    const pricingPlaceholders = document.querySelectorAll('.pricing-placeholder');
    const currentPriceElements = document.querySelectorAll('[data-current-price], .mini-atc-modal__current-price');

    // Check if we can get the correct price from POMC system
    if (window.pomcSystem && window.pomcSystem.getSelectedProductAmountData) {
      try {
        const productData = window.pomcSystem.getSelectedProductAmountData();

        if (productData && productData.price) {
          const correctPrice = (productData.price / 100).toFixed(2);
          const formattedPrice = `£${correctPrice}`;

          pricingPlaceholders.forEach(el => {
            if (el.textContent !== formattedPrice) {
              el.textContent = formattedPrice;
            }
          });

          currentPriceElements.forEach(el => {
            const placeholder = el.querySelector('.pricing-placeholder');
            if (placeholder && placeholder.textContent !== formattedPrice) {
              placeholder.textContent = formattedPrice;
            }
          });
        }
      } catch (error) {
      }
    }
  }
  
  // Force update pricing display immediately if systems are ready
  forceUpdatePricingDisplay();
  
  // Watch for dynamic price changes
  function watchForPriceChanges() {
    const targetNodes = document.querySelectorAll('.pricing-placeholder, [data-current-price]');

    if (targetNodes.length > 0) {
      const observer = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
          if (mutation.type === 'childList' || mutation.type === 'characterData') {
            const target = mutation.target;
            const element = target.nodeType === Node.TEXT_NODE ? target.parentElement : target;

            // Monitor price changes
            if (element && (element.classList.contains('pricing-placeholder') || element.hasAttribute('data-current-price'))) {
              // Price change detected - could add logic here if needed
            }
          }
        });
      });

      targetNodes.forEach(node => {
        observer.observe(node, {
          childList: true,
          subtree: true,
          characterData: true
        });
      });
    }
  }
  
  // Start watching for price changes
  watchForPriceChanges();
  
  // Gift box items are now allowed to remain in cart
  // Removed auto-removal logic to allow gift box display
  
  // Also fetch current cart data via JavaScript API
  if (window.cartManager) {
    window.cartManager.getCart()
      .then(cartData => {
        console.log('🛒 CART MANAGER DATA:', cartData);
        console.log('🛒 Cart Manager items:', cartData.items);
        
        // Update progress indicator based on cart items
        updateProgressIndicatorOnLoad(cartData);
      })
      .catch(error => {
        console.error('🛒 Cart Manager error:', error);
      });
  } else {
    // Fallback if cart manager isn't available yet
    fetch('/cart.js')
      .then(response => response.json())
      .then(cartData => {
        console.log('🛒 FETCH CART DATA:', cartData);
        console.log('🛒 Fetch items:', cartData.items);
        
        // Check for gift box items in JavaScript data
        const jsGiftBoxItems = (cartData.items || []).filter(item => {
          const title = (item.product_title || item.title || '').toLowerCase();
          return title.includes('gift') || title.includes('box');
        });
        
        console.log('🛒 Gift box items found:', jsGiftBoxItems);
        
        // Update progress indicator based on cart items
        updateProgressIndicatorOnLoad(cartData);
      })
      .catch(error => {
        console.error('🛒 Fetch cart error:', error);
      });
  }
  
  // Helper function to update progress indicator on initial load
  function updateProgressIndicatorOnLoad(cartData) {
    try {
      // Count non-gift-box items in the cart
      let nonGiftBoxItemCount = 0;
      
      if (cartData && cartData.items) {
        nonGiftBoxItemCount = cartData.items.filter(item => {
          // Check if this item is NOT a gift box
          if (item.properties && item.properties['Add-on'] === 'Premium Gift Box') {
            return false; // Exclude gift boxes
          }
          return true; // Include all other items
        }).length;
      }
      
      console.log(`📊 Progress Indicator (Initial Load): ${nonGiftBoxItemCount} non-gift-box items in cart`);
      
      // Find the progress fill element
      const progressFill = document.querySelector('.step-process-indicator__progress-fill');
      
      if (progressFill) {
        // Remove all progress classes first
        progressFill.classList.remove('progress-full', 'progress-half');
        
        // Add appropriate class based on non-gift-box item count
        if (nonGiftBoxItemCount >= 2) {
          progressFill.classList.add('progress-full');
          console.log('📊 Progress Indicator (Initial Load): Added progress-full class (2+ items)');
        } else if (nonGiftBoxItemCount === 1) {
          progressFill.classList.add('progress-half');
          console.log('📊 Progress Indicator (Initial Load): Added progress-half class (1 item)');
        } else {
          console.log('📊 Progress Indicator (Initial Load): No progress class (0 items)');
        }
      }
    } catch (error) {
      console.error("Failed to update progress indicator on load:", error);
    }
  }

})();
</script>
