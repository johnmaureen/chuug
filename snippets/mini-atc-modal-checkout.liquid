  </div>
</section>

<script>
  // Show countdown section when checkout view is active
  // Countdown timer logic is handled by global system in theme.liquid
  (function() {
    const countdownSection = document.querySelector('[data-countdown-section]');
    
    if (countdownSection) {
      countdownSection.style.display = '';
      console.log('✅ Mini-ATC countdown section displayed (using global countdown)');
    }
    
    // Re-initialize global countdown when modal opens or view changes
    document.addEventListener('viewChanged', function(event) {
      if (event.detail === 'checkout' && window.chuugCountdown) {
        window.chuugCountdown.init();
      }
    });
  })();
</script>

