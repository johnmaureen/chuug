
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Set the countdown time (2 hours 7 minutes) in seconds
    const initialTime = 2 * 60 * 60 + 7 * 60; // 2 hours and 7 minutes in seconds

    // Function to calculate the time remaining based on previous session
    function getTimeRemaining() {
        const savedTime = localStorage.getItem('countdownTimer');
        const currentTime = Math.floor(Date.now() / 1000); // current time in seconds

        if (savedTime) {
            const remainingTime = initialTime - (currentTime - savedTime);
            return remainingTime > 0 ? remainingTime : 0;
        } else {
            // Store the start time if not already set
            localStorage.setItem('countdownTimer', currentTime);
            return initialTime;
        }
    }

    let timeRemaining = getTimeRemaining();

    // Function to update the countdown timer display
    function updateCountdownDisplay(hours, minutes, seconds) {
        document.getElementById('hours').textContent = String(hours).padStart(2, '0');
        document.getElementById('minutes').textContent = String(minutes).padStart(2, '0');
        document.getElementById('seconds').textContent = String(seconds).padStart(2, '0');
    }

    // Countdown logic
    function startCountdown() {
        let countdownInterval = setInterval(function() {
            if (timeRemaining > 0) {
                timeRemaining--;

                // Convert time to HH:MM:SS
                const hours = Math.floor(timeRemaining / 3600);
                const minutes = Math.floor((timeRemaining % 3600) / 60);
                const seconds = timeRemaining % 60;

              //  updateCountdownDisplay(hours, minutes, seconds);
            } else {
                // Restart the timer when it reaches zero
                timeRemaining = initialTime;
                localStorage.setItem('countdownTimer', Math.floor(Date.now() / 1000)); // Reset the start time
            }
        }, 1000);
    }

    startCountdown();
});
</script>


