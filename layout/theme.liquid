<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Function to show the message
    function showMessage() {
      var messageElement = document.querySelector('.bss-pl-banner-wrapper');
      if (messageElement) {
        messageElement.style.display = 'block';
      }
    }

    // Function to check if the visitor is within the first 24 hours
    function isWithinFirstDay() {
      var now = new Date().getTime();
      var visitedAt = localStorage.getItem('visitedAt');
      return now - visitedAt <= 24 * 60 * 60 * 1000; // 24 hours in milliseconds
    }

    // Check if this is the first visit or within the first 24 hours
    if (!localStorage.getItem('visitedAt')) {
      // First-time visitor
      localStorage.setItem('visitedAt', new Date().getTime());
      showMessage();
      console.log("Its First time!");
    } else if (isWithinFirstDay()) {
      // Visitor within the first 24 hours
      showMessage();
      console.log("its first day!");
    }
    else{
    	console.log("Not Show!");
    }
  });
</script>

    
    
