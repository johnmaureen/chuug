      				  TAX = item.wcp_v_price * (TAX.dpTaxPercent / 100);                      
      				  price = item.wcp_v_price - TAX;                      
      				  element.innerHTML =  Shopify.formatMoney(price, dpWPDmoneyFormate);
          		   }
      			 }
          	  });
